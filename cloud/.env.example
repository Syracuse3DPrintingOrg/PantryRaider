# Copy to .env on the VPS and fill in real values. Never commit .env.

# The public domain Caddy serves (DNS must point at this VPS).
CLOUD_DOMAIN=forager.pantryraider.app

# Postgres password for the pantrycloud database (pick a long random value).
POSTGRES_PASSWORD=change-me

# Stripe webhook endpoint secret, from the Stripe dashboard (whsec_...).
# REQUIRED for billing: the webhook REFUSES to process while this is left at
# the placeholder below, because that value is public in this repo and anyone
# could forge events to grant themselves premium. Replace it with the real
# signing secret from your Stripe endpoint before going live.
CLOUD_STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Stripe price id for the starter plan (price_...). The plan's price is set
# in the Stripe dashboard; this id maps purchases to the starter quota.
# Stripe price ids per plan (create the prices in the Stripe dashboard).
CLOUD_STRIPE_PRICE_BASIC_YEAR=
CLOUD_STRIPE_PRICE_PREMIUM_MONTH=
CLOUD_STRIPE_PRICE_PREMIUM_YEAR=
# Deprecated alias, still maps a purchase to premium if set.
CLOUD_STRIPE_PRICE_STARTER=

# Stripe Checkout link the portal's Subscribe button points at. Leave empty
# until billing goes live; the account page says so instead of showing a
# dead button.
CLOUD_STRIPE_CHECKOUT_URL=

# Google sign-in ("Continue with Google"), from a Google Cloud OAuth client.
# Leave both empty to hide Google sign-in entirely. The OAuth client must
# register https://forager.pantryraider.app/auth/google/callback as a
# redirect URI (CLOUD_PUBLIC_BASE_URL overrides the origin).
CLOUD_GOOGLE_CLIENT_ID=
CLOUD_GOOGLE_CLIENT_SECRET=

# Admin panel access: comma-separated account emails allowed into /admin.
# Leave empty to lock the panel to nobody; anyone not listed gets a 404.
CLOUD_ADMIN_EMAILS=

# --- Outgoing email (password reset, verification) ---
# Dark until CLOUD_SMTP_HOST and CLOUD_SMTP_FROM are both set: the forgot-
# password link, verification emails, and the verify banner only appear once
# email is configured. Production uses Resend over SMTP: host smtp.resend.com,
# user "resend", password = your Resend API key. Port 587 with STARTTLS (the
# default) or port 465 with CLOUD_SMTP_STARTTLS=0 (SMTP_SSL).
CLOUD_SMTP_HOST=
CLOUD_SMTP_PORT=587
CLOUD_SMTP_USER=
CLOUD_SMTP_PASSWORD=
CLOUD_SMTP_FROM=noreply@forager.pantryraider.app
CLOUD_SMTP_STARTTLS=1

# The AI proxy upstream: "gemini" in production, "stub" for local testing.
CLOUD_AI_FORWARDER=gemini

# Google AI Studio API key backing the proxy (Gemini 2.5 Flash).
CLOUD_GEMINI_API_KEY=

# --- Remote-access tunnel (WireGuard + Caddy) ---
# See cloud/vps/README.md for the full VPS setup. These pair the cloud app
# with the tunnel agent and the WireGuard server on the VPS.
# The public WireGuard endpoint kitchens dial out to (host:port).
CLOUD_TUNNEL_ENDPOINT=forager.pantryraider.app:51820
# The VPS WireGuard server's public key (from /etc/wireguard/server_public.key).
CLOUD_TUNNEL_SERVER_PUBLIC_KEY=
# The tunnel network kitchens are allocated /32s from.
CLOUD_TUNNEL_CIDR=10.99.0.0/16
# Where the cloud app reaches the tunnel agent. Use 127.0.0.1 when both run on
# the host, or the sidecar name (http://tunnel-agent:9300) in compose.
CLOUD_TUNNEL_AGENT_URL=http://127.0.0.1:9300
# The shared token the app presents to the agent; the agent reads the same
# value from /etc/forager/tunnel-token.
CLOUD_TUNNEL_AGENT_TOKEN=

# Cloudflare Turnstile signup CAPTCHA (free, from the Cloudflare Turnstile
# dashboard). Both must be set for the widget to render and verify.
CLOUD_TURNSTILE_SITE_KEY=
CLOUD_TURNSTILE_SECRET=

# --- Two-factor authenticator secret encryption ---
# Encryption key for the base32 TOTP seed stored on each 2FA-enabled account.
# The seed is the one stored credential that is directly usable, so it is kept
# encrypted at rest under this key (held here, out of the database). REQUIRED
# once any account turns on two-factor sign-in: the app refuses to start when
# enrolled accounts exist without it, and the migration that encrypts existing
# seeds fails loudly rather than leave them in the clear. Generate a value with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Set it once and keep it: losing it locks every enrolled account out of its
# second factor (they would recover with a recovery code or support). A brand-
# new deploy with no 2FA users can leave this empty until the first enrollment.
CLOUD_TOTP_SECRET_KEY=

# --- Privacy: anonymous-reporter hashing ---
# Secret mixed into the hash of an anonymous reporter's IP before it is stored,
# so the database never holds a raw address and the short hash cannot be
# brute-forced back to one from a dump. Set this to a long random value (for
# example: openssl rand -base64 32) and leave it: changing it only resets
# anonymous-report dedupe, nothing else. If you leave it empty the service
# generates a random pepper and persists it under its data directory, so the
# hash is never unsalted; set it explicitly to keep the value under your control.
CLOUD_REPORT_IP_PEPPER=

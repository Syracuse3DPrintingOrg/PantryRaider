#!/usr/bin/env python3
"""Forager tunnel agent.

Runs on the VPS as root (not in Docker), listening on 127.0.0.1:9300. The
cloud app (behind Caddy on the same host, or a compose sidecar) asks it to
program the two things a kitchen tunnel needs and that only root can touch:
the WireGuard interface wg0 and Caddy's per-kitchen reverse-proxy routes.

The app never runs `wg` or edits Caddy itself; it calls here with the shared
token so the privileged surface stays small and auditable.

Authentication: every route except GET /health requires the X-Tunnel-Token
header to match the token in /etc/forager/tunnel-token (the same value the
cloud app holds as CLOUD_TUNNEL_AGENT_TOKEN).

Endpoints
---------
GET    /health   liveness probe (no token)
POST   /peer     add or update a peer + its Caddy route
                 {public_key, tunnel_ip, domain}
DELETE /peer     remove a peer + its Caddy route  {public_key}

State: the agent keeps its own view of the live peers in a small JSON file
(PEERS_STATE) so it can regenerate the Caddy include and re-apply peers after
a restart. WireGuard peers are also written into wg0's config via `wg-quick
save` so they survive an interface bounce.

The pure helpers (the peers store shape, the Caddy include renderer) carry no
side effects, so cloud/tests exercises them without wg or Caddy present.
"""
import hmac
import http.server
import json
import os
import subprocess
import sys
from pathlib import Path

# Bind host: 127.0.0.1 by default (agent and app on the same host netns).
# When the cloud app runs in Docker and the agent on the host, set this to the
# compose network's gateway IP (an internal-only address, e.g. 172.28.0.1) via
# FORAGER_TUNNEL_AGENT_HOST so containers can reach it while the public
# internet cannot. Never bind 0.0.0.0: that would expose a root helper.
LISTEN_HOST = os.environ.get("FORAGER_TUNNEL_AGENT_HOST", "127.0.0.1")
LISTEN_PORT = int(os.environ.get("FORAGER_TUNNEL_AGENT_PORT", "9300"))

WG_INTERFACE = "wg0"
# The Caddy include the app writes and Caddy imports. One site block per
# kitchen; regenerated in full on every change so it always matches state.
CADDY_KITCHENS_FILE = "/etc/caddy/forager-kitchens.caddy"
# The port the kitchen's Pantry Raider app listens on, reached over the
# tunnel. Same 9284 the app uses everywhere.
KITCHEN_APP_PORT = 9284
# Where the agent remembers the live peers between restarts.
PEERS_STATE = "/etc/forager/tunnel-peers.json"
# The shared token file. Written out-of-band during VPS setup (see the VPS
# README); the cloud app carries the same value in CLOUD_TUNNEL_AGENT_TOKEN.
TOKEN_PATH = "/etc/forager/tunnel-token"

_EXPECTED_TOKEN = ""


# --- Pure helpers (unit-tested; no wg, Caddy, or disk) --------------------

def render_kitchen_block(domain: str, tunnel_ip: str,
                         app_port: int = KITCHEN_APP_PORT) -> str:
    """One Caddy site block routing a kitchen's public domain to its app over
    the tunnel. TLS is left to the global on_demand config in the Caddyfile."""
    return (f"{domain} {{\n"
            f"\treverse_proxy {tunnel_ip}:{app_port}\n"
            f"}}\n")


def render_caddy_config(peers, app_port: int = KITCHEN_APP_PORT) -> str:
    """The full forager-kitchens.caddy include from the peer list.

    ``peers`` is an iterable of dicts with "domain" and "tunnel_ip". Sorted by
    domain so the file is stable (no spurious reloads from dict ordering), and
    peers missing a domain are skipped rather than rendered into a broken
    block.
    """
    usable = [p for p in peers if p.get("domain") and p.get("tunnel_ip")]
    usable.sort(key=lambda p: p["domain"])
    header = ("# Managed by forager-tunnel-agent. Do not edit by hand; this\n"
              "# file is regenerated whenever a kitchen tunnel changes.\n")
    if not usable:
        return header
    blocks = [render_kitchen_block(p["domain"], p["tunnel_ip"], app_port)
              for p in usable]
    return header + "\n".join(blocks)


def upsert_peer(peers, public_key: str, tunnel_ip: str, domain: str):
    """Add or update a peer in the store (a list of dicts), keyed by public
    key. Returns a new list, leaving the input untouched."""
    out = [p for p in peers if p.get("public_key") != public_key]
    out.append({"public_key": public_key, "tunnel_ip": tunnel_ip,
                "domain": domain})
    return out


def remove_peer_entry(peers, public_key: str):
    """The store with any peer matching ``public_key`` dropped."""
    return [p for p in peers if p.get("public_key") != public_key]


def token_ok(provided: str, expected: str) -> bool:
    """Constant-time token check. An empty expected token denies everything
    (the agent refuses to run open); an empty provided token is a plain deny."""
    if not expected or not provided:
        return False
    return hmac.compare_digest(provided.strip(), expected.strip())


# --- Side-effecting layer (wg, Caddy, disk); stubbed in tests -------------

def run_command(args) -> None:
    """Run a command with no shell. Raises CalledProcessError on failure.

    Isolated here (never shell=True, always an arg list) so the request
    handlers stay declarative and tests replace this with a recorder."""
    subprocess.run(args, check=True)


def load_peers(path: str = None):
    # Resolved at call time (not bound as a default) so a test or an env
    # override of PEERS_STATE takes effect.
    path = path or PEERS_STATE
    try:
        return json.loads(Path(path).read_text())
    except (OSError, ValueError):
        return []


def save_peers(peers, path: str = None) -> None:
    path = path or PEERS_STATE
    tmp = f"{path}.tmp"
    Path(tmp).write_text(json.dumps(peers, indent=2))
    os.replace(tmp, path)


def write_caddy_config(peers, path: str = None) -> None:
    path = path or CADDY_KITCHENS_FILE
    tmp = f"{path}.tmp"
    Path(tmp).write_text(render_caddy_config(peers))
    os.replace(tmp, path)


def apply_add(public_key: str, tunnel_ip: str, domain: str) -> None:
    """Bring a peer fully online: wg peer, saved config, Caddy route, reload."""
    run_command(["wg", "set", WG_INTERFACE, "peer", public_key,
                 "allowed-ips", f"{tunnel_ip}/32",
                 "persistent-keepalive", "25"])
    run_command(["wg-quick", "save", WG_INTERFACE])
    peers = upsert_peer(load_peers(), public_key, tunnel_ip, domain)
    save_peers(peers)
    write_caddy_config(peers)
    run_command(["systemctl", "reload", "caddy"])


def apply_remove(public_key: str) -> None:
    """Tear a peer down: drop it from wg0, the store, and Caddy, then reload."""
    run_command(["wg", "set", WG_INTERFACE, "peer", public_key, "remove"])
    run_command(["wg-quick", "save", WG_INTERFACE])
    peers = remove_peer_entry(load_peers(), public_key)
    save_peers(peers)
    write_caddy_config(peers)
    run_command(["systemctl", "reload", "caddy"])


# --- HTTP layer -----------------------------------------------------------

class Handler(http.server.BaseHTTPRequestHandler):
    server_version = "forager-tunnel-agent"

    def log_message(self, fmt, *args):
        sys.stderr.write("tunnel-agent: " + (fmt % args) + "\n")

    def _send(self, status: int, body: dict) -> None:
        payload = json.dumps(body).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def _authed(self) -> bool:
        return token_ok(self.headers.get("X-Tunnel-Token", ""), _EXPECTED_TOKEN)

    def _read_json(self) -> dict:
        length = int(self.headers.get("Content-Length", 0) or 0)
        if not length:
            return {}
        try:
            return json.loads(self.rfile.read(length))
        except ValueError:
            return {}

    def do_GET(self):
        if self.path.split("?", 1)[0] == "/health":
            self._send(200, {"status": "ok", "app": "forager-tunnel-agent"})
            return
        self._send(404, {"error": "not_found"})

    def do_POST(self):
        if self.path.split("?", 1)[0] != "/peer":
            self._send(404, {"error": "not_found"})
            return
        if not self._authed():
            self._send(403, {"error": "forbidden"})
            return
        body = self._read_json()
        public_key = str(body.get("public_key", "")).strip()
        tunnel_ip = str(body.get("tunnel_ip", "")).strip()
        domain = str(body.get("domain", "")).strip()
        if not public_key or not tunnel_ip:
            self._send(400, {"error": "public_key and tunnel_ip are required"})
            return
        try:
            apply_add(public_key, tunnel_ip, domain)
        except Exception as exc:  # noqa: BLE001 - report, do not crash the loop
            self.log_message("peer add failed: %s", exc)
            self._send(500, {"error": "peer_add_failed"})
            return
        self._send(200, {"ok": True})

    def do_DELETE(self):
        if self.path.split("?", 1)[0] != "/peer":
            self._send(404, {"error": "not_found"})
            return
        if not self._authed():
            self._send(403, {"error": "forbidden"})
            return
        body = self._read_json()
        public_key = str(body.get("public_key", "")).strip()
        if not public_key:
            self._send(400, {"error": "public_key is required"})
            return
        try:
            apply_remove(public_key)
        except Exception as exc:  # noqa: BLE001
            self.log_message("peer remove failed: %s", exc)
            self._send(500, {"error": "peer_remove_failed"})
            return
        self._send(200, {"ok": True})


class _ThreadingServer(http.server.ThreadingHTTPServer):
    daemon_threads = True


def _load_token(path: str = TOKEN_PATH) -> str:
    try:
        return Path(path).read_text().strip()
    except OSError:
        return ""


def main() -> int:
    global _EXPECTED_TOKEN
    _EXPECTED_TOKEN = _load_token()
    if not _EXPECTED_TOKEN:
        sys.stderr.write(
            f"tunnel-agent: no token at {TOKEN_PATH}; refusing to start "
            "(create it and restart)\n")
        return 1
    server = _ThreadingServer((LISTEN_HOST, LISTEN_PORT), Handler)
    sys.stderr.write(f"tunnel-agent: listening on {LISTEN_HOST}:{LISTEN_PORT}\n")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

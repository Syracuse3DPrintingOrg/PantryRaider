# TLS termination for Forager.
#
# Two kinds of site are served here:
#   1. The apex, forager.pantryraider.app: the portal, API, and Stripe
#      webhook, reverse-proxied to the app container. Caddy fetches and
#      renews the certificate automatically once CLOUD_DOMAIN's DNS points
#      at this VPS.
#   2. Per-kitchen subdomains, <sub>.forager.pantryraider.app: each kitchen's
#      remote-access tunnel. These are issued on demand (no wildcard cert, no
#      DNS API token): when a browser asks for a subdomain Caddy has not
#      seen, it first calls the app's tls-check endpoint, and only issues a
#      certificate if the app recognizes a live tunnel for that name.
#
# DNS: point *.forager.pantryraider.app (A) at this VPS in addition to the
# apex, so every kitchen subdomain resolves here. The per-subdomain routes
# themselves live in the agent-managed import below.

# Caddy runs on the VPS HOST (not in the compose stack): only a host-network
# Caddy can reach both the app (published on 127.0.0.1:8000) and the kitchen
# tunnel peers (10.99.0.0/16 on wg0, which lives in the host netns). The app
# and Postgres stay in Docker Compose; Caddy, WireGuard, and the tunnel agent
# run on the host.
{
	# On-demand TLS ask target. Caddy issues a certificate for an unknown
	# host only when this endpoint answers 200; the app returns 200 solely
	# for a known kitchen subdomain with a live tunnel, so this gates cert
	# issuance to real kitchens and nothing else.
	on_demand_tls {
		ask http://127.0.0.1:8000/v1/tunnel/tls-check
		# A safety rail on issuance rate, so a flood of bogus hostnames
		# cannot drive Caddy to hammer the ACME endpoint.
		interval 2m
		burst 5
	}
}

# The apex: portal, API, webhook.
{$CLOUD_DOMAIN} {
	reverse_proxy 127.0.0.1:8000
}

# Per-kitchen tunnel routes, regenerated by forager-tunnel-agent whenever a
# kitchen enables or disables remote access. Each block reverse-proxies one
# subdomain to that kitchen's app over the WireGuard tunnel. VPS setup creates
# this file empty (`touch`), so the import always resolves even before the
# first kitchen enables remote access.
import /etc/caddy/forager-kitchens.caddy

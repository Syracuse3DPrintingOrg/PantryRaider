# FoodAssistant appliance configuration
# =====================================
# This file is read once by the first-boot provisioner
# (scripts/image-build/firstboot.sh). Edit it BEFORE flashing, or edit it on
# the boot partition of the SD card after flashing (it is copied to
# /boot/firmware/foodassistant.config.env by the image-prep step).
#
# Every value is optional; the defaults below produce a working
# FoodAssistant + Grocy appliance reachable at http://foodassistant.local:9284/
#
# Format: KEY=value  (POSIX shell assignment — no spaces around '=', quote
# values that contain spaces). Lines starting with '#' are comments.

# ── Identity / network ─────────────────────────────────────────────────────
# Hostname for the box. Also drives the mDNS name: <HOSTNAME>.local
HOSTNAME=foodassistant

# Timezone (IANA name, e.g. America/New_York, Europe/London, UTC).
TZ=America/New_York

# ── Backends (Docker Compose profiles) ─────────────────────────────────────
# Grocy (inventory) is the core backend and is always enabled.
# Set these to "true" to additionally start the optional services.
ENABLE_MEALIE=false
ENABLE_OLLAMA=false

# ── Kiosk mode ─────────────────────────────────────────────────────────────
# When "true" AND a display is detected, the box auto-launches a full-screen
# Chromium kiosk pointed at the FoodAssistant UI. Leave "false" for headless
# server installs (the default).
ENABLE_KIOSK=false

# URL the kiosk opens. Defaults to the local UI; change if you front the app
# with a reverse proxy.
KIOSK_URL=http://localhost:9284/ui/

# ── Stream Deck controller (opt-in) ────────────────────────────────────────
# When "true", the provisioner installs the Stream Deck Python package and
# wires up a systemd service to drive an Elgato Stream Deck. Requires an
# Elgato Stream Deck to be connected via USB.
ENABLE_STREAMDECK=false

# ── Image / registry ───────────────────────────────────────────────────────
# Pin a specific FoodAssistant image tag (default: latest).
FOODASSISTANT_TAG=latest

# Where the stack is installed on the device.
INSTALL_DIR=/opt/foodassistant

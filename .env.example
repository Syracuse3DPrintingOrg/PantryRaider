# FoodAssistant — environment variables
#
# The web setup wizard at http://localhost:9284/setup writes to
# service/data/settings.json and is the recommended way to configure
# the app.  Variables set here take priority over the wizard's values,
# making this file useful for CI, scripted deploys, or overrides.
#
# Copy to .env and fill in any values you want to pin via env var:
#   cp .env.example .env

# ── Vision Provider ────────────────────────────────────────────────────────────
# "gemini" (default), "openai", "anthropic" (cloud) or "ollama" (local).
VISION_PROVIDER=gemini

# Gemini — get a free key at aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI — platform.openai.com → API keys (model must be vision-capable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — console.anthropic.com → API Keys
# claude-opus-4-8 is the most capable; claude-haiku-4-5 the budget option.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Ollama — run with:  docker compose --profile with-ollama up -d
# then: docker exec foodassistant-ollama ollama pull llava:7b
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llava:7b

# ── Barcode Scan Enrichment ────────────────────────────────────────────────────
# Scanned barcodes are looked up in Open Food Facts, whose names/categories are
# contributor-entered and often messy ("zero sugar" for Dr Pepper Zero). With
# BARCODE_ENRICHMENT=llm the LLM cleans up the name, category, storage location,
# and shelf-life estimate per scan (one small text call). Set to "off" to use
# Open Food Facts heuristics only.
BARCODE_ENRICHMENT=llm
# Provider used for enrichment: "gemini", "openai", "anthropic", "ollama", or
# empty to follow VISION_PROVIDER. For a fully local pipeline set
# VISION_PROVIDER=ollama (or just this to "ollama" to keep a cloud provider
# for photos but enrich locally).
ENRICH_PROVIDER=
# Model override for enrichment; empty uses the chosen provider's model above.
# Enrichment is text-only, so a small/cheap model works well
# (e.g. claude-haiku-4-5, gpt-4o-mini, llama3.2:3b).
ENRICH_MODEL=

# ── Grocy ──────────────────────────────────────────────────────────────────────
# URL of your Grocy instance (no trailing slash).
# Use the web setup wizard to configure this interactively.
GROCY_BASE_URL=
GROCY_API_KEY=

# ── Mealie (optional) ──────────────────────────────────────────────────────────
# Recipe manager / meal planner / shopping lists. Enables the Meal Plan and
# Shopping pages plus inventory-aware recipe suggestions.
# Run one with: docker compose --profile with-mealie up -d  (port 9285)
# Use a URL your browser can also reach — recipe links open it directly.
# Token: Mealie → User Profile → API Tokens
MEALIE_BASE_URL=
MEALIE_API_KEY=
# Optional external address used only for browser links (e.g. behind a reverse
# proxy). API calls always use MEALIE_BASE_URL. Empty = links use base URL too.
MEALIE_PUBLIC_URL=

# ── Service ────────────────────────────────────────────────────────────────────
# Auto-generated on first run if left empty — you normally don't need to set this.
SECRET_KEY=
DATA_DIR=/app/data

# ── Auth (both optional) ───────────────────────────────────────────────────────
# AUTH_PASSWORD gates the web UI (login page).
# API_KEY lets headless clients (Home Assistant, scripts) authenticate
# by sending an X-API-Key header.
# Leave both empty to disable auth (recommended if behind a reverse proxy).
#   Generate a key: openssl rand -hex 24
AUTH_PASSWORD=
API_KEY=

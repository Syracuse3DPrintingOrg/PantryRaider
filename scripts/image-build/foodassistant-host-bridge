    def _wifi_status(self):
        # Report a structured state the UI can show instead of a bare blank:
        #   no-networkmanager -> nmcli/NetworkManager is not running
        #   no-adapter        -> no wifi hardware on this device
        #   unmanaged         -> wifi device exists but NM does not manage it
        #   disconnected      -> wifi adapter present, no active connection
        #   connected         -> joined a network (ssid is set)
        # The raw default route travels back as "default_route" so the app can
        # classify which link actually carries the network (wired vs wifi) and
        # show a Pi on Ethernet as connected, not as if Wi-Fi has failed
        # (FoodAssistant-1idf). Keeping the classification in the app keeps this
        # bridge helper thin and unit-testable there.
        eth = _ethernet_status()
        route = _default_route_out()
        try:
            if not _nm_running():
                self._send(200, {
                    "ok": True, "state": "no-networkmanager", "ssid": "",
                    "detail": "NetworkManager is not running.", "ethernet": eth,
                    "default_route": route,
                })
                return
            dev_out = subprocess.run(
                ["nmcli", "-t", "-f", "DEVICE,TYPE,STATE", "device"],
                capture_output=True, text=True, timeout=5
            ).stdout
            device, dev_state = _parse_wifi_device(dev_out)
            if not device:
                self._send(200, {
                    "ok": True, "state": "no-adapter", "ssid": "",
                    "detail": "No Wi-Fi adapter found.", "ethernet": eth,
                    "default_route": route,
                })
                return
            if dev_state == "unmanaged":
                self._send(200, {
                    "ok": True, "state": "unmanaged", "ssid": "", "device": device,
                    "detail": "Wi-Fi device is not managed by NetworkManager.",
                    "ethernet": eth, "default_route": route,
                })
                return
            ssid_out = subprocess.run(
                ["nmcli", "-t", "-f", "ACTIVE,SSID", "dev", "wifi"],
                capture_output=True, text=True, timeout=5
            ).stdout
            ssid = _parse_active_ssid(ssid_out)
            self._send(200, {
                "ok": True,
                "state": "connected" if ssid else "disconnected",
                "ssid": ssid,
                "device": device,
                "ethernet": eth,
                "default_route": route,
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e), "ethernet": eth,
                             "default_route": route})

    def _wifi_scan(self):
        try:
            if not _nm_running():
                self._send(200, {
                    "ok": True, "state": "no-networkmanager", "networks": [],
                    "detail": "NetworkManager is not running.",
                })
                return
            dev_out = subprocess.run(
                ["nmcli", "-t", "-f", "DEVICE,TYPE,STATE", "device"],
                capture_output=True, text=True, timeout=5
            ).stdout
            device, _ = _parse_wifi_device(dev_out)
            if not device:
                self._send(200, {
                    "ok": True, "state": "no-adapter", "networks": [],
                    "detail": "No Wi-Fi adapter found.",
                })
                return
            r = subprocess.run(
                ["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY", "dev", "wifi", "list"],
                capture_output=True, text=True, timeout=20
            )
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            self._send(200, {
                "ok": True, "state": "ok",
                "networks": _parse_wifi_scan(r.stdout),
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _wifi_connect(self):
        body = self._body()
        ssid = body.get("ssid", "").strip()
        password = body.get("password", "").strip()
        if not ssid:
            self._send(400, {"ok": False, "error": "ssid is required"})
            return
        try:
            cmd = ["nmcli", "device", "wifi", "connect", ssid]
            if password:
                cmd += ["password", password]
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            if r.returncode == 0:
                self._send(200, {"ok": True})
            else:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _get_hostname(self):
        try:
            hn = subprocess.run(
                ["hostname"], capture_output=True, text=True
            ).stdout.strip()
            self._send(200, {"ok": True, "hostname": hn})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _set_hostname(self):
        body = self._body()
        name = body.get("hostname", "").strip().lower()
        if not name or not re.fullmatch(r"[a-z0-9]([a-z0-9\-]{0,61}[a-z0-9])?", name):
            self._send(400, {"ok": False, "error": "Invalid hostname. Use lowercase letters, digits, and hyphens."})
            return
        try:
            subprocess.run(["hostnamectl", "set-hostname", name], check=True, timeout=10)
            r = subprocess.run(["grep", "-q", r"^127\.0\.1\.1", "/etc/hosts"])
            if r.returncode == 0:
                subprocess.run(
                    ["sed", "-i", rf"s/^127\.0\.1\.1.*/127.0.1.1\t{name}/", "/etc/hosts"],
                    check=True
                )
            else:
                with open("/etc/hosts", "a") as f:
                    f.write(f"127.0.1.1\t{name}\n")
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _get_rotation(self):
        rotation = 0
        try:
            with open("/etc/foodassistant/kiosk-env") as f:
                for line in f:
                    m = re.match(r"^\s*WLR_OUTPUT_TRANSFORM\s*=\s*(\S+)", line)
                    if m:
                        val = m.group(1).strip()
                        rotation = int(val) if val.isdigit() else 0
        except OSError:
            pass
        self._send(200, {"ok": True, "rotation": rotation})

    def _set_rotation(self):
        body = self._body()
        try:
            degrees = int(body.get("degrees", 0))
        except (TypeError, ValueError):
            self._send(400, {"ok": False, "error": "degrees must be 0, 90, 180, or 270"})
            return
        if degrees not in (0, 90, 180, 270):
            self._send(400, {"ok": False, "error": "degrees must be 0, 90, 180, or 270"})
            return
        reboot = bool(body.get("reboot", False))
        # Self-heal a device imaged before the rotation helpers existed: they
        # are reinstalled from the source checkout when missing. apply-rotation
        # is best effort (set-rotation falls back to a kiosk restart without
        # it), but set-rotation itself is required.
        _ensure_helper("foodassistant-apply-rotation")
        helper = _ensure_helper("foodassistant-set-rotation")
        if not helper:
            self._send(500, {"ok": False, "error":
                "The rotation helper is missing on this device. Press Update "
                "under Backup & Updates to install it, then try again."})
            return
        cmd = [helper, str(degrees)]
        if reboot:
            cmd.append("--reboot")
        try:
            # Follow the rotation with the touch matrix (9ohp/mox4): recompose
            # the stored fit for the new rotation, or the pure rotation matrix
            # when the panel was never calibrated, so touch stays aligned with
            # the rotated image (the compositor rotates only the output, never
            # touch). The udev rule is written BEFORE set-rotation runs: it is
            # persistent and picked up on boot, and on the --reboot path the
            # device starts going down inside the command, so writing it after
            # would race the shutdown.
            recomposed = False
            try:
                matrix = _matrix_for_rotation(degrees)
                if matrix:
                    _write_calibration_rule(matrix)
                    recomposed = True
                else:
                    _remove_calibration_rule()
            except Exception:
                pass
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
            if r.returncode != 0:
                # The display rotation did not change; put the touch rule back
                # in step with the still-current rotation.
                try:
                    prev = _matrix_for_rotation(_read_kiosk_rotation())
                    if prev:
                        _write_calibration_rule(prev)
                    else:
                        _remove_calibration_rule()
                except Exception:
                    pass
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            # The compositor only reads the matrix when the touch device is
            # (re)opened, so restart the live kiosk (detached, so a page shown
            # on the kiosk itself gets this response before cage goes down);
            # skipped when a reboot is coming anyway.
            if not reboot and _service_active("foodassistant-kiosk.service"):
                _schedule_kiosk_restart()
            self._send(200, {"ok": True, "calibration_recomposed": recomposed})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _touch_calibrate(self):
        # Apply a LIBINPUT_CALIBRATION_MATRIX by delegating to the calibrate
        # helper's non-interactive mode. The bridge runs as root, so it can
        # write the udev rule and reload udev without sudo (the app service
        # cannot: its unit caps privileges to CAP_NET_BIND_SERVICE).
        body = self._body()
        matrix = (body.get("matrix") or "").strip()
        parts = matrix.split()
        if len(parts) != 6:
            self._send(400, {"ok": False, "error": "matrix must be exactly 6 floats"})
            return
        try:
            [float(p) for p in parts]
        except ValueError:
            self._send(400, {"ok": False, "error": "matrix has a non-numeric value"})
            return
        try:
            # Write the calibration udev rule directly (the bridge runs as root),
            # rather than shelling out to a separately installed helper, so this
            # works even on a device whose touch was configured by hand.
            target = _write_calibration_rule(" ".join(parts))
            # Remember the fit and the rotation it was taken at, so the matrix
            # can follow a later rotation change without recalibrating (9ohp).
            _store_base_calibration(" ".join(parts), _read_kiosk_rotation())
            # The compositor (cage/wlroots) holds the touch device open and only
            # reads LIBINPUT_CALIBRATION_MATRIX when the device is added, so a
            # udevadm trigger alone does not change the live mapping. Restart the
            # kiosk so cage reopens the device and picks up the new matrix. The
            # restart is scheduled detached: the calibration page that posted
            # this request lives inside the kiosk browser, so a synchronous
            # restart killed it before this response could land
            # (FoodAssistant-9ext).
            restarted = False
            if _service_active("foodassistant-kiosk.service"):
                restarted = _schedule_kiosk_restart()
            self._send(200, {
                "ok": True,
                "message": "Calibration applied to %s." % target,
                "kiosk_restarted": restarted,
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _touch_calibrate_reset(self):
        # Remove the calibration fit so touch reverts to the panel/overlay
        # default. Used when a calibration came out wrong; the bridge runs as
        # root and can delete the udev rule and reload udev. On a rotated
        # display the panel default is still unrotated, so the pure rotation
        # matrix is re-applied for the current rotation (identity fit).
        try:
            rule = "/etc/udev/rules.d/99-foodassistant-touch.rules"
            existed = os.path.exists(rule)
            if existed:
                os.remove(rule)
            # Forget the stored base so a later rotation does not re-apply it.
            try:
                os.remove(_CALIB_STORE)
            except OSError:
                pass
            matrix = _matrix_for_rotation(_read_kiosk_rotation())
            if matrix:
                _write_calibration_rule(matrix)
            subprocess.run(["udevadm", "control", "--reload-rules"], timeout=10)
            subprocess.run(["udevadm", "trigger", "--subsystem-match=input"], timeout=10)
            restarted = False
            if _service_active("foodassistant-kiosk.service"):
                restarted = _schedule_kiosk_restart()
            self._send(200, {"ok": True, "removed": existed, "kiosk_restarted": restarted})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _touch_provision(self):
        # Apply the boot config an ADS7846 SPI touch panel needs when the display
        # type was chosen in the wizard after first boot (firstboot never re-runs).
        # Only ads7846 needs a config.txt change; usb/generic/none are a no-op.
        body = self._body()
        driver = (body.get("driver") or "").strip()
        if driver not in ("ads7846", "usb", "generic", "none", ""):
            self._send(400, {"ok": False, "error": "unknown touch driver: %s" % driver})
            return
        reboot = bool(body.get("reboot", False))
        try:
            changed, needs_reboot = _provision_touch(driver)
        except OSError as e:
            self._send(500, {"ok": False, "error": str(e)})
            return
        if reboot and needs_reboot:
            try:
                subprocess.Popen(_reboot_command())
            except Exception:
                pass
        self._send(200, {"ok": True, "changed": changed, "needs_reboot": needs_reboot})

    def _system_timezone_set(self):
        # Set the host timezone via timedatectl so the system clock, logs, and the
        # kiosk browser all read in the chosen zone. The clock stays NTP-synced;
        # only the zone changes. The name is validated against the IANA charset so
        # nothing shell-unfriendly reaches timedatectl.
        body = self._body()
        tz = (body.get("tz") or "").strip()
        if not tz or not re.match(r"^[A-Za-z0-9_+./-]+$", tz):
            self._send(400, {"ok": False, "error": "a valid IANA timezone is required"})
            return
        try:
            r = subprocess.run(["timedatectl", "set-timezone", tz],
                               capture_output=True, text=True, timeout=10)
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            self._send(200, {"ok": True, "timezone": tz})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _scheduled_reboot_set(self):
        # Install (or remove) a systemd timer that reboots the appliance at a
        # fixed local time, nightly or weekly, handy for a kiosk that should
        # refresh itself. An empty time (or frequency "off") removes the timer.
        # HH:MM is validated so OnCalendar is safe.
        body = self._body()
        t = (body.get("time") or "").strip()
        frequency = (body.get("frequency") or "").strip().lower()
        day = body.get("day", 0)
        base = "foodassistant-scheduled-reboot"
        svc = "/etc/systemd/system/%s.service" % base
        tmr = "/etc/systemd/system/%s.timer" % base
        try:
            if not t or frequency == "off":
                subprocess.run(["systemctl", "disable", "--now", "%s.timer" % base],
                               capture_output=True, text=True, timeout=15)
                for f in (svc, tmr):
                    try:
                        os.remove(f)
                    except OSError:
                        pass
                subprocess.run(["systemctl", "daemon-reload"], timeout=15)
                self._send(200, {"ok": True, "scheduled": False})
                return
            if not re.match(r"^([01]\d|2[0-3]):[0-5]\d$", t):
                self._send(400, {"ok": False, "error": "time must be HH:MM (24h)"})
                return
            calendar = _reboot_calendar(t, frequency, day)
            with open(svc, "w") as f:
                f.write("[Unit]\nDescription=FoodAssistant scheduled reboot\n\n"
                        "[Service]\nType=oneshot\nExecStart=/sbin/reboot\n")
            with open(tmr, "w") as f:
                f.write("[Unit]\nDescription=FoodAssistant scheduled reboot timer\n\n"
                        "[Timer]\nOnCalendar=%s\nPersistent=false\n\n"
                        "[Install]\nWantedBy=timers.target\n" % calendar)
            subprocess.run(["systemctl", "daemon-reload"], timeout=15)
            r = subprocess.run(["systemctl", "enable", "--now", "%s.timer" % base],
                               capture_output=True, text=True, timeout=15)
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            self._send(200, {"ok": True, "scheduled": True, "time": t,
                             "calendar": calendar})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_get_config(self):
        try:
            import tomllib
            path = "/opt/foodassistant/config.toml"
            data = {}
            if os.path.exists(path):
                with open(path, "rb") as f:
                    data = tomllib.load(f)
            # Replace the raw on-disk keys with the RESOLVED layout the controller
            # actually uses (defaults to the full DEFAULT_ORDER, drops invalid
            # names), so the web editor mirrors the deck instead of showing a
            # missing or stale key list (FoodAssistant-3y5p). Best-effort: a
            # failure here just leaves the raw keys in place.
            try:
                r = subprocess.run(
                    ["/opt/foodassistant/venv/bin/python", "-m",
                     "foodassistant_streamdeck", "--dump-config", "--config", path],
                    cwd="/opt/foodassistant", capture_output=True, text=True, timeout=10)
                if r.returncode == 0 and r.stdout.strip():
                    resolved = json.loads(r.stdout)
                    if isinstance(resolved.get("keys"), list):
                        data["keys"] = resolved["keys"]
            except Exception:
                pass
            self._send(200, {"ok": True, "config": data})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_set_config(self):
        try:
            body = self._body()
            cfg = body.get("config", {})
            toml_str = _streamdeck_config_toml(cfg)

            path = "/opt/foodassistant/config.toml"
            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, "w") as f:
                f.write(toml_str)
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_actions(self):
        try:
            r = subprocess.run(
                ["/opt/foodassistant/venv/bin/python", "-m", "foodassistant_streamdeck", "--dump-actions"],
                cwd="/opt/foodassistant", capture_output=True, text=True, timeout=10
            )
            if r.returncode == 0 and r.stdout.strip():
                self._send(200, {"ok": True, "actions": json.loads(r.stdout)})
            else:
                self._send(500, {"ok": False, "error": (r.stderr or "no output").strip()})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_restart(self):
        try:
            subprocess.run(
                ["systemctl", "restart", "foodassistant-streamdeck"],
                check=True, timeout=15
            )
            self._send(200, {"ok": True})
        except subprocess.CalledProcessError as e:
            self._send(500, {"ok": False, "error": str(e)})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _kiosk_restart(self):
        # Scheduled detached rather than run inline: this endpoint can be hit
        # from a settings page shown on the kiosk display itself, and a
        # synchronous restart kills that page before the response lands.
        if _schedule_kiosk_restart():
            self._send(200, {"ok": True, "scheduled": True})
        else:
            self._send(500, {"ok": False, "error": "could not schedule kiosk restart"})

    def _mealie_container_up(self):
        """True when the Mealie container exists (compose service 'mealie')."""
        return _mealie_container_exists()

    def _mealie_serving(self):
        """True when Mealie actually answers HTTP on its port.

        The container can sit in 'health: starting' for a minute after it is
        created, during which docker compose ps already lists it but the web
        server refuses connections. Probing the port is what tells us the link
        the user is about to click will actually work.
        """
        return _http_serving(f"http://127.0.0.1:{MEALIE_PORT}/")

    def _mealie_running(self):
        """Backwards-compatible alias: True when Mealie is up and serving."""
        return self._mealie_container_up() and self._mealie_serving()

    def _mealie_status(self):
        # Report a single phase the web UI can poll on. We only call Mealie
        # 'running' once it actually answers HTTP, so the user never gets a
        # link that refuses the connection:
        #   running        -> the container is up AND serving HTTP
        #   starting       -> the pull/up is in flight, OR the container exists
        #                     but is not serving yet (health: starting)
        #   not-installed  -> neither (idle, image not pulled / not started)
        try:
            container_up = self._mealie_container_up()
            serving = container_up and self._mealie_serving()
            starting = _installing("mealie")
            if serving:
                state = "running"
            elif starting or container_up:
                state = "starting"
            else:
                state = "not-installed"
            self._send(200, {
                "ok": True,
                "state": state,
                "running": serving,
                "starting": state == "starting",
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _mealie_start(self):
        # Pulling the Mealie image on first run can take several minutes on a
        # Pi, far longer than any reasonable HTTP timeout. Run the pull/up in
        # the background (mirroring the install provisioner) and return
        # immediately; the web UI polls /mealie/status for progress. Calling
        # this again while a start is in flight (or after Mealie is up) is a
        # no-op, so the UI can safely re-attach after a page reload.
        if self._mealie_running():
            self._send(200, {"ok": True, "started": False, "state": "running"})
            return
        if _installing("mealie"):
            self._send(200, {"ok": True, "started": False, "state": "starting"})
            return
        try:
            # Persist the intent first: if this install is interrupted (bridge
            # restart, reboot mid-pull), the startup resume finishes it.
            _persist_compose_profile("with-mealie")
            _launch_mealie_install()
            self._send(200, {"ok": True, "started": True, "state": "starting"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _logs(self, name):
        # Tail of an install/start log so the setup UI can show live output.
        # Strip any trailing slash/query and never raise: an unknown name or a
        # log that does not exist yet just returns an empty line list.
        name = name.split("?", 1)[0].strip("/")
        if name not in _LOG_PATHS:
            self._send(404, {"ok": False, "error": "unknown log name"})
            return
        try:
            lines = _tail_log(name)
            self._send(200, {
                "ok": True,
                "name": name,
                "running": _installing(name),
                "lines": lines,
            })
        except Exception as e:
            # Defensive: _tail_log already swallows errors, but keep the
            # endpoint from ever bubbling an exception to the client.
            self._send(200, {"ok": True, "name": name, "running": False, "lines": [], "error": str(e)})

    def _hardware_status(self):
        # Live attached-hardware detection (display connectors + Stream Deck
        # model) read straight from sysfs, merged with the kiosk/streamdeck
        # service-install state the setup UI already polls for. The detection
        # block lives under "display" and the deck "model"/sysfs presence is
        # folded into the existing "streamdeck" object.
        hw = _hardware_status()
        sd_present, sd_model = hw["streamdeck"]["present"], hw["streamdeck"]["model"]
        self._send(200, {
            "ok": True,
            "display": hw["display"],
            "kiosk": {
                # "present" means a display is actually connected (DRM
                # connector state), not merely that a KMS card exists: the
                # card node is there even on a headless Pi, which used to
                # make the UI offer a kiosk install with nothing attached.
                "present": hw["display"]["present"],
                "installed": _unit_installed("foodassistant-kiosk.service"),
                "active": _service_active("foodassistant-kiosk.service"),
                "installing": _installing("kiosk"),
            },
            "streamdeck": {
                "present": _streamdeck_present() or sd_present,
                "model": sd_model,
                "installed": _unit_installed("foodassistant-streamdeck.service"),
                "active": _service_active("foodassistant-streamdeck.service"),
                "installing": _installing("streamdeck"),
                "key_count": _streamdeck_keycount(),
            },
        })

    def _system_health(self):

#!/usr/bin/env python3
"""FoodAssistant host bridge.

Runs on the Pi host (not inside Docker) at 127.0.0.1:9299. The main app
container can reach it via localhost because docker-compose.appliance.yml
uses network_mode: host.

Exposes a minimal HTTP API for operations that need host-level access, such
as Wi-Fi, hostname, display KMS rotation, and service restarts.

Endpoints
---------
GET  /wifi/status          current Wi-Fi state + SSID (from nmcli)
GET  /wifi/scan            list visible networks {ssid, signal, security}
POST /wifi/connect         connect to a network  {ssid, password?}
GET  /hostname             current hostname
POST /hostname             change hostname       {hostname}
GET  /display/rotation     current KMS rotation (from /boot/firmware/config.txt)
POST /display/rotation     set KMS rotation      {degrees, reboot?}
POST /touch/calibrate      apply touch matrix    {matrix: "a b c d e f"}
POST /streamdeck/restart   restart Stream Deck service
GET  /streamdeck/actions     list assignable deck actions (for the web editor)
POST /kiosk/restart        restart the kiosk browser (apply scale/rotation)
GET  /mealie/status        Mealie state: not-installed / starting / running
POST /mealie/start         start Mealie in the background (docker compose --profile with-mealie up -d)
GET  /logs/<name>          tail of an install/start log (name in mealie/kiosk/streamdeck)
GET  /hardware/status      display/Stream Deck presence + service/install state
GET  /system/health        power/thermal/disk warnings (vcgencmd get_throttled, temp, df)
POST /kiosk/install        provision the kiosk service (display attached later)
POST /streamdeck/install   provision the Stream Deck service (attached later)
GET  /ap/status            whether the fallback AP is active {active: bool}
POST /ap/disable           stop hostapd+dnsmasq and remove the AP flag file
POST /update               git pull + redeploy app and Stream Deck + restart (Pi Remote OTA)
POST /reboot               reboot the host (systemctl reboot, or reboot as fallback)
POST /restore              full-stack snapshot restore (stop stack, swap data, restart)  {source}
GET  /activity             shared activity/display state (polled by the deck)
POST /activity             report user activity; wakes the display  {source?}
POST /display/blank        blank the kiosk display now
POST /display/wake         wake the kiosk display now
POST /display/idle         set+persist the display idle timeout  {minutes}
"""
import http.server
import json
import os
from pathlib import Path
import re
import shutil
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.request

LISTEN_HOST = "127.0.0.1"
LISTEN_PORT = 9299
INSTALL_DIR = "/opt/foodassistant"
# Mealie serves on this host port (mapped from the container's 9000 in the
# appliance compose file). Used for the readiness probe below.
MEALIE_PORT = 9285
# Flag file written by the AP watchdog service when the fallback hotspot is
# active. Checked by GET /ap/status and removed by POST /ap/disable.
_AP_FLAG = "/run/foodassistant-ap-active"

# Candidate locations for the provisioner script (curl-installer clone first,
# then a baked-image asset dir, then the legacy home-dir clone).
_FIRSTBOOT_CANDIDATES = [
    "/boot/firmware/firstboot.sh",
    "/home/foodassistant/FoodAssistant/scripts/image-build/firstboot.sh",
    "/opt/foodassistant-src/scripts/image-build/firstboot.sh",
]
# Background long-running processes, keyed by step name
# ("kiosk"/"streamdeck" installs, "mealie" start). Each value is a Popen whose
# poll() tells us whether the work is still in flight.
_INSTALL_PROCS = {}

# Log files the background steps stream their stdout/stderr into. The setup UI
# tails these (via GET /logs/<name>) to show live install/start output. The
# Mealie start writes the first path; the kiosk/streamdeck installs use the
# foodassistant-<name>-install.log pattern that _provision() opens.
_LOG_PATHS = {
    "mealie": "/var/log/foodassistant-mealie-start.log",
    "kiosk": "/var/log/foodassistant-kiosk-install.log",
    "streamdeck": "/var/log/foodassistant-streamdeck-install.log",
}

# Cap the bytes we read off the tail of a log so a long-running install cannot
# return a multi-megabyte body to the polling UI.
_LOG_TAIL_BYTES = 8192

# --- Display + activity coordination (FoodAssistant-otiy) -----------------
# The bridge is the one process both the kiosk browser and the Stream Deck
# controller can reach, so it brokers "user activity" between them and owns the
# physical display power. The kiosk display and the Stream Deck keep SEPARATE
# idle timeouts (the deck times itself out locally), but activity on either
# surface is reported here and wakes both: this loop wakes the display, and the
# deck polls GET /activity to wake itself.
#
# The display idle timeout (minutes, 0 = off) is pushed by the app on settings
# save and persisted here so it survives a bridge restart.
_DISPLAY_IDLE_FILE = "/etc/foodassistant/display-idle"
_activity_lock = threading.Lock()
_activity_state = {
    "last_activity": time.time(),
    "display_blanked": False,
    "idle_minutes": 0,
}


def _read_persisted_idle_minutes(path=_DISPLAY_IDLE_FILE):
    """Read the persisted display idle timeout in minutes (0 if unset/bad)."""
    try:
        with open(path) as f:
            return max(0, int((f.read().strip() or "0")))
    except (OSError, ValueError):
        return 0


def _write_persisted_idle_minutes(minutes, path=_DISPLAY_IDLE_FILE):
    """Persist the display idle timeout so a bridge restart keeps it."""
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w") as f:
            f.write(str(int(minutes)))
        return True
    except (OSError, ValueError):
        return False


def _display_power_commands(on, which=shutil.which):
    """Ordered candidate command vectors to switch the display on/off.

    The caller tries each until one succeeds. Kept pure (the tool probe is
    injected) so the selection is unit-testable.

    The compositor-aware helper is preferred (FoodAssistant-8khi): on a cage
    kiosk, vcgencmd cuts the panel below the compositor, dropping it to the
    console with no clean recovery until reboot. foodassistant-display-power
    toggles the output through wlr-randr so cage stays in control. vcgencmd and
    xset remain as fallbacks for setups without the compositor helper (e.g. a
    bare X11 display or when the kiosk is not running).
    """
    cmds = []
    if which("foodassistant-display-power"):
        cmds.append(["foodassistant-display-power", "on" if on else "off"])
    if which("vcgencmd"):
        cmds.append(["vcgencmd", "display_power", "1" if on else "0"])
    if which("xset"):
        cmds.append(["xset", "dpms", "force", "on" if on else "off"])
    return cmds


def _reboot_command(which=shutil.which):
    """The command vector used to reboot the host.

    Prefers `systemctl reboot`; falls back to a bare `reboot` when systemctl is
    not on PATH. Kept pure (the tool probe is injected) so it is unit-testable
    without actually rebooting, mirroring _display_power_commands.
    """
    if which("systemctl"):
        return ["systemctl", "reboot"]
    return ["reboot"]


def _should_blank(now, last_activity, idle_minutes, already_blanked):
    """True when the display has been idle long enough to blank.

    Pure helper for the idle loop and its tests.
    """
    if idle_minutes <= 0 or already_blanked:
        return False
    return (now - last_activity) >= idle_minutes * 60


def _set_display_power(on):
    """Try each candidate command to power the display on/off. Returns True on
    the first success, False if none worked (or none are available)."""
    for cmd in _display_power_commands(on):
        try:
            subprocess.run(cmd, check=True, capture_output=True, timeout=10)
            return True
        except (OSError, subprocess.SubprocessError):
            continue
    return False


def _record_activity():
    """Note user activity from either surface and wake the display if it was
    blanked. Returns whether the display was woken."""
    with _activity_lock:
        was_blanked = _activity_state["display_blanked"]
        _activity_state["last_activity"] = time.time()
    if was_blanked:
        _set_display_power(True)
        with _activity_lock:
            _activity_state["display_blanked"] = False
    return was_blanked


def _display_idle_loop():
    """Background tick: blank the display once it has been idle long enough."""
    while True:
        try:
            with _activity_lock:
                idle = _activity_state["idle_minutes"]
                last = _activity_state["last_activity"]
                blanked = _activity_state["display_blanked"]
            if _should_blank(time.time(), last, idle, blanked):
                if _set_display_power(False):
                    with _activity_lock:
                        _activity_state["display_blanked"] = True
        except Exception:
            pass
        time.sleep(10)


def _tail_log(name, max_bytes=_LOG_TAIL_BYTES):
    """Return the last max_bytes of the named log as a list of lines.

    Safe by design: an unknown name, a missing file, or any read error yields
    an empty list rather than raising, so the polling endpoint never 500s just
    because a step has not created its log yet.
    """
    path = _LOG_PATHS.get(name)
    if not path:
        return []
    try:
        with open(path, "rb") as f:
            try:
                f.seek(0, os.SEEK_END)
                size = f.tell()
                f.seek(max(0, size - max_bytes))
            except OSError:
                # Not seekable for some reason; fall back to a plain read.
                f.seek(0)
            data = f.read()
        text = data.decode("utf-8", "replace")
        # Drop a leading partial line when we seeked into the middle of one.
        if len(data) >= max_bytes and "\n" in text:
            text = text.split("\n", 1)[1]
        return [ln for ln in text.splitlines() if ln.strip()]
    except OSError:
        return []
    except Exception:
        return []


def _http_serving(url, timeout=3):
    """True when a GET to url gets any HTTP response (server is up).

    A redirect or even a 4xx still means the web server answered, so anything
    short of a connection failure or a 5xx counts as serving. Used to tell a
    container that is merely created apart from one that is actually ready.
    """
    try:
        req = urllib.request.Request(url, method="GET")
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status < 500
    except urllib.error.HTTPError:
        # The server answered with an error status; it is up.
        return True
    except Exception:
        return False


def _find_firstboot():
    """Return (script_path, repo_dir) for the provisioner, or (None, None)."""
    for path in _FIRSTBOOT_CANDIDATES:
        if os.path.isfile(path):
            # firstboot.sh lives at <repo>/scripts/image-build/firstboot.sh;
            # derive the repo root so it can find the streamdeck package etc.
            repo_dir = ""
            if path.endswith("/scripts/image-build/firstboot.sh"):
                repo_dir = path[: -len("/scripts/image-build/firstboot.sh")]
            return path, repo_dir
    return None, None


def _compose_env():
    """Environment for `docker compose` runs from INSTALL_DIR.

    The appliance compose file resolves the service build context from
    ${REPO_DIR}; firstboot.sh exports it before every compose call. The bridge
    process does not inherit that export, so derive it the same way (from the
    provisioner location, falling back to the compose file's own default) to
    keep the build context valid if compose ever needs to build `service`.
    """
    env = dict(os.environ)
    if not env.get("REPO_DIR"):
        _, repo_dir = _find_firstboot()
        env["REPO_DIR"] = repo_dir or "/home/foodassistant/FoodAssistant"
    return env


# --- Full-stack restore source handling (FoodAssistant-h18b) --------------
# The restore helper (/usr/local/bin/foodassistant-restore) accepts a snapshot
# that is either already on the device (an absolute path) or pulled first from
# the configured rclone remote (an "rclone:" prefixed source). These pure
# helpers classify the source string and build the rclone pull command so they
# can be unit-tested without root or docker.

# rclone.conf lives in the install data dir, the same path the app container
# uses for RCLONE_CONFIG (admin.py writes it there).
_RCLONE_CONFIG = f"{INSTALL_DIR}/data/rclone.conf"


def _classify_restore_source(source):
    """Classify a restore source string.

    Returns a (kind, value) tuple:
      ("path", "/abs/path.tar.gz")  an absolute path on the device
      ("rclone", "remote:bucket/x") an object to pull from the rclone remote
      ("invalid", reason)           anything else (empty, relative, bad rclone)
    """
    s = (source or "").strip()
    if not s:
        return ("invalid", "Source is required.")
    if s.startswith("rclone:"):
        remote = s[len("rclone:"):].strip()
        if not remote:
            return ("invalid", "rclone source has no remote path.")
        return ("rclone", remote)
    if s.startswith("/"):
        return ("path", s)
    return ("invalid", "Source must be an absolute path or an rclone:remote path.")


def _rclone_pull_cmd(remote, dest, rclone="rclone"):
    """Build the rclone command (argv list) that copies a remote object to a
    local destination file. The caller sets RCLONE_CONFIG in the environment."""
    return [rclone, "copyto", remote, dest]


def _service_active(unit):
    """True when the given systemd unit is active."""
    try:
        return subprocess.run(
            ["systemctl", "is-active", "--quiet", unit], timeout=5
        ).returncode == 0
    except Exception:
        return False


def _display_present():
    return os.path.exists("/dev/dri/card0")


# Stream Deck / display detection from sysfs
# ------------------------------------------
# These read sysfs directly (no lsusb, no extra packages) so the appliance can
# report attached hardware on a minimal image. They take the sysfs root as an
# argument so they are testable against a faked layout under tmp_path.

# Elgato (Stream Deck maker) USB vendor id.
_STREAMDECK_VENDOR = "0fd9"


def _read_sysfs(path):
    """Return the stripped contents of a sysfs file, or "" on any error."""
    try:
        with open(path) as fh:
            return fh.read().strip()
    except OSError:
        return ""
    except Exception:
        return ""


def _drm_connected(root="/sys/class/drm"):
    """Return the list of connected DRM connector names under root.

    Scans <root>/*/status; a connector counts as connected when its status
    file reads "connected" (the kernel also emits "disconnected", which must
    not match). A missing root yields an empty list rather than raising.
    """
    import glob
    names = []
    for status_path in sorted(glob.glob(os.path.join(root, "*", "status"))):
        if _read_sysfs(status_path) == "connected":
            names.append(os.path.basename(os.path.dirname(status_path)))
    return names


def _streamdeck_info(usb_root="/sys/bus/usb/devices"):
    """Return (present, model) for an attached Stream Deck under usb_root.

    Scans <usb_root>/*/idVendor for the Elgato vendor id; on a match reads the
    sibling product file for the model string. Returns (False, "") when none is
    found or the tree is absent.
    """
    import glob
    for vendor_path in sorted(glob.glob(os.path.join(usb_root, "*", "idVendor"))):
        if _read_sysfs(vendor_path).lower() == _STREAMDECK_VENDOR:
            product = _read_sysfs(os.path.join(os.path.dirname(vendor_path), "product"))
            return True, product
    return False, ""


def _hardware_status():
    """Display + Stream Deck presence read straight from sysfs.

    Returned as the body of GET /hardware/status. Always succeeds: a missing
    sysfs tree degrades to present=false rather than raising.
    """
    connectors = _drm_connected()
    sd_present, sd_model = _streamdeck_info()
    # key_count lets the wizard/editor pre-select the right deck size instead of
    # defaulting to 15 (FoodAssistant). None when the model is unknown, in which
    # case the app keeps its current selection.
    return {
        "ok": True,
        "display": {"present": bool(connectors), "connectors": connectors},
        "streamdeck": {"present": sd_present, "model": sd_model,
                       "key_count": _streamdeck_keycount()},
    }


# Meaning of each bit in the "throttled" word reported by `vcgencmd
# get_throttled`. The low four bits are live (happening right now); the high
# four are sticky (happened at some point since boot). See
# https://www.raspberrypi.com/documentation/computers/os.html#get_throttled
_THROTTLE_BITS = {
    0: ("undervoltage", "Under-voltage detected", True),
    1: ("freq_capped", "Arm frequency capped", True),
    2: ("throttled", "Currently throttled", True),
    3: ("temp_limit", "Soft temperature limit active", True),
    16: ("undervoltage", "Under-voltage has occurred since boot", False),
    17: ("freq_capped", "Arm frequency capping has occurred since boot", False),
    18: ("throttled", "Throttling has occurred since boot", False),
    19: ("temp_limit", "Soft temperature limit has occurred since boot", False),
}


def _parse_throttled(word):
    """Decode a `vcgencmd get_throttled` value into a list of warnings.

    `word` is the integer throttle bitmask (the 0x... value vcgencmd prints).
    Returns a list of {key, message, live} dicts, live=True for conditions
    happening right now and live=False for sticky "since boot" flags. An
    all-clear bitmask returns an empty list.
    """
    out = []
    for bit, (key, message, live) in _THROTTLE_BITS.items():
        if word & (1 << bit):
            out.append({"key": key, "message": message, "live": live})
    return out


def _read_throttled_word():
    """Return the integer from `vcgencmd get_throttled`, or None if unavailable.

    Output looks like "throttled=0x50005"; anything else (vcgencmd missing, a
    non-Pi host) yields None so the caller can report "unknown" rather than a
    false all-clear.
    """
    try:
        out = subprocess.run(
            ["vcgencmd", "get_throttled"], capture_output=True, text=True, timeout=5
        ).stdout.strip()
    except Exception:
        return None
    m = re.search(r"throttled=(0x[0-9a-fA-F]+|\d+)", out)
    if not m:
        return None
    try:
        return int(m.group(1), 0)
    except ValueError:
        return None


def _read_cpu_temp(path="/sys/class/thermal/thermal_zone0/temp"):
    """CPU temperature in Celsius (float), or None if it can't be read.

    The sysfs file holds millidegrees, e.g. "48312" -> 48.3.
    """
    raw = _read_sysfs(path)
    if not raw:
        return None
    try:
        return round(int(raw) / 1000.0, 1)
    except ValueError:
        return None


def _disk_usage(path="/"):
    """Return (percent_used, free_gb) for the filesystem holding path.

    Returns (None, None) if it can't be determined.
    """
    try:
        import shutil
        total, used, free = shutil.disk_usage(path)
        percent = round(used / total * 100) if total else None
        return percent, round(free / (1024 ** 3), 1)
    except Exception:
        return None, None


# Surface a warning when the CPU crosses this temperature or the disk crosses
# this fill level. The Pi soft-throttles around 80C and hard-throttles at 85C,
# so 80 is the right point to start nudging the user.
_TEMP_WARN_C = 80.0
_DISK_WARN_PCT = 90


def _system_health():
    """Pi system health for GET /system/health: power, thermal, and disk.

    Always succeeds. Each probe degrades to None/empty rather than raising, so
    a partial read (e.g. vcgencmd present but no thermal zone) still returns a
    usable shape. The "warnings" list is what the UI badge keys off; an empty
    list means all clear.
    """
    word = _read_throttled_word()
    throttle_flags = _parse_throttled(word) if word is not None else []
    temp_c = _read_cpu_temp()
    disk_pct, disk_free_gb = _disk_usage()

    warnings = list(throttle_flags)
    if temp_c is not None and temp_c >= _TEMP_WARN_C:
        warnings.append({
            "key": "temperature",
            "message": f"CPU temperature high ({temp_c:.0f}C)",
            "live": True,
        })
    if disk_pct is not None and disk_pct >= _DISK_WARN_PCT:
        warnings.append({
            "key": "disk",
            "message": f"Disk almost full ({disk_pct}% used)",
            "live": True,
        })

    return {
        "ok": True,
        "throttled": word,
        "temp_c": temp_c,
        "disk_percent": disk_pct,
        "disk_free_gb": disk_free_gb,
        "warnings": warnings,
    }


def _streamdeck_present():
    try:
        out = subprocess.run(["lsusb"], capture_output=True, text=True, timeout=5).stdout
        if "0fd9:" in out.lower():
            return True
    except Exception:
        pass
    # Fallback: scan sysfs idVendor files.
    try:
        import glob
        for f in glob.glob("/sys/bus/usb/devices/*/idVendor"):
            try:
                with open(f) as fh:
                    if fh.read().strip().lower() == "0fd9":
                        return True
            except OSError:
                continue
    except Exception:
        pass
    return False


# Elgato USB product IDs mapped to their key counts. Lets the web editor size
# its grid to the deck that is actually attached instead of guessing.
_SD_PRODUCT_KEYS = {
    "0060": 15, "006d": 15, "0080": 15,   # Original / v2 / MK.2
    "0063": 6, "0090": 6,                 # Mini / Mini MK.2
    "006c": 32, "008f": 32,               # XL / XL v2
}


def _streamdeck_keycount(usb_root="/sys/bus/usb/devices"):
    """Best-effort key count for the attached deck, or None if unknown."""
    try:
        import re
        out = subprocess.run(["lsusb"], capture_output=True, text=True, timeout=5).stdout
        m = re.search(r"0fd9:([0-9a-fA-F]{4})", out)
        if m:
            return _SD_PRODUCT_KEYS.get(m.group(1).lower())
    except Exception:
        pass
    # Fallback when lsusb is unavailable: read the Elgato device's idProduct from
    # sysfs and map it, mirroring how _streamdeck_info finds the vendor there.
    try:
        import glob
        for vendor_path in sorted(glob.glob(os.path.join(usb_root, "*", "idVendor"))):
            if _read_sysfs(vendor_path).lower() == _STREAMDECK_VENDOR:
                pid = _read_sysfs(os.path.join(os.path.dirname(vendor_path), "idProduct")).lower()
                if pid:
                    return _SD_PRODUCT_KEYS.get(pid)
    except Exception:
        pass
    return None


def _installing(step):
    p = _INSTALL_PROCS.get(step)
    return bool(p and p.poll() is None)


# Wi-Fi helpers
# -------------
# nmcli is always invoked in terse mode (-t -f) so the output is colon-separated
# and stable across versions. nmcli escapes literal colons in field values as
# "\:", so splitting must unescape them rather than a naive str.split(":").

def _nmcli_split(line):
    """Split one terse nmcli line into fields, honoring backslash escapes.

    nmcli escapes ':' and '\\' in values as '\\:' and '\\\\'. A naive split on
    ':' would break SSIDs that contain a colon, so walk the string instead.
    """
    fields = []
    cur = []
    i = 0
    while i < len(line):
        ch = line[i]
        if ch == "\\" and i + 1 < len(line):
            cur.append(line[i + 1])
            i += 2
            continue
        if ch == ":":
            fields.append("".join(cur))
            cur = []
            i += 1
            continue
        cur.append(ch)
        i += 1
    fields.append("".join(cur))
    return fields


def _parse_wifi_device(out):
    """Pick the wifi device from `nmcli -t -f DEVICE,TYPE,STATE device` output.

    Returns (device, state) for the first wifi device, or (None, None) when no
    wifi hardware is present. state is the raw nmcli state string, for example
    "connected", "disconnected", or "unmanaged".
    """
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = _nmcli_split(line)
        if len(parts) < 3:
            continue
        device, dtype, state = parts[0], parts[1], parts[2]
        if dtype == "wifi":
            return device, state
    return None, None


def _parse_active_ssid(out):
    """Connected SSID from `nmcli -t -f ACTIVE,SSID dev wifi`, or "" if none."""
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = _nmcli_split(line)
        if len(parts) >= 2 and parts[0] == "yes":
            return parts[1]
    return ""


def _parse_wifi_scan(out):
    """Parse `nmcli -t -f SSID,SIGNAL,SECURITY dev wifi list` output.

    Returns a list of {ssid, signal, security} dicts, hidden/blank SSIDs
    dropped, deduped by SSID (keeping the strongest signal), sorted by signal
    descending.
    """
    best = {}
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = _nmcli_split(line)
        if len(parts) < 1:
            continue
        ssid = parts[0]
        if not ssid:
            continue
        try:
            signal = int(parts[1]) if len(parts) > 1 and parts[1] else 0
        except ValueError:
            signal = 0
        security = parts[2] if len(parts) > 2 else ""
        prev = best.get(ssid)
        if prev is None or signal > prev["signal"]:
            best[ssid] = {"ssid": ssid, "signal": signal, "security": security}
    return sorted(best.values(), key=lambda n: n["signal"], reverse=True)


def _ethernet_status():
    """Best-effort wired status: {connected, device, ip}. Never raises.

    A Pi on Ethernet should not look offline just because Wi-Fi is idle
    (FoodAssistant-7r5), so the Wi-Fi status carries the wired state too. A
    physical interface counts as connected when its carrier is up and it holds
    an IPv4 address; virtual interfaces (docker, veth, bridges) are skipped.
    """
    try:
        for name in sorted(os.listdir("/sys/class/net")):
            if name == "lo" or name.startswith(("wlan", "ap", "docker", "veth", "br-", "tun", "tap", "vir")):
                continue
            try:
                carrier = Path(f"/sys/class/net/{name}/carrier").read_text().strip()
            except Exception:
                carrier = "0"
            if carrier != "1":
                continue
            ip = ""
            try:
                out = subprocess.run(
                    ["ip", "-4", "-o", "addr", "show", "dev", name],
                    capture_output=True, text=True, timeout=4
                ).stdout
                for tok in out.split():
                    if "/" in tok and tok[0].isdigit():
                        ip = tok.split("/")[0]
                        break
            except Exception:
                pass
            if ip:
                return {"connected": True, "device": name, "ip": ip}
        return {"connected": False, "device": "", "ip": ""}
    except Exception:
        return {"connected": False, "device": "", "ip": ""}


def _nm_running():
    """True when NetworkManager (nmcli) is reachable."""
    try:
        r = subprocess.run(
            ["nmcli", "-t", "-f", "RUNNING", "general"],
            capture_output=True, text=True, timeout=5
        )
        return r.returncode == 0 and "running" in r.stdout.lower()
    except Exception:
        return False


class _Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code, data):
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _body(self):
        n = int(self.headers.get("Content-Length", 0))
        return json.loads(self.rfile.read(n)) if n else {}

    # --- Display + activity coordination (FoodAssistant-otiy) -------------

    def _activity_get(self):
        """Current activity/display state, polled by the Stream Deck controller
        so a kiosk touch wakes the deck (shared activity, separate timeouts)."""
        with _activity_lock:
            self._send(200, {
                "ok": True,
                "last_activity": _activity_state["last_activity"],
                "display_blanked": _activity_state["display_blanked"],
                "idle_minutes": _activity_state["idle_minutes"],
            })

    def _activity_post(self):
        """Report user activity from either surface; wakes the display."""
        woke = _record_activity()
        with _activity_lock:
            last = _activity_state["last_activity"]
        self._send(200, {"ok": True, "woke": woke, "last_activity": last})

    def _display_blank(self):
        ok = _set_display_power(False)
        with _activity_lock:
            _activity_state["display_blanked"] = ok
        self._send(200, {"ok": ok})

    def _display_wake(self):
        ok = _set_display_power(True)
        with _activity_lock:
            _activity_state["display_blanked"] = False
            _activity_state["last_activity"] = time.time()
        self._send(200, {"ok": ok})

    def _display_idle_set(self):
        """Set (and persist) the display idle timeout in minutes."""
        body = self._body()
        try:
            minutes = max(0, int(body.get("minutes", 0)))
        except (TypeError, ValueError):
            self._send(400, {"ok": False, "error": "minutes must be an integer"})
            return
        with _activity_lock:
            _activity_state["idle_minutes"] = minutes
        persisted = _write_persisted_idle_minutes(minutes)
        self._send(200, {"ok": True, "minutes": minutes, "persisted": persisted})

    def do_GET(self):
        if self.path == "/wifi/status":
            self._wifi_status()
        elif self.path == "/wifi/scan":
            self._wifi_scan()
        elif self.path == "/hostname":
            self._get_hostname()
        elif self.path == "/display/rotation":
            self._get_rotation()
        elif self.path == "/mealie/status":
            self._mealie_status()
        elif self.path.startswith("/logs/"):
            self._logs(self.path[len("/logs/"):])
        elif self.path == "/hardware/status":
            self._hardware_status()
        elif self.path == "/system/health":
            self._system_health()
        elif self.path == "/streamdeck/config":
            self._streamdeck_get_config()
        elif self.path == "/streamdeck/actions":
            self._streamdeck_actions()
        elif self.path == "/ap/status":
            self._ap_status()
        elif self.path == "/activity":
            self._activity_get()
        else:
            self._send(404, {"error": "not found"})

    def do_POST(self):
        if self.path == "/wifi/connect":
            self._wifi_connect()
        elif self.path == "/hostname":
            self._set_hostname()
        elif self.path == "/display/rotation":
            self._set_rotation()
        elif self.path == "/touch/calibrate":
            self._touch_calibrate()
        elif self.path == "/streamdeck/restart":
            self._streamdeck_restart()
        elif self.path == "/kiosk/restart":
            self._kiosk_restart()
        elif self.path == "/mealie/start":
            self._mealie_start()
        elif self.path == "/kiosk/install":
            self._provision("kiosk", "foodassistant-kiosk.service")
        elif self.path == "/streamdeck/install":
            self._provision("streamdeck", "foodassistant-streamdeck.service")
        elif self.path == "/streamdeck/config":
            self._streamdeck_set_config()
        elif self.path == "/ap/disable":
            self._ap_disable()
        elif self.path == "/update":
            self._update()
        elif self.path == "/reboot":
            self._reboot()
        elif self.path == "/restore":
            self._restore()
        elif self.path == "/activity":
            self._activity_post()
        elif self.path == "/display/blank":
            self._display_blank()
        elif self.path == "/display/wake":
            self._display_wake()
        elif self.path == "/display/idle":
            self._display_idle_set()
        else:
            self._send(404, {"error": "not found"})

    def _wifi_status(self):
        # Report a structured state the UI can show instead of a bare blank:
        #   no-networkmanager -> nmcli/NetworkManager is not running
        #   no-adapter        -> no wifi hardware on this device
        #   unmanaged         -> wifi device exists but NM does not manage it
        #   disconnected      -> wifi adapter present, no active connection
        #   connected         -> joined a network (ssid is set)
        eth = _ethernet_status()
        try:
            if not _nm_running():
                self._send(200, {
                    "ok": True, "state": "no-networkmanager", "ssid": "",
                    "detail": "NetworkManager is not running.", "ethernet": eth,
                })
                return
            dev_out = subprocess.run(
                ["nmcli", "-t", "-f", "DEVICE,TYPE,STATE", "device"],
                capture_output=True, text=True, timeout=5
            ).stdout
            device, dev_state = _parse_wifi_device(dev_out)
            if not device:
                self._send(200, {
                    "ok": True, "state": "no-adapter", "ssid": "",
                    "detail": "No Wi-Fi adapter found.", "ethernet": eth,
                })
                return
            if dev_state == "unmanaged":
                self._send(200, {
                    "ok": True, "state": "unmanaged", "ssid": "", "device": device,
                    "detail": "Wi-Fi device is not managed by NetworkManager.",
                    "ethernet": eth,
                })
                return
            ssid_out = subprocess.run(
                ["nmcli", "-t", "-f", "ACTIVE,SSID", "dev", "wifi"],
                capture_output=True, text=True, timeout=5
            ).stdout
            ssid = _parse_active_ssid(ssid_out)
            self._send(200, {
                "ok": True,
                "state": "connected" if ssid else "disconnected",
                "ssid": ssid,
                "device": device,
                "ethernet": eth,
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e), "ethernet": eth})

    def _wifi_scan(self):
        try:
            if not _nm_running():
                self._send(200, {
                    "ok": True, "state": "no-networkmanager", "networks": [],
                    "detail": "NetworkManager is not running.",
                })
                return
            dev_out = subprocess.run(
                ["nmcli", "-t", "-f", "DEVICE,TYPE,STATE", "device"],
                capture_output=True, text=True, timeout=5
            ).stdout
            device, _ = _parse_wifi_device(dev_out)
            if not device:
                self._send(200, {
                    "ok": True, "state": "no-adapter", "networks": [],
                    "detail": "No Wi-Fi adapter found.",
                })
                return
            r = subprocess.run(
                ["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY", "dev", "wifi", "list"],
                capture_output=True, text=True, timeout=20
            )
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            self._send(200, {
                "ok": True, "state": "ok",
                "networks": _parse_wifi_scan(r.stdout),
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _wifi_connect(self):
        body = self._body()
        ssid = body.get("ssid", "").strip()
        password = body.get("password", "").strip()
        if not ssid:
            self._send(400, {"ok": False, "error": "ssid is required"})
            return
        try:
            cmd = ["nmcli", "device", "wifi", "connect", ssid]
            if password:
                cmd += ["password", password]
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            if r.returncode == 0:
                self._send(200, {"ok": True})
            else:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _get_hostname(self):
        try:
            hn = subprocess.run(
                ["hostname"], capture_output=True, text=True
            ).stdout.strip()
            self._send(200, {"ok": True, "hostname": hn})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _set_hostname(self):
        body = self._body()
        name = body.get("hostname", "").strip().lower()
        if not name or not re.fullmatch(r"[a-z0-9]([a-z0-9\-]{0,61}[a-z0-9])?", name):
            self._send(400, {"ok": False, "error": "Invalid hostname. Use lowercase letters, digits, and hyphens."})
            return
        try:
            subprocess.run(["hostnamectl", "set-hostname", name], check=True, timeout=10)
            r = subprocess.run(["grep", "-q", r"^127\.0\.1\.1", "/etc/hosts"])
            if r.returncode == 0:
                subprocess.run(
                    ["sed", "-i", rf"s/^127\.0\.1\.1.*/127.0.1.1\t{name}/", "/etc/hosts"],
                    check=True
                )
            else:
                with open("/etc/hosts", "a") as f:
                    f.write(f"127.0.1.1\t{name}\n")
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _get_rotation(self):
        rotation = 0
        try:
            with open("/etc/foodassistant/kiosk-env") as f:
                for line in f:
                    m = re.match(r"^\s*WLR_OUTPUT_TRANSFORM\s*=\s*(\S+)", line)
                    if m:
                        val = m.group(1).strip()
                        rotation = int(val) if val.isdigit() else 0
        except OSError:
            pass
        self._send(200, {"ok": True, "rotation": rotation})

    def _set_rotation(self):
        body = self._body()
        try:
            degrees = int(body.get("degrees", 0))
        except (TypeError, ValueError):
            self._send(400, {"ok": False, "error": "degrees must be 0, 90, 180, or 270"})
            return
        if degrees not in (0, 90, 180, 270):
            self._send(400, {"ok": False, "error": "degrees must be 0, 90, 180, or 270"})
            return
        reboot = bool(body.get("reboot", False))
        cmd = ["/usr/local/bin/foodassistant-set-rotation", str(degrees)]
        if reboot:
            cmd.append("--reboot")
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
            if r.returncode == 0:
                self._send(200, {"ok": True})
            else:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _touch_calibrate(self):
        # Apply a LIBINPUT_CALIBRATION_MATRIX by delegating to the calibrate
        # helper's non-interactive mode. The bridge runs as root, so it can
        # write the udev rule and reload udev without sudo (the app service
        # cannot: its unit caps privileges to CAP_NET_BIND_SERVICE).
        body = self._body()
        matrix = (body.get("matrix") or "").strip()
        parts = matrix.split()
        if len(parts) != 6:
            self._send(400, {"ok": False, "error": "matrix must be exactly 6 floats"})
            return
        try:
            [float(p) for p in parts]
        except ValueError:
            self._send(400, {"ok": False, "error": "matrix has a non-numeric value"})
            return
        helper = "/usr/local/bin/foodassistant-touch-calibrate"
        if not os.path.exists(helper):
            self._send(500, {"ok": False, "error": "calibrate helper not installed"})
            return
        try:
            r = subprocess.run(
                [helper, "--apply-matrix", " ".join(parts)],
                capture_output=True, text=True, timeout=15,
            )
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            # The compositor (cage/wlroots) holds the touch device open and only
            # reads LIBINPUT_CALIBRATION_MATRIX when the device is added, so a
            # udevadm trigger alone does not change the live mapping. Restart the
            # kiosk so cage reopens the device and picks up the new matrix.
            restarted = False
            if _service_active("foodassistant-kiosk.service"):
                try:
                    subprocess.run(
                        ["systemctl", "restart", "foodassistant-kiosk.service"],
                        timeout=30,
                    )
                    restarted = True
                except Exception:
                    pass
            self._send(200, {
                "ok": True,
                "message": r.stdout.strip(),
                "kiosk_restarted": restarted,
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_get_config(self):
        try:
            import tomllib
            path = "/opt/foodassistant/config.toml"
            if not os.path.exists(path):
                self._send(200, {"ok": True, "config": {}})
                return
            with open(path, "rb") as f:
                data = tomllib.load(f)
            self._send(200, {"ok": True, "config": data})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_set_config(self):
        try:
            body = self._body()
            cfg = body.get("config", {})

            def _scalar(v):
                if isinstance(v, bool):
                    return "true" if v else "false"
                if isinstance(v, int):
                    return str(v)
                if isinstance(v, float):
                    return repr(v)
                # Strings (and anything else) are emitted as escaped strings.
                s = str(v).replace("\\", "\\\\").replace('"', '\\"')
                return f'"{s}"'

            # Scalars and string/number lists are written as inline keys; a list
            # of dicts (e.g. key_overrides) is written as an array of tables so
            # the controller's TOML loader reads it back as configured slots.
            lines = []
            table_blocks = []
            for k, v in cfg.items():
                if isinstance(v, list) and any(isinstance(x, dict) for x in v):
                    for entry in v:
                        if not isinstance(entry, dict):
                            continue
                        table_blocks.append(f"[[{k}]]")
                        for ek, ev in entry.items():
                            table_blocks.append(f"{ek} = {_scalar(ev)}")
                        table_blocks.append("")
                elif isinstance(v, list):
                    items = ", ".join(_scalar(x) for x in v)
                    lines.append(f"{k} = [{items}]")
                elif isinstance(v, (bool, int, float, str)):
                    lines.append(f"{k} = {_scalar(v)}")
            toml_str = "\n".join(lines + [""] + table_blocks).rstrip("\n") + "\n"
            
            path = "/opt/foodassistant/config.toml"
            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, "w") as f:
                f.write(toml_str)
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_actions(self):
        try:
            r = subprocess.run(
                ["/opt/foodassistant/venv/bin/python", "-m", "foodassistant_streamdeck", "--dump-actions"],
                cwd="/opt/foodassistant", capture_output=True, text=True, timeout=10
            )
            if r.returncode == 0 and r.stdout.strip():
                self._send(200, {"ok": True, "actions": json.loads(r.stdout)})
            else:
                self._send(500, {"ok": False, "error": (r.stderr or "no output").strip()})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _streamdeck_restart(self):
        try:
            subprocess.run(
                ["systemctl", "restart", "foodassistant-streamdeck"],
                check=True, timeout=15
            )
            self._send(200, {"ok": True})
        except subprocess.CalledProcessError as e:
            self._send(500, {"ok": False, "error": str(e)})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _kiosk_restart(self):
        try:
            subprocess.run(
                ["systemctl", "restart", "foodassistant-kiosk.service"],
                check=True, timeout=30
            )
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _mealie_container_up(self):
        """True when the Mealie container exists (compose service 'mealie')."""
        try:
            r = subprocess.run(
                ["docker", "compose", "ps", "--format=json", "mealie"],
                cwd=INSTALL_DIR,
                capture_output=True, text=True, timeout=10
            )
            return bool(r.stdout.strip()) and r.returncode == 0
        except Exception:
            return False

    def _mealie_serving(self):
        """True when Mealie actually answers HTTP on its port.

        The container can sit in 'health: starting' for a minute after it is
        created, during which docker compose ps already lists it but the web
        server refuses connections. Probing the port is what tells us the link
        the user is about to click will actually work.
        """
        return _http_serving(f"http://127.0.0.1:{MEALIE_PORT}/")

    def _mealie_running(self):
        """Backwards-compatible alias: True when Mealie is up and serving."""
        return self._mealie_container_up() and self._mealie_serving()

    def _mealie_status(self):
        # Report a single phase the web UI can poll on. We only call Mealie
        # 'running' once it actually answers HTTP, so the user never gets a
        # link that refuses the connection:
        #   running        -> the container is up AND serving HTTP
        #   starting       -> the pull/up is in flight, OR the container exists
        #                     but is not serving yet (health: starting)
        #   not-installed  -> neither (idle, image not pulled / not started)
        try:
            container_up = self._mealie_container_up()
            serving = container_up and self._mealie_serving()
            starting = _installing("mealie")
            if serving:
                state = "running"
            elif starting or container_up:
                state = "starting"
            else:
                state = "not-installed"
            self._send(200, {
                "ok": True,
                "state": state,
                "running": serving,
                "starting": state == "starting",
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _mealie_start(self):
        # Pulling the Mealie image on first run can take several minutes on a
        # Pi, far longer than any reasonable HTTP timeout. Run the pull/up in
        # the background (mirroring the install provisioner) and return
        # immediately; the web UI polls /mealie/status for progress.
        if self._mealie_running():
            self._send(200, {"ok": True, "started": False, "state": "running"})
            return
        if _installing("mealie"):
            self._send(200, {"ok": True, "started": False, "state": "starting"})
            return
        try:
            log_path = "/var/log/foodassistant-mealie-start.log"
            log = open(log_path, "ab")
            p = subprocess.Popen(
                ["docker", "compose", "--profile", "with-mealie", "up", "-d"],
                cwd=INSTALL_DIR,
                env=_compose_env(),
                stdout=log, stderr=subprocess.STDOUT,
            )
            _INSTALL_PROCS["mealie"] = p
            self._send(200, {"ok": True, "started": True, "state": "starting"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _logs(self, name):
        # Tail of an install/start log so the setup UI can show live output.
        # Strip any trailing slash/query and never raise: an unknown name or a
        # log that does not exist yet just returns an empty line list.
        name = name.split("?", 1)[0].strip("/")
        if name not in _LOG_PATHS:
            self._send(404, {"ok": False, "error": "unknown log name"})
            return
        try:
            lines = _tail_log(name)
            self._send(200, {
                "ok": True,
                "name": name,
                "running": _installing(name),
                "lines": lines,
            })
        except Exception as e:
            # Defensive: _tail_log already swallows errors, but keep the
            # endpoint from ever bubbling an exception to the client.
            self._send(200, {"ok": True, "name": name, "running": False, "lines": [], "error": str(e)})

    def _hardware_status(self):
        # Live attached-hardware detection (display connectors + Stream Deck
        # model) read straight from sysfs, merged with the kiosk/streamdeck
        # service-install state the setup UI already polls for. The detection
        # block lives under "display" and the deck "model"/sysfs presence is
        # folded into the existing "streamdeck" object.
        hw = _hardware_status()
        sd_present, sd_model = hw["streamdeck"]["present"], hw["streamdeck"]["model"]
        self._send(200, {
            "ok": True,
            "display": hw["display"],
            "kiosk": {
                "present": _display_present(),
                "active": _service_active("foodassistant-kiosk.service"),
                "installing": _installing("kiosk"),
            },
            "streamdeck": {
                "present": _streamdeck_present() or sd_present,
                "model": sd_model,
                "active": _service_active("foodassistant-streamdeck.service"),
                "installing": _installing("streamdeck"),
                "key_count": _streamdeck_keycount(),
            },
        })

    def _system_health(self):
        """Power / thermal / disk health for the non-obtrusive UI indicator."""
        try:
            self._send(200, _system_health())
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _provision(self, step, unit):
        if _installing(step):
            self._send(200, {"ok": True, "started": False, "message": "Already installing."})
            return
        script, repo_dir = _find_firstboot()
        if not script:
            self._send(500, {"ok": False, "error": "Provisioner not found on this device."})
            return
        try:
            env = dict(os.environ, STEPS=step)
            if repo_dir:
                env["REPO_DIR"] = repo_dir
            log_path = f"/var/log/foodassistant-{step}-install.log"
            log = open(log_path, "ab")
            p = subprocess.Popen(
                ["bash", script], env=env, stdout=log, stderr=subprocess.STDOUT
            )
            _INSTALL_PROCS[step] = p
            self._send(200, {"ok": True, "started": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _ap_status(self):
        """Return whether the fallback AP is active."""
        try:
            active = Path(_AP_FLAG).exists()
            self._send(200, {"ok": True, "active": active})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _ap_disable(self):
        """Stop the fallback AP and remove the flag file."""
        try:
            subprocess.run(["systemctl", "stop", "hostapd"], timeout=10)
            subprocess.run(["systemctl", "stop", "dnsmasq"], timeout=10)
            try:
                subprocess.run(
                    ["ip", "addr", "del", "192.168.99.1/24", "dev", "wlan0"],
                    timeout=5
                )
            except Exception:
                pass
            try:
                Path(_AP_FLAG).unlink(missing_ok=True)
            except TypeError:
                # missing_ok added in Python 3.8; fall back for older versions.
                if Path(_AP_FLAG).exists():
                    Path(_AP_FLAG).unlink()
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _update(self):
        # Pull the latest source and redeploy by delegating to the
        # foodassistant-update helper. The bridge runs as root, so it can write
        # under /opt and restart the units (the app service cannot: its caps are
        # bound to CAP_NET_BIND_SERVICE).
        #
        # The helper redeploys both the web app and the Stream Deck package,
        # reinstalls venv deps only when requirements changed, and restarts
        # whichever services it refreshed. It is idempotent and safe to re-run
        # after a manual pull. It prints a human log to stdout and ends with a
        # single JSON line {ok, error, before, after, restarted, service_synced,
        # streamdeck_synced, deps_installed}. We parse that last line and pass
        # the full text back as "log" so the setup UI can show it. A pull that
        # fails to fast-forward leaves the checkout untouched (the helper still
        # redeploys the current HEAD); we never restart from here directly.
        helper = "/usr/local/bin/foodassistant-update"
        if not os.path.exists(helper):
            self._send(500, {"ok": False, "error": "update helper not installed"})
            return
        try:
            # An update can pull, run pip, and restart, which on a Pi may take a
            # couple of minutes when requirements change. Keep the timeout
            # generous so a slow pip install does not look like a failure.
            r = subprocess.run(
                [helper], capture_output=True, text=True, timeout=600
            )
            out = (r.stdout or "").strip()
            result = {}
            if out:
                # The JSON summary is the last non-empty stdout line.
                last = out.splitlines()[-1].strip()
                try:
                    result = json.loads(last)
                except ValueError:
                    result = {}
            if not result:
                # The helper did not emit its summary line (it should always);
                # fall back to the return code and whatever it printed.
                self._send(500, {
                    "ok": False,
                    "error": (r.stderr or out or "update helper produced no output").strip(),
                    "log": out,
                })
                return
            result["log"] = out
            self._send(200 if result.get("ok") else 500, result)
        except subprocess.TimeoutExpired:
            self._send(500, {"ok": False, "error": "update timed out"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _reboot(self):
        # Reboot the host. The bridge runs as root, so it can call systemctl
        # directly (the app service cannot: its caps are bound to
        # CAP_NET_BIND_SERVICE). We answer before the reboot takes effect; the
        # caller treats a dropped connection as success.
        cmd = _reboot_command()
        try:
            subprocess.Popen(cmd)
            self._send(200, {"ok": True, "rebooting": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _restore(self):
        # Restore the FULL stack snapshot (Grocy + Mealie + app data) by
        # delegating to the foodassistant-restore helper. The bridge runs as
        # root, so it can stop/start the docker stack and swap the data dirs;
        # the app container cannot. This mirrors _update: we validate the body,
        # run the helper synchronously, parse its LAST stdout line as JSON, and
        # relay it with the full text as "log".
        #
        # Design (the bead's open question): we do NOT accept a browser upload
        # of the large snapshot. The body's {source} is either an absolute path
        # to a .tar.gz already on the device, or "rclone:<remote-path>" to pull
        # from the configured rclone remote first. The helper itself also
        # resolves rclone sources, but we validate the shape here so a bad
        # source fails fast with a clear error and never reaches the stack.
        helper = "/usr/local/bin/foodassistant-restore"
        if not os.path.exists(helper):
            self._send(500, {"ok": False, "error": "restore helper not installed"})
            return
        body = self._body()
        kind, value = _classify_restore_source(body.get("source", ""))
        if kind == "invalid":
            self._send(400, {"ok": False, "error": value})
            return
        try:
            env = dict(os.environ)
            env.setdefault("INSTALL_DIR", INSTALL_DIR)
            env.setdefault("RCLONE_CONFIG", _RCLONE_CONFIG)
            # Stopping the stack, pulling a possibly-large snapshot, unpacking,
            # and restarting can take a while on a Pi, so keep the timeout
            # generous (the proxy's timeout is matched to this).
            r = subprocess.run(
                [helper, body.get("source", "").strip()],
                capture_output=True, text=True, timeout=900, env=env,
            )
            out = (r.stdout or "").strip()
            result = {}
            if out:
                last = out.splitlines()[-1].strip()
                try:
                    result = json.loads(last)
                except ValueError:
                    result = {}
            if not result:
                self._send(500, {
                    "ok": False,
                    "error": (r.stderr or out or "restore helper produced no output").strip(),
                    "log": out,
                })
                return
            result["log"] = out
            self._send(200 if result.get("ok") else 500, result)
        except subprocess.TimeoutExpired:
            self._send(500, {"ok": False, "error": "restore timed out"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def log_message(self, *_):
        pass



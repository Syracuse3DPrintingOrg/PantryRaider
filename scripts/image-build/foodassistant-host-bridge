# appliance compose file). Used for the readiness probe below.
MEALIE_PORT = 9285
# Flag file written by the AP watchdog service when the fallback hotspot is
# active. Checked by GET /ap/status and removed by POST /ap/disable.
_AP_FLAG = "/run/foodassistant-ap-active"

# --- Shared-token handshake (FoodAssistant-pxcm) ---------------------------
# The bridge runs as root and used to trust anything on localhost, which put
# reboot, restore, and udev writes one curl away from any local process. At
# startup it now writes a random token where the app can read it and requires
# that token back (header X-Bridge-Token) on every state-changing route.
#
# Token location: INSTALL_DIR/data/bridge-token. That directory is the app
# container's /app/data bind mount on a pi_hosted appliance, and the venv
# app's DATA_DIR on a pi_remote, so one well-known path serves both shapes.
# The Stream Deck controller reads the same path.
TOKEN_PATH = os.path.join(INSTALL_DIR, "data", "bridge-token")

# Grace mode: a request with NO token is logged and allowed, so a fleet where
# the app or deck predates the handshake cannot lock itself out of its own
# update path. A request with a WRONG token is always denied (the client
# re-reads the token file and recovers on its next call).
# TODO(FoodAssistant-pxcm): flip to False one release after every fleet
# component (app, Stream Deck controller, satellite sync) ships the
# X-Bridge-Token header, so a device that updates the bridge first keeps a
# working OTA path in the meantime. Enforcing in the same release as the
# clients would brick mixed-version fleets mid-update.
GRACE_MODE = True

# GET routes that stay open without a token. Deliberately a short list of
# harmless read-only status probes: no secrets, no file contents, nothing a
# local process could not already learn, and some are polled by callers that
# may predate the token (the app's hostname probe, the deck's activity poll).
# Everything else, including every POST, requires the token.
TOKEN_EXEMPT_GET = frozenset({
    "/hostname",
    "/activity",
    "/system/health",
    "/system/warnings",
    "/hardware/status",
    "/ap/status",
    "/mealie/status",
    "/stack/status",
    "/display/rotation",
})

# Loaded (or created) once at startup by _load_or_create_token(). Empty only
# if the token file could not be written, in which case every check falls
# back to the grace path so the bridge keeps working.
_EXPECTED_TOKEN = ""


def _load_or_create_token(path=TOKEN_PATH):
    """Return the shared token, creating the file when missing.

    Reuses an existing token so app and deck caches stay valid across bridge
    restarts. The data dir is created defensively: on first boot this service
    can start before firstboot.sh (or docker) has made INSTALL_DIR/data.

    The file is mode 644, not 600: the directory is the real boundary. The
    bridge runs as root but its callers do not all run as root (the venv app
    and the Stream Deck controller run as the primary user), and on a hosted
    appliance the data dir stays root-owned, so a 600 root:root file would be
    unreadable to them. Tradeoff: any local account can read the token, which
    is acceptable on a single-user appliance and still a large step up from
    trusting every localhost request outright.
    """
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        try:
            existing = Path(path).read_text().strip()
        except OSError:
            existing = ""
        if existing:
            os.chmod(path, 0o644)
            return existing
        token = secrets.token_hex(32)
        Path(path).write_text(token + "\n")
        os.chmod(path, 0o644)
        return token
    except OSError as e:
        print(f"bridge token: could not write {path}: {e}", flush=True)
        return ""


def _token_gate(method, path, provided, expected, grace):
    """Pure auth decision for one request: 'ok', 'grace', or 'deny'.

    Exempt read-only GETs are always 'ok'. A matching token is 'ok'. A
    missing token is 'grace' while GRACE_MODE holds, else 'deny'. A present
    but wrong token is always 'deny' (the client re-reads the file and
    recovers). When the bridge has no token of its own to compare against
    the check degrades to 'grace' so it never locks everyone out.
    """
    clean = (path or "").split("?", 1)[0]
    if method == "GET" and clean in TOKEN_EXEMPT_GET:
        return "ok"
    if not expected:
        return "grace"
    provided = (provided or "").strip()
    if provided:
        return "ok" if hmac.compare_digest(provided, expected) else "deny"
    return "grace" if grace else "deny"

# Interface name prefixes that never count as wired LAN connectivity: Wi-Fi
# (handled separately), Docker bridges, veth pairs, tunnels, and libvirt.
# Mirrors the skip list in the foodassistant-ap-watchdog script.
_NON_WIRED_PREFIXES = ("wlan", "docker", "br-", "veth", "tun", "tap", "vir")


def _is_wired_iface(name):
    """Whether an interface name looks like a real wired NIC (eth0, end0, ...)."""
    if name == "lo":
        return False
    return not name.startswith(_NON_WIRED_PREFIXES)


def _connectivity_from(default_route, wired_ifaces):
    """Pure decision: does this network state amount to real connectivity?

    default_route: `ip route show default` output (any non-blank line means a
    gateway exists). wired_ifaces: iterable of (name, carrier_up, has_ipv4)
    tuples for the machine's interfaces. The fallback hotspot assigns wlan0 a
    static address but never a default route, so a genuinely stranded device
    fails both checks and this stays False while the AP is legitimately up.
    """
    if (default_route or "").strip():
        return True
    for name, carrier_up, has_ipv4 in wired_ifaces:
        if _is_wired_iface(name) and carrier_up and has_ipv4:
            return True
    return False


def _has_lan_connectivity():
    """Whether the device already has a usable network (default route, or a
    wired interface up with an IPv4 address). Same checks as the AP watchdog,
    re-evaluated live so a cable plugged in after boot is seen."""
    try:
        route = subprocess.run(
            ["ip", "route", "show", "default"],
            capture_output=True, text=True, timeout=5,
        ).stdout
    except Exception:
        route = ""
    ifaces = []
    try:
        for dev in Path("/sys/class/net").iterdir():
            name = dev.name
            if not _is_wired_iface(name):
                continue
            try:
                carrier_up = (dev / "carrier").read_text().strip() == "1"
            except Exception:
                carrier_up = False
            has_ipv4 = False
            if carrier_up:
                try:
                    out = subprocess.run(
                        ["ip", "-4", "addr", "show", "dev", name],
                        capture_output=True, text=True, timeout=5,
                    ).stdout
                    has_ipv4 = "inet " in out
                except Exception:
                    has_ipv4 = False
            ifaces.append((name, carrier_up, has_ipv4))
    except Exception:
        pass
    return _connectivity_from(route, ifaces)


def _ap_stand_down():
    """Stop the fallback hotspot and clear its flag file (best effort)."""
    subprocess.run(["systemctl", "stop", "hostapd"], timeout=10)
    subprocess.run(["systemctl", "stop", "dnsmasq"], timeout=10)
    try:
        subprocess.run(
            ["ip", "addr", "del", "192.168.99.1/24", "dev", "wlan0"],
            timeout=5
        )
    except Exception:
        pass
    try:
        Path(_AP_FLAG).unlink(missing_ok=True)
    except TypeError:
        # missing_ok added in Python 3.8; fall back for older versions.
        if Path(_AP_FLAG).exists():
            Path(_AP_FLAG).unlink()

# Candidate locations for the provisioner script (curl-installer clone first,
# then a baked-image asset dir, then the legacy home-dir clone).
_FIRSTBOOT_CANDIDATES = [
    "/boot/firmware/firstboot.sh",
    "/home/foodassistant/FoodAssistant/scripts/image-build/firstboot.sh",
    "/opt/foodassistant-src/scripts/image-build/firstboot.sh",
]
# Helper scripts the bridge shells out to live in /usr/local/bin, installed by
# firstboot and refreshed by foodassistant-update. A device imaged before a
# helper existed (and not yet updated) is missing it, so before reporting a
# failure the bridge self-heals: the git checkout that feeds updates carries
# every helper under scripts/image-build, and the bridge runs as root, so it
# can install the missing script on the fly and proceed
# (FoodAssistant-jppi/9la0).
_HELPER_BIN_DIR = "/usr/local/bin"


def _helper_source_dirs():
    """Candidate directories holding the checkout copies of the helper
    scripts, best first. Mirrors the update helper's REPO_CANDIDATES."""
    dirs = []
    repo = os.environ.get("REPO_DIR", "").strip()
    if repo:
        dirs.append(os.path.join(repo, "scripts", "image-build"))
    dirs.append("/opt/foodassistant-src/scripts/image-build")
    dirs.append("/home/foodassistant/FoodAssistant/scripts/image-build")
    return dirs


def _find_helper_source(name, src_dirs=None):
    """Path to the checkout copy of helper `name`, or None. Pure lookup (the
    candidate dirs are injectable) so it is unit-testable."""
    for d in (src_dirs if src_dirs is not None else _helper_source_dirs()):
        path = os.path.join(d, name)
        if os.path.isfile(path):
            return path
    return None


def _ensure_helper(name, bin_dir=_HELPER_BIN_DIR):
    """Return the installed path of helper `name`, installing it from the git
    checkout when it is missing under bin_dir. Returns None when the helper is
    nowhere to be found (no checkout copy either)."""
    dst = os.path.join(bin_dir, name)
    if os.path.exists(dst):
        return dst
    src = _find_helper_source(name)
    if not src:
        return None
    try:
        shutil.copyfile(src, dst)
        os.chmod(dst, 0o755)
    except OSError:
        return None
    return dst



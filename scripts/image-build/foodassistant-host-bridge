def _write_persisted_idle_minutes(minutes, path=_DISPLAY_IDLE_FILE):
    """Persist the display idle timeout so a bridge restart keeps it."""
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w") as f:
            f.write(str(int(minutes)))
        return True
    except (OSError, ValueError):
        return False


def _display_power_commands(on, which=shutil.which, helper_path=""):
    """Ordered candidate command vectors to switch the display on/off.

    The caller tries each until one succeeds. Kept pure (the tool probe and
    the self-healed helper path are injected) so the selection is
    unit-testable.

    The compositor-aware helper is preferred (FoodAssistant-8khi): on a cage
    kiosk, vcgencmd cuts the panel below the compositor, dropping it to the
    console with no clean recovery until reboot. foodassistant-display-power
    toggles the output through wlr-randr so cage stays in control. vcgencmd and
    xset remain as fallbacks for setups without the compositor helper (e.g. a
    bare X11 display or when the kiosk is not running). `helper_path` is the
    freshly self-healed install of the helper, used when PATH does not see it
    yet (FoodAssistant-9la0).
    """
    cmds = []
    if which("foodassistant-display-power"):
        cmds.append(["foodassistant-display-power", "on" if on else "off"])
    elif helper_path:
        cmds.append([helper_path, "on" if on else "off"])
    if which("vcgencmd"):
        cmds.append(["vcgencmd", "display_power", "1" if on else "0"])
    if which("xset"):
        cmds.append(["xset", "dpms", "force", "on" if on else "off"])
    return cmds


# systemd day-of-week names indexed by the app's scheduled_reboot_day
# (0=Sunday .. 6=Saturday).
_REBOOT_WEEKDAYS = ("Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat")


def _reboot_calendar(t, frequency="", day=0):
    """The OnCalendar expression for the scheduled reboot timer.

    Nightly fires every day at HH:MM; weekly fires once a week on the given
    day (0=Sunday .. 6=Saturday). An unknown or empty frequency falls back to
    nightly, matching the original behaviour where a set time alone meant a
    nightly reboot, so an older app pushing just a time keeps working. Kept
    pure so it is unit-testable (FoodAssistant-8x4u).
    """
    try:
        day = int(day)
    except (TypeError, ValueError):
        day = 0
    if not 0 <= day <= 6:
        day = 0
    if frequency == "weekly":
        return "%s *-*-* %s:00" % (_REBOOT_WEEKDAYS[day], t)
    return "*-*-* %s:00" % t


def _reboot_command(which=shutil.which):
    """The command vector used to reboot the host.

    Prefers `systemctl reboot`; falls back to a bare `reboot` when systemctl is
    not on PATH. Kept pure (the tool probe is injected) so it is unit-testable
    without actually rebooting, mirroring _display_power_commands.
    """
    if which("systemctl"):
        return ["systemctl", "reboot"]
    return ["reboot"]


def _kiosk_restart_cmd(delay_seconds=2, token="0", which=shutil.which):
    """The command that schedules a detached, delayed kiosk restart.

    Returns ("transient", argv) when systemd-run is available: the restart
    runs as its own transient unit a moment out, decoupled from the HTTP
    request that asked for it. Falls back to ("shell", argv), a sleep+restart
    to be spawned detached. Pure (the tool probe is injected) so the selection
    is unit-testable, mirroring _display_power_commands.
    """
    delay = int(delay_seconds)
    if which("systemd-run"):
        return ("transient", [
            "systemd-run", "--collect", "--on-active=%ds" % delay,
            "--unit=fa-kiosk-restart-%s" % token,
            "systemctl", "restart", "foodassistant-kiosk.service",
        ])
    return ("shell", [
        "/bin/sh", "-c",
        "sleep %d; systemctl restart foodassistant-kiosk.service" % delay,
    ])


def _schedule_kiosk_restart(delay_seconds=2):
    """Schedule a kiosk restart without blocking the HTTP response.

    Restarting foodassistant-kiosk.service kills cage and with it the very
    browser page that made the request (the on-screen calibration flow, or a
    settings page opened on the kiosk itself). A synchronous systemctl restart
    tore that page down before the response landed, and on a Pi 3 the
    half-torn-down compositor could strand the display on the console
    (FoodAssistant-9ext). Detach and delay instead: the response is written
    first, the restart fires on its own a couple of seconds later. Returns
    True when the restart was scheduled.
    """
    kind, cmd = _kiosk_restart_cmd(
        delay_seconds, token=str(int(time.time() * 1000)), which=shutil.which)
    if kind == "transient":
        try:
            r = subprocess.run(cmd, capture_output=True, timeout=10)
            if r.returncode == 0:
                return True
        except Exception:
            pass
        # systemd-run refused (e.g. a leftover transient unit); fall back to
        # the detached shell form.
        _, cmd = _kiosk_restart_cmd(delay_seconds, which=lambda name: None)
    try:
        subprocess.Popen(cmd, start_new_session=True)
        return True
    except Exception:
        return False


def _read_persisted_wake_on_motion(path=_WAKE_ON_MOTION_FILE):
    """Read the persisted wake-on-motion mode ("auto" if unset or bad)."""
    try:
        with open(path) as f:
            mode = f.read().strip().lower()
        return mode if mode in _WAKE_ON_MOTION_MODES else "auto"
    except OSError:
        return "auto"


def _write_persisted_wake_on_motion(mode, path=_WAKE_ON_MOTION_FILE):
    """Persist the wake-on-motion mode so a bridge restart keeps it."""
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w") as f:
            f.write(str(mode))
        return True
    except OSError:
        return False


def _motion_wake_enabled(mode, sensor_present):
    """Whether motion should count as wake-worthy activity.

    Pure helper: "off" always disables; "auto" and "on" both need the sensor
    to actually be readable, so a device without one never wakes on phantom
    motion regardless of the setting.
    """
    if mode == "off":
        return False
    return bool(sensor_present)


def _motion_exceeds(prev, cur, threshold=_MOTION_THRESHOLD_G):
    """True when the acceleration vector moved more than ``threshold`` g
    between two samples.

    Pure helper: compares the magnitude of the vector delta, so a tilt, lift,
    or knock all register while a device at rest (a steady gravity vector)
    does not. A missing or malformed sample never counts as motion.
    """
    if not prev or not cur:
        return False
    try:
        dx = float(cur[0]) - float(prev[0])
        dy = float(cur[1]) - float(prev[1])
        dz = float(cur[2]) - float(prev[2])
    except (TypeError, ValueError, IndexError):
        return False
    return (dx * dx + dy * dy + dz * dz) ** 0.5 >= threshold


def _accel_iio_device(iio_root="/sys/bus/iio/devices"):
    """Sysfs directory of an LSM6-family IIO accelerometer, or "".

    Empty is the usual case: the rotation helper talks raw I2C because no
    kernel driver is bound on these devices, but if an overlay ever binds
    lsm6dsx the IIO path is preferred (no bus contention with other readers).
    """
    try:
        import glob
        for name_path in sorted(glob.glob(os.path.join(iio_root, "iio:device*", "name"))):
            if "lsm6" in _read_sysfs(name_path).lower():
                return os.path.dirname(name_path)
    except Exception:
        pass
    return ""


def _read_iio_accel(device_dir):
    """One (x, y, z) sample in g from an IIO accelerometer dir, or None."""
    try:
        scale = float(_read_sysfs(os.path.join(device_dir, "in_accel_scale")))
        out = []
        for axis in ("x", "y", "z"):
            raw = _read_sysfs(os.path.join(device_dir, "in_accel_%s_raw" % axis))
            # IIO reports raw * scale in m/s^2; convert to g so both read
            # paths and the threshold share one unit.
            out.append(int(raw) * scale / 9.80665)
        return tuple(out)
    except (TypeError, ValueError, OSError):
        return None


# LSM6DSOX I2C addresses: 0x6A with SDO low (the Adafruit default), 0x6B high.
_LSM6DSOX_ADDRS = (0x6A, 0x6B)


def _read_i2c_accel(bus_num=1):
    """One (x, y, z) sample in g straight from the LSM6DSOX over I2C, or None.

    Mirrors foodassistant-accel-rotation: no kernel driver is bound on these
    devices, so the bridge reads the registers itself. smbus2 is installed by
    firstboot when the sensor is detected at provision time; without it (or
    without the sensor) this returns None and motion wake stays off.
    """
    try:
        import smbus2  # type: ignore[import]
    except ImportError:
        return None
    CTRL1_XL = 0x10
    OUTX_L_XL = 0x28
    for addr in _LSM6DSOX_ADDRS:
        try:
            with smbus2.SMBus(bus_num) as bus:
                # 104 Hz output rate, +/-2 g range (idempotent re-arm).
                bus.write_byte_data(addr, CTRL1_XL, 0x40)
                time.sleep(0.02)
                raw = bus.read_i2c_block_data(addr, OUTX_L_XL, 6)
        except (OSError, ValueError):
            continue

        def _s16(lo, hi):
            v = (hi << 8) | lo
            return v - 65536 if v >= 32768 else v

        sens = 0.061 / 1000  # g per LSB at +/-2 g
        return (
            _s16(raw[0], raw[1]) * sens,
            _s16(raw[2], raw[3]) * sens,
            _s16(raw[4], raw[5]) * sens,
        )
    return None


def _read_accel_sample():
    """One accelerometer sample in g, IIO first then raw I2C. None when no
    sensor is readable, which is what gates motion wake on plain hardware."""
    device_dir = _accel_iio_device()
    if device_dir:
        sample = _read_iio_accel(device_dir)
        if sample is not None:
            return sample
    return _read_i2c_accel()


def _motion_wake_loop():
    """Background tick: treat real device motion as user activity.

    Polls the accelerometer about once a second while wake-on-motion is
    enabled and wakes the display through the normal activity path when the
    reading jumps. Cheap and safe everywhere else: with the mode off or no
    readable sensor the loop just sleeps on a long back-off, so hardware
    without the part never pays for the probe.
    """
    prev = None
    delay = 1.0
    while True:
        try:
            with _activity_lock:
                mode = _activity_state["wake_on_motion"]
            if mode == "off":
                prev = None
                delay = 30.0
            else:
                sample = _read_accel_sample()
                present = sample is not None
                with _activity_lock:
                    _activity_state["motion_sensor"] = present
                if not present:
                    # No sensor (or a wedged bus): back off up to five minutes
                    # so a sensorless device is not probed every second, while
                    # a hot-fixed sensor is still picked up eventually.
                    prev = None
                    delay = min(300.0, max(30.0, delay * 2))
                else:
                    if (_motion_wake_enabled(mode, present)
                            and _motion_exceeds(prev, sample)):
                        _record_activity()
                    prev = sample
                    delay = 1.0
        except Exception:
            delay = 30.0
        time.sleep(delay)


def _should_blank(now, last_activity, idle_minutes, already_blanked):
    """True when the display has been idle long enough to blank.

    Pure helper for the idle loop and its tests.
    """
    if idle_minutes <= 0 or already_blanked:
        return False
    return (now - last_activity) >= idle_minutes * 60


def _set_display_power(on):
    """Try each candidate command to power the display on/off. Returns True on
    the first success, False if none worked (or none are available). A missing
    foodassistant-display-power is reinstalled from the source checkout first
    (devices imaged before the helper existed, FoodAssistant-9la0)."""
    helper = ""
    if not shutil.which("foodassistant-display-power"):
        helper = _ensure_helper("foodassistant-display-power") or ""
    for cmd in _display_power_commands(on, helper_path=helper):
        try:
            subprocess.run(cmd, check=True, capture_output=True, timeout=10)
            return True
        except (OSError, subprocess.SubprocessError):
            continue
    return False


def _record_activity():
    """Note user activity from either surface and wake the display if it was
    blanked. Returns whether the display was woken."""
    with _activity_lock:
        was_blanked = _activity_state["display_blanked"]
        _activity_state["last_activity"] = time.time()
    if was_blanked:
        _set_display_power(True)
        with _activity_lock:
            _activity_state["display_blanked"] = False
    return was_blanked


def _display_idle_loop():
    """Background tick: blank the display once it has been idle long enough."""
    while True:
        try:
            with _activity_lock:
                idle = _activity_state["idle_minutes"]
                last = _activity_state["last_activity"]
                blanked = _activity_state["display_blanked"]
            if _should_blank(time.time(), last, idle, blanked):
                if _set_display_power(False):
                    with _activity_lock:
                        _activity_state["display_blanked"] = True
        except Exception:
            pass
        time.sleep(10)


def _tail_log(name, max_bytes=_LOG_TAIL_BYTES):
    """Return the last max_bytes of the named log as a list of lines.

    Safe by design: an unknown name, a missing file, or any read error yields
    an empty list rather than raising, so the polling endpoint never 500s just
    because a step has not created its log yet.
    """
    path = _LOG_PATHS.get(name)
    if not path:
        return []
    try:
        with open(path, "rb") as f:
            try:
                f.seek(0, os.SEEK_END)
                size = f.tell()
                f.seek(max(0, size - max_bytes))
            except OSError:
                # Not seekable for some reason; fall back to a plain read.
                f.seek(0)
            data = f.read()
        text = data.decode("utf-8", "replace")
        # Drop a leading partial line when we seeked into the middle of one.
        if len(data) >= max_bytes and "\n" in text:
            text = text.split("\n", 1)[1]
        return [ln for ln in text.splitlines() if ln.strip()]
    except OSError:
        return []
    except Exception:
        return []


def _http_serving(url, timeout=3):
    """True when a GET to url gets any HTTP response (server is up).

    A redirect or even a 4xx still means the web server answered, so anything
    short of a connection failure or a 5xx counts as serving. Used to tell a
    container that is merely created apart from one that is actually ready.
    """
    try:
        req = urllib.request.Request(url, method="GET")
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status < 500
    except urllib.error.HTTPError:
        # The server answered with an error status; it is up.
        return True
    except Exception:
        return False


def _find_firstboot():
    """Return (script_path, repo_dir) for the provisioner, or (None, None)."""
    for path in _FIRSTBOOT_CANDIDATES:
        if os.path.isfile(path):
            # firstboot.sh lives at <repo>/scripts/image-build/firstboot.sh;
            # derive the repo root so it can find the streamdeck package etc.
            repo_dir = ""
            if path.endswith("/scripts/image-build/firstboot.sh"):
                repo_dir = path[: -len("/scripts/image-build/firstboot.sh")]
            return path, repo_dir
    return None, None


def _compose_env():
    """Environment for `docker compose` runs from INSTALL_DIR.

    The appliance compose file resolves the service build context from
    ${REPO_DIR}; firstboot.sh exports it before every compose call. The bridge
    process does not inherit that export, so derive it the same way (from the
    provisioner location, falling back to the compose file's own default) to
    keep the build context valid if compose ever needs to build `service`.
    """
    env = dict(os.environ)
    if not env.get("REPO_DIR"):
        _, repo_dir = _find_firstboot()
        env["REPO_DIR"] = repo_dir or "/home/foodassistant/FoodAssistant"
    return env


# --- Mealie install persistence + resume (FoodAssistant-nqpb) --------------
# The first Mealie start pulls a large image, and the pull used to live only
# in this process's memory (_INSTALL_PROCS): a bridge restart or reboot mid
# pull lost the intent and left the install half done with nothing to finish
# it. The intent is therefore persisted as a COMPOSE_PROFILES entry in the
# stack's .env (which also makes every later plain `docker compose` command
# from INSTALL_DIR include Mealie), and the bridge re-runs an interrupted
# install on startup. `docker compose up -d` itself is idempotent: the pull
# resumes from cached layers and an existing container is reused, so re-running
# it converges rather than duplicating anything.

_ENV_FILE = f"{INSTALL_DIR}/.env"


def _env_profiles(env_text):
    """Parse COMPOSE_PROFILES from compose .env text into a list of names."""
    for line in (env_text or "").splitlines():
        s = line.strip()
        if s.startswith("COMPOSE_PROFILES="):
            val = s.split("=", 1)[1].strip().strip('"').strip("'")
            return [p.strip() for p in val.split(",") if p.strip()]
    return []


def _add_env_profile(env_text, profile):
    """Return env_text with `profile` listed in COMPOSE_PROFILES.

    Pure: appends to an existing COMPOSE_PROFILES line, or adds the line when
    missing. Returns the text unchanged when the profile is already listed.
    """
    text = env_text or ""
    lines = text.splitlines()
    for i, line in enumerate(lines):
        if line.strip().startswith("COMPOSE_PROFILES="):
            existing = _env_profiles(line)
            if profile in existing:
                return env_text
            existing.append(profile)
            lines[i] = "COMPOSE_PROFILES=" + ",".join(existing)
            return "\n".join(lines) + ("\n" if text.endswith("\n") else "")
    lines.append(f"COMPOSE_PROFILES={profile}")
    return "\n".join(lines) + "\n"


def _persist_compose_profile(profile, path=_ENV_FILE):
    """Best-effort: record `profile` in the stack's .env.

    Survives bridge restarts and reboots, so the startup resume knows Mealie
    was requested, and future compose commands include it without --profile.
    """
    try:
        text = ""
        if os.path.exists(path):
            with open(path) as f:
                text = f.read()
        new = _add_env_profile(text, profile)
        if new != text:
            with open(path, "w") as f:
                f.write(new)
        return True
    except OSError:
        return False


def _should_resume_mealie(profiles, container_up, installing):
    """True when a previously requested Mealie install should be re-run.

    Pure decision helper for the startup resume: resume only when the .env
    profiles record the intent, the container never came up (the install was
    interrupted mid-pull), and no install is currently in flight.
    """
    return "with-mealie" in profiles and not container_up and not installing


def _mealie_container_exists():
    """True when the Mealie container exists (compose service 'mealie')."""
    try:
        r = subprocess.run(
            ["docker", "compose", "ps", "--format=json", "mealie"],
            cwd=INSTALL_DIR,
            capture_output=True, text=True, timeout=10
        )
        return bool(r.stdout.strip()) and r.returncode == 0
    except Exception:
        return False


def _launch_mealie_install():
    """Start `docker compose --profile with-mealie up -d` in the background,
    streaming output into the mealie log, and track it in _INSTALL_PROCS."""
    log = open(_LOG_PATHS["mealie"], "ab")
    p = subprocess.Popen(
        ["docker", "compose", "--profile", "with-mealie", "up", "-d"],
        cwd=INSTALL_DIR,
        env=_compose_env(),
        stdout=log, stderr=subprocess.STDOUT,
    )
    _INSTALL_PROCS["mealie"] = p
    return p


def _resume_mealie_install(retries=30, delay=10, sleep=time.sleep):
    """Finish an interrupted Mealie install after a bridge restart or reboot.

    Runs once in a background thread at startup: waits for the docker daemon
    (the bridge can start before docker at boot), then re-runs the compose up
    when the stack's .env says Mealie belongs but its container never came up.
    Returns True when a resume was launched.
    """
    for _ in range(retries):
        try:
            r = subprocess.run(["docker", "info"], capture_output=True, timeout=15)
            if r.returncode == 0:
                break
        except Exception:
            pass
        sleep(delay)
    else:
        return False
    try:
        with open(_ENV_FILE) as f:
            profiles = _env_profiles(f.read())
    except OSError:
        return False
    if not _should_resume_mealie(
        profiles, _mealie_container_exists(), _installing("mealie")
    ):
        return False
    _launch_mealie_install()
    return True


# --- One-image mode switch: park / resume the local stack (FoodAssistant-dzx9)
# A pi_hosted appliance can be switched to satellite duty from Settings: the
# app flips its own deployment_mode and asks the bridge to stop the local
# backend containers. Stopping (never removing) is deliberate: the Grocy and
# Mealie data directories stay on the SD card, and because the appliance
# compose file uses restart: unless-stopped, a manually stopped container
# stays stopped across reboots with no unit changes. Switching back is a plain
# `docker compose up -d` (the persisted COMPOSE_PROFILES in the stack's .env
# brings back exactly the services that were enabled before).
#
# The app container itself is never touched here: it keeps serving the kiosk
# and, in satellite mode, pulls its config from the main server.

# Backend services the switch parks. The app's own `service` container is
# excluded on purpose: it must keep running in both modes.
_STACK_BACKEND_SERVICES = ("grocy", "mealie", "ollama")


def _compose_backend_services(compose_text):
    """Backend service names defined in a compose file's services block.

    Matches the two-space-indented `grocy:` / `mealie:` / `ollama:` service
    keys of the appliance compose file. The Pi Remote compose defines none of
    them, so an empty result means this device never hosted a local stack and
    the stand-down/stand-up endpoints must refuse to act. Pure, for tests.
    """
    found = []
    for name in _STACK_BACKEND_SERVICES:
        if re.search(r"^  %s:" % name, compose_text or "", re.M):
            found.append(name)
    return found


def _stack_stop_cmd(services):
    """The docker compose argv that stops the given backend services.

    Every optional profile is enabled explicitly so compose recognizes the
    profile-gated services (mealie/ollama) even when the profile is not in the
    stack's .env; stopping a service whose container was never created is a
    no-op. Pure, for tests.
    """
    return ["docker", "compose", "--profile", "with-mealie",
            "--profile", "with-ollama", "stop"] + list(services)


def _stack_up_cmd():
    """The docker compose argv that resumes the parked stack.

    A plain `up -d`: the COMPOSE_PROFILES persisted in the stack's .env decides
    which optional services come back, so an appliance that ran Mealie gets
    Mealie again and one that never enabled it does not. Pure, for tests.
    """
    return ["docker", "compose", "up", "-d"]


def _read_stack_compose(path=None):
    """The deployed compose file's text, or "" when it does not exist."""
    p = path or os.path.join(INSTALL_DIR, "docker-compose.yml")
    try:
        with open(p) as f:
            return f.read()
    except OSError:
        return ""


def _container_running(name):
    """True when the named container exists and is running."""
    try:
        r = subprocess.run(
            ["docker", "inspect", "-f", "{{.State.Running}}", name],
            capture_output=True, text=True, timeout=10,
        )
        return r.returncode == 0 and r.stdout.strip() == "true"
    except Exception:
        return False


# --- Full-stack restore source handling (FoodAssistant-h18b) --------------
# The restore helper (/usr/local/bin/foodassistant-restore) accepts a snapshot
# that is either already on the device (an absolute path) or pulled first from
# the configured rclone remote (an "rclone:" prefixed source). These pure
# helpers classify the source string and build the rclone pull command so they
# can be unit-tested without root or docker.

# rclone.conf lives in the install data dir, the same path the app container
# uses for RCLONE_CONFIG (admin.py writes it there).
_RCLONE_CONFIG = f"{INSTALL_DIR}/data/rclone.conf"


def _classify_restore_source(source):
    """Classify a restore source string.

    Returns a (kind, value) tuple:
      ("path", "/abs/path.tar.gz")  an absolute path on the device
      ("rclone", "remote:bucket/x") an object to pull from the rclone remote
      ("invalid", reason)           anything else (empty, relative, bad rclone)
    """
    s = (source or "").strip()
    if not s:
        return ("invalid", "Source is required.")
    if s.startswith("rclone:"):
        remote = s[len("rclone:"):].strip()
        if not remote:
            return ("invalid", "rclone source has no remote path.")
        return ("rclone", remote)
    if s.startswith("/"):
        return ("path", s)
    return ("invalid", "Source must be an absolute path or an rclone:remote path.")


def _rclone_pull_cmd(remote, dest, rclone="rclone"):
    """Build the rclone command (argv list) that copies a remote object to a
    local destination file. The caller sets RCLONE_CONFIG in the environment."""
    return [rclone, "copyto", remote, dest]


def _service_active(unit):
    """True when the given systemd unit is active."""
    try:
        return subprocess.run(
            ["systemctl", "is-active", "--quiet", unit], timeout=5
        ).returncode == 0
    except Exception:
        return False


def _unit_installed(unit, root="/etc/systemd/system"):
    """True when the unit file exists, i.e. the service was provisioned on
    this device (whether or not it is currently running). firstboot writes
    all appliance units under /etc/systemd/system."""
    return os.path.exists(os.path.join(root, unit))


# --- Forager remote-access WireGuard tunnel (FoodAssistant-uczr) -----------
# The app drives remote access from Settings, but the WireGuard endpoint lives
# on the host, not in the container: only root can create the interface and
# write /etc/wireguard. The bridge generates the device keypair, keeps the
# PRIVATE key on the device (never returned to the caller, never logged), and
# brings a split-tunnel interface up that routes ONLY the server's /32 (a hub
# route, not a full VPN, so normal traffic is untouched). The cloud side hands
# back the server public key, endpoint, and this device's tunnel address.
_WG_INTERFACE = "fa-forager"
_WG_CONFIG_PATH = "/etc/wireguard/%s.conf" % _WG_INTERFACE
_WG_PRIVATE_KEY_PATH = "/etc/wireguard/%s.key" % _WG_INTERFACE


def _render_wg_config(private_key, address, server_public_key, endpoint,
                      allowed_ips, dns="", keepalive=25):
    """Render the wg-quick config text for the Forager interface. Pure.

    AllowedIPs is the server's /32 only (the cloud passes it), so this is a
    hub route to reach the kitchen through Forager, not a full tunnel that
    would capture all of the device's traffic. DNS is written only when the
    cloud provides a resolver, so wg-quick never fails on a device without
    resolvconf. Kept pure and off the log path so the private key stays put.
    """
    addr = str(address or "").strip()
    if addr and "/" not in addr:
        addr = addr + "/32"
    try:
        keep = int(keepalive)
    except (TypeError, ValueError):
        keep = 25
    lines = [
        "[Interface]",
        "PrivateKey = %s" % (private_key or "").strip(),
        "Address = %s" % addr,
    ]
    dns = (dns or "").strip()
    if dns:
        lines.append("DNS = %s" % dns)
    lines += [
        "",
        "[Peer]",
        "PublicKey = %s" % (server_public_key or "").strip(),
        "Endpoint = %s" % (endpoint or "").strip(),
        "AllowedIPs = %s" % (allowed_ips or "").strip(),
        "PersistentKeepalive = %d" % keep,
        "",
    ]
    return "\n".join(lines)


def _parse_wg_handshakes(text):
    r"""Latest handshake epoch (int) from `wg show <iface> latest-handshakes`.

    That command prints one `<pubkey>\t<epoch-seconds>` line per peer; a peer
    that has never completed a handshake reports 0. Returns the largest epoch
    seen, or 0 when there is none. Pure, so the status parse is unit-testable
    against stubbed command output.
    """
    best = 0
    for line in (text or "").splitlines():
        parts = line.split()
        if len(parts) < 2:
            continue
        try:
            epoch = int(parts[-1])
        except ValueError:
            continue
        if epoch > best:
            best = epoch
    return best


def _wg_tools_present(which=shutil.which):
    """True when both `wg` and `wg-quick` are on PATH. Pure (probe injected)."""
    return bool(which("wg")) and bool(which("wg-quick"))


# Stream Deck / display detection from sysfs
# ------------------------------------------
# These read sysfs directly (no lsusb, no extra packages) so the appliance can
# report attached hardware on a minimal image. They take the sysfs root as an
# argument so they are testable against a faked layout under tmp_path.

# Elgato (Stream Deck maker) USB vendor id.
_STREAMDECK_VENDOR = "0fd9"


def _read_sysfs(path):
    """Return the stripped contents of a sysfs file, or "" on any error."""
    try:
        with open(path) as fh:
            return fh.read().strip()
    except OSError:
        return ""
    except Exception:
        return ""


def _drm_connected(root="/sys/class/drm"):
    """Return the list of connected DRM connector names under root.

    Scans <root>/*/status; a connector counts as connected when its status
    file reads "connected" (the kernel also emits "disconnected", which must
    not match). A missing root yields an empty list rather than raising.
    """
    import glob
    names = []
    for status_path in sorted(glob.glob(os.path.join(root, "*", "status"))):
        if _read_sysfs(status_path) == "connected":
            names.append(os.path.basename(os.path.dirname(status_path)))
    return names


def _streamdeck_config_toml(cfg):
    """Serialize the posted Stream Deck config dict to the controller's TOML.

    Scalars and flat lists are written as inline keys; a list of dicts (e.g.
    key_overrides) becomes an array of tables so the controller's TOML loader
    reads it back as configured slots. A list INSIDE a table entry (a macro
    key's "actions") is written as an inline TOML array; it used to be
    stringified, which turned the macro's action names into one unusable
    string after a round trip. Nested dicts are dropped (nothing produces
    them). Pure, so the round trip is unit-testable with tomllib.
    """
    def _scalar(v):
        if isinstance(v, bool):
            return "true" if v else "false"
        if isinstance(v, int):
            return str(v)
        if isinstance(v, float):
            return repr(v)
        # Strings (and anything else) are emitted as escaped strings.
        s = str(v).replace("\\", "\\\\").replace('"', '\\"')
        return '"%s"' % s

    def _value(v):
        if isinstance(v, list):
            return "[%s]" % ", ".join(_scalar(x) for x in v)
        return _scalar(v)

    lines = []
    table_blocks = []
    for k, v in cfg.items():
        if isinstance(v, list) and any(isinstance(x, dict) for x in v):
            for entry in v:
                if not isinstance(entry, dict):
                    continue
                table_blocks.append("[[%s]]" % k)
                for ek, ev in entry.items():
                    if isinstance(ev, dict):
                        continue
                    table_blocks.append("%s = %s" % (ek, _value(ev)))
                table_blocks.append("")
        elif isinstance(v, list):
            lines.append("%s = %s" % (k, _value(v)))
        elif isinstance(v, (bool, int, float, str)):
            lines.append("%s = %s" % (k, _scalar(v)))
    return "\n".join(lines + [""] + table_blocks).rstrip("\n") + "\n"


def _streamdeck_info(usb_root="/sys/bus/usb/devices"):
    """Return (present, model) for an attached Stream Deck under usb_root.

    Scans <usb_root>/*/idVendor for the Elgato vendor id; on a match reads the
    sibling product file for the model string. Returns (False, "") when none is
    found or the tree is absent.
    """
    import glob
    for vendor_path in sorted(glob.glob(os.path.join(usb_root, "*", "idVendor"))):
        if _read_sysfs(vendor_path).lower() == _STREAMDECK_VENDOR:
            product = _read_sysfs(os.path.join(os.path.dirname(vendor_path), "product"))
            return True, product
    return False, ""


def _hardware_status():
    """Display + Stream Deck presence read straight from sysfs.

    Returned as the body of GET /hardware/status. Always succeeds: a missing
    sysfs tree degrades to present=false rather than raising.
    """
    connectors = _drm_connected()
    sd_present, sd_model = _streamdeck_info()
    # key_count lets the wizard/editor pre-select the right deck size instead of
    # defaulting to 15 (FoodAssistant). None when the model is unknown, in which
    # case the app keeps its current selection.
    return {
        "ok": True,
        "display": {"present": bool(connectors), "connectors": connectors},
        "streamdeck": {"present": sd_present, "model": sd_model,
                       "key_count": _streamdeck_keycount()},
    }


# USB flash drive backups (FoodAssistant-ch6d)
# ---------------------------------------------
# The app container cannot see the host's /media, so backing up to an attached
# flash drive is a bridge job. Detection relies on the drive already being
# mounted (udisks/automount or fstab); the bridge never mounts, never formats,
# and only ever writes inside a pantryraider-backups/ directory on the drive.
# The parsing and rotation helpers are pure so they are unit-testable.

_USB_BACKUP_DIRNAME = "pantryraider-backups"
_USB_BACKUP_KEEP = 14
_USB_BACKUP_NAME = re.compile(r"^foodassistant-usb-\d{8}-\d{6}\.(tar\.gz|zip)$")


def _usb_removable_disks(sys_block="/sys/block"):
    """Disk names whose removable flag in sysfs is 1 (USB sticks, card readers)."""
    names = []
    try:
        entries = sorted(os.listdir(sys_block))
    except OSError:
        return []
    for name in entries:
        if _read_sysfs(os.path.join(sys_block, name, "removable")) == "1":
            names.append(name)
    return names


def _usb_parse_mounts(text):
    """Pure: parse /proc/mounts text into (device, mountpoint, fstype, options)
    tuples, decoding the octal escapes mountpoints with spaces arrive with."""
    out = []
    for line in text.splitlines():
        parts = line.split()
        if len(parts) < 4:
            continue
        dev, mnt, fstype, opts = parts[:4]
        mnt = re.sub(r"\\([0-7]{3})", lambda m: chr(int(m.group(1), 8)), mnt)
        out.append((dev, mnt, fstype, opts))
    return out


def _usb_disk_for(partition, disks):
    """Pure: the removable disk a partition belongs to (sda1 -> sda), or None.
    The remainder must be a partition suffix so sdab1 never matches sda."""
    for d in sorted(disks, key=len, reverse=True):
        if partition == d:
            return d
        if partition.startswith(d) and re.fullmatch(r"p?\d+", partition[len(d):]):
            return d
    return None


def _usb_mount_candidates(removable, mounts):
    """Pure: mounted, writable filesystems that live on a removable disk.

    Skips non-device mounts, read-only mounts, and (safety) the root and boot
    filesystems, so a Pi booted from a removable USB SSD never has its system
    disk offered as a backup target. Returns (device, mountpoint) pairs.
    """
    out = []
    for dev, mnt, _fstype, opts in mounts:
        if not dev.startswith("/dev/"):
            continue
        if _usb_disk_for(os.path.basename(dev), removable) is None:
            continue
        if mnt == "/" or mnt == "/boot" or mnt.startswith("/boot/"):
            continue
        if "ro" in opts.split(","):
            continue
        out.append((dev, mnt))
    return out


def _usb_pick_mount(candidates):
    """Pure: choose the backup target, preferring normal automount locations."""
    for prefix in ("/media/", "/run/media/", "/mnt/"):
        for dev, mnt in candidates:
            if mnt.startswith(prefix) or mnt == prefix.rstrip("/"):
                return (dev, mnt)
    return candidates[0] if candidates else None


def _usb_rotation_victims(names, keep=_USB_BACKUP_KEEP):
    """Pure: which backup files to delete so only the newest `keep` remain.
    Only our own timestamped names are considered; anything else on the drive
    is never touched."""
    ours = sorted(n for n in names if _USB_BACKUP_NAME.match(n))
    if keep <= 0:
        return ours
    return ours[:-keep] if len(ours) > keep else []


def _usb_data_dirs(root=None):
    """The data dirs to snapshot, relative to the install dir.

    An appliance's compose files bind-mount ./data (the app), ./grocy and
    ./mealie (Pi Hosted only). Whatever exists is included, so a Pi Remote
    naturally gets a config-only backup. A repo-style checkout layout is the
    fallback so the helper also works on a plain server install.
    """
    root = root or INSTALL_DIR
    dirs = []
    for options in (("data", "service/data"), ("grocy",), ("mealie",)):
        for d in options:
            if os.path.isdir(os.path.join(root, d)):
                dirs.append(d)
                break
    return dirs


def _usb_drive_status():
    """Status body for GET /usb/status. Always answers, never raises."""
    try:
        removable = _usb_removable_disks()
        with open("/proc/mounts") as f:
            mounts = _usb_parse_mounts(f.read())
        pick = _usb_pick_mount(_usb_mount_candidates(removable, mounts))
        if not pick:
            return {"ok": True, "detected": False}
        dev, mnt = pick
        st = os.statvfs(mnt)
        bdir = os.path.join(mnt, _USB_BACKUP_DIRNAME)
        backups = []
        if os.path.isdir(bdir):
            backups = sorted(n for n in os.listdir(bdir) if _USB_BACKUP_NAME.match(n))
        last = backups[-1] if backups else ""
        last_time = 0.0
        if last:
            try:
                last_time = os.stat(os.path.join(bdir, last)).st_mtime
            except OSError:
                last_time = 0.0
        return {
            "ok": True, "detected": True, "device": dev, "mountpoint": mnt,
            "free_bytes": st.f_bavail * st.f_frsize,
            "total_bytes": st.f_blocks * st.f_frsize,
            "backups_dir": bdir, "backups": len(backups),
            "last_backup": last, "last_backup_time": last_time,
        }
    except Exception as e:
        return {"ok": False, "detected": False, "error": str(e)}


# Screensaver photo slideshow (FoodAssistant-5w4m)
# -------------------------------------------------
# The kiosk screensaver can play photos from the attached flash drive. The
# bridge only ever READS, and only from a pictures/ or photos/ directory at
# the drive root (case-insensitive name match); nothing else on the drive is
# looked at. Oversized files are skipped so a stray raw dump cannot stall the
# kiosk, and every requested path is resolved and re-checked against the
# photos directory so a crafted name can never escape it.

_USB_PHOTO_DIRNAMES = ("pictures", "photos")
# HEIC/HEIF is the iPhone default. Browsers cannot render it natively, so the
# serve path transcodes it to JPEG (heif-convert) before returning bytes; it is
# still listed here so the slideshow picks it up.
_USB_HEIC_EXTS = (".heic", ".heif")
_USB_PHOTO_EXTS = (".jpg", ".jpeg", ".png", ".webp", ".gif") + _USB_HEIC_EXTS
_USB_PHOTO_MAX_BYTES = 20 * 1024 * 1024
_USB_PHOTO_TYPES = {
    ".jpg": "image/jpeg", ".jpeg": "image/jpeg", ".png": "image/png",
    ".webp": "image/webp", ".gif": "image/gif",
    # HEIC/HEIF are served transcoded, so their content type is JPEG.
    ".heic": "image/jpeg", ".heif": "image/jpeg",
}

# Transcoded HEIC frames are cached under a runtime tmp dir keyed by source
# path + mtime, so a slideshow that loops the same photos does not re-run
# heif-convert every cycle. The cache lives in tmp (not data_dir) to spare the
# SD card, and is capped so a big drive cannot fill it.
_HEIC_CACHE_DIR = os.path.join(tempfile.gettempdir(), "foodassistant-heic-cache")
_HEIC_CACHE_MAX = 60


def _usb_photos_dir(mountpoint):
    """The pictures/ or photos/ directory at the drive root, or None.

    Case-insensitive on the name (FAT drives show whatever case the other OS
    wrote), first match in sorted order wins so the pick is stable."""
    try:
        entries = sorted(os.listdir(mountpoint))
    except OSError:
        return None
    for name in entries:
        if name.lower() in _USB_PHOTO_DIRNAMES:
            path = os.path.join(mountpoint, name)
            if os.path.isdir(path):
                return path
    return None


def _usb_photo_names(pdir, max_bytes=_USB_PHOTO_MAX_BYTES):
    """Image filenames directly inside pdir: image extensions only, hidden
    files skipped, files over max_bytes skipped. Sorted for a stable list."""
    try:
        entries = sorted(os.listdir(pdir))
    except OSError:
        return []
    names = []
    for name in entries:
        if name.startswith("."):
            continue
        if os.path.splitext(name)[1].lower() not in _USB_PHOTO_EXTS:
            continue
        full = os.path.join(pdir, name)
        try:
            if not os.path.isfile(full) or os.path.getsize(full) > max_bytes:
                continue
        except OSError:
            continue
        names.append(name)
    return names


def _usb_photo_safe_path(pdir, name):
    """Resolve a requested photo name to a real path, or None if unsafe.

    Rejects anything with a path separator or leading dot outright, then
    resolves symlinks and verifies the result is a regular file whose parent
    is exactly the photos directory, so ../, absolute paths, and symlinks
    pointing elsewhere all fail closed. Extension is re-checked so this
    endpoint can only ever serve image files."""
    if not name or name.startswith(".") or "/" in name or "\\" in name:
        return None
    if os.path.splitext(name)[1].lower() not in _USB_PHOTO_EXTS:
        return None
    full = os.path.realpath(os.path.join(pdir, name))
    if os.path.dirname(full) != os.path.realpath(pdir):
        return None
    if not os.path.isfile(full):
        return None
    return full


def _usb_photo_is_heic(name):
    """True when the file is a HEIC/HEIF photo that must be transcoded to JPEG
    before a browser can render it. Pure: extension only."""
    return os.path.splitext(name)[1].lower() in _USB_HEIC_EXTS


def _heif_convert_cmd(src, dst):
    """The heif-convert argument vector to transcode src (.heic/.heif) into dst
    (.jpg). Plain args, no shell, so a filename can never be read as an option
    or a second command."""
    return ["heif-convert", src, dst]


def _heic_cache_key(src, mtime):
    """Flat cache filename for a transcoded HEIC, keyed by source path and
    mtime so an edited-in-place photo re-transcodes. Hashed so the key is a
    safe single path segment regardless of the source name. Pure."""
    import hashlib
    digest = hashlib.sha256(
        ("%s\0%s" % (src, mtime)).encode("utf-8")).hexdigest()
    return "heic-" + digest + ".jpg"


def _heic_cache_prune(cache_dir, keep=_HEIC_CACHE_MAX):
    """Keep the newest `keep` cached JPEGs, delete the rest. Best-effort."""
    try:
        entries = [os.path.join(cache_dir, n) for n in os.listdir(cache_dir)]
    except OSError:
        return
    files = []
    for path in entries:
        try:
            files.append((os.path.getmtime(path), path))
        except OSError:
            continue
    files.sort(reverse=True)
    for _mtime, path in files[keep:]:
        try:
            os.unlink(path)
        except OSError:
            pass


def _heic_transcode(src, runner=None, cache_dir=_HEIC_CACHE_DIR):
    """Return JPEG bytes for a HEIC/HEIF source, or None if it cannot be made.

    Serves from a per-source cache (keyed by path + mtime) when present,
    otherwise runs heif-convert into a tempfile and caches the result. Returns
    None (never raises) when heif-convert is missing or fails, so the serve
    path can answer 415 instead of 500. `runner` is injectable for tests."""
    if runner is None:
        runner = subprocess.run
    try:
        mtime = os.path.getmtime(src)
    except OSError:
        return None
    cached = os.path.join(cache_dir, _heic_cache_key(src, mtime))
    try:
        with open(cached, "rb") as f:
            return f.read()
    except OSError:
        pass
    tmp = None
    try:
        os.makedirs(cache_dir, exist_ok=True)
        fd, tmp = tempfile.mkstemp(suffix=".jpg", dir=cache_dir)
        os.close(fd)
        r = runner(_heif_convert_cmd(src, tmp),
                   capture_output=True, timeout=120)
        if getattr(r, "returncode", 1) != 0:
            return None
        with open(tmp, "rb") as f:
            body = f.read()
        if not body:
            return None
        # Publish atomically so a torn write is never read as a good frame.
        os.replace(tmp, cached)
        tmp = None
        _heic_cache_prune(cache_dir)
        return body
    except (OSError, FileNotFoundError, subprocess.SubprocessError):
        # FileNotFoundError covers heif-convert not being installed.
        return None
    finally:
        if tmp is not None:
            try:
                os.unlink(tmp)
            except OSError:
                pass


# Photos are read-only, so unlike backups they can use a drive mounted
# read-only (many automounters, and every headless mount below, mount FAT and
# exFAT sticks that way). This mirrors _usb_mount_candidates but keeps the ro
# mounts the backup target must skip.
def _usb_photo_mount_candidates(removable, mounts):
    """Pure: mounted removable filesystems, read-only ones included."""
    out = []
    for dev, mnt, _fstype, opts in mounts:
        if not dev.startswith("/dev/"):
            continue
        if _usb_disk_for(os.path.basename(dev), removable) is None:
            continue
        if mnt == "/" or mnt == "/boot" or mnt.startswith("/boot/"):
            continue
        out.append((dev, mnt))
    return out


def _usb_partitions_for(disk, sys_block="/sys/block"):
    """Pure: partition device paths on a removable disk (sda -> [/dev/sda1..]).
    A disk with no partition table (whole-disk filesystem) yields the disk."""
    try:
        entries = sorted(os.listdir(os.path.join(sys_block, disk)))
    except OSError:
        return []
    parts = [os.path.join("/dev", e) for e in entries
             if e.startswith(disk) and re.fullmatch(r"p?\d+", e[len(disk):])]
    return parts or [os.path.join("/dev", disk)]


def _usb_unmounted_partitions(removable, mounts, sys_block="/sys/block"):
    """Pure: removable partitions with no entry in the mount table. These are
    the ones a headless Pi never automounts, so the bridge mounts one itself."""
    mounted = {dev for dev, _mnt, _fs, _opts in mounts}
    out = []
    for disk in removable:
        for part in _usb_partitions_for(disk, sys_block):
            if part not in mounted:
                out.append(part)
    return out


# Where the bridge mounts a drive that nothing else did. Read-only, so a photo
# slideshow never risks a write or an fsck on the user's stick.
_USB_PHOTO_MOUNT = "/run/foodassistant-usb"


def _usb_try_mount_ro(device, mountpoint=_USB_PHOTO_MOUNT):
    """Mount a removable partition read-only for reading photos. Best-effort:
    returns the mountpoint on success, None otherwise. Read-only with the
    hardening flags means the worst a bad stick can do is fail to mount."""
    try:
        os.makedirs(mountpoint, exist_ok=True)
        subprocess.run(
            ["mount", "-o", "ro,noatime,nosuid,nodev,noexec", device, mountpoint],
            check=True, capture_output=True, timeout=20)
        return mountpoint
    except (OSError, subprocess.SubprocessError):
        return None


def _usb_photos_status():
    """The drive's photos directory, or (None, reason). Uses an already-mounted
    removable drive (read-only included); if none is mounted, mounts an
    unmounted removable partition read-only and looks there, so the feature
    works on a headless Pi that has no automounter (FoodAssistant-l3op)."""
    removable = _usb_removable_disks()
    with open("/proc/mounts") as f:
        mounts = _usb_parse_mounts(f.read())
    # Already mounted (by an automounter or a previous call): read it in place.
    pick = _usb_pick_mount(_usb_photo_mount_candidates(removable, mounts))
    if pick:
        pdir = _usb_photos_dir(pick[1])
        return (pdir, "") if pdir else (None, "no photos folder")
    # Nothing mounted the drive. Mount an unmounted removable partition
    # read-only ourselves and look for the photos folder.
    for device in _usb_unmounted_partitions(removable, mounts):
        mnt = _usb_try_mount_ro(device)
        if not mnt:
            continue
        pdir = _usb_photos_dir(mnt)
        if pdir:
            return pdir, ""
        # Wrong partition (no photos folder): unmount and try the next.
        subprocess.run(["umount", mnt], capture_output=True, timeout=20)
    return None, "no drive"


# Meaning of each bit in the "throttled" word reported by `vcgencmd
# get_throttled`. The low four bits are live (happening right now); the high
# four are sticky (happened at some point since boot). See
# https://www.raspberrypi.com/documentation/computers/os.html#get_throttled
_THROTTLE_BITS = {
    0: ("undervoltage", "Under-voltage detected", True),
    1: ("freq_capped", "Arm frequency capped", True),
    2: ("throttled", "Currently throttled", True),
    3: ("temp_limit", "Soft temperature limit active", True),
    16: ("undervoltage", "Under-voltage has occurred since boot", False),
    17: ("freq_capped", "Arm frequency capping has occurred since boot", False),
    18: ("throttled", "Throttling has occurred since boot", False),
    19: ("temp_limit", "Soft temperature limit has occurred since boot", False),
}


def _parse_throttled(word):
    """Decode a `vcgencmd get_throttled` value into a list of warnings.

    `word` is the integer throttle bitmask (the 0x... value vcgencmd prints).
    Returns a list of {key, message, live} dicts, live=True for conditions
    happening right now and live=False for sticky "since boot" flags. An
    all-clear bitmask returns an empty list.
    """
    out = []
    for bit, (key, message, live) in _THROTTLE_BITS.items():
        if word & (1 << bit):
            out.append({"key": key, "message": message, "live": live})
    return out


def _read_throttled_word():
    """Return the integer from `vcgencmd get_throttled`, or None if unavailable.

    Output looks like "throttled=0x50005"; anything else (vcgencmd missing, a
    non-Pi host) yields None so the caller can report "unknown" rather than a
    false all-clear.
    """
    try:
        out = subprocess.run(
            ["vcgencmd", "get_throttled"], capture_output=True, text=True, timeout=5
        ).stdout.strip()
    except Exception:
        return None
    m = re.search(r"throttled=(0x[0-9a-fA-F]+|\d+)", out)
    if not m:
        return None
    try:
        return int(m.group(1), 0)
    except ValueError:
        return None


def _read_cpu_temp(path="/sys/class/thermal/thermal_zone0/temp"):
    """CPU temperature in Celsius (float), or None if it can't be read.

    The sysfs file holds millidegrees, e.g. "48312" -> 48.3.
    """
    raw = _read_sysfs(path)
    if not raw:
        return None
    try:
        return round(int(raw) / 1000.0, 1)
    except ValueError:
        return None


def _disk_usage(path="/"):
    """Return (percent_used, free_gb) for the filesystem holding path.

    Returns (None, None) if it can't be determined.
    """
    try:
        import shutil
        total, used, free = shutil.disk_usage(path)
        percent = round(used / total * 100) if total else None
        return percent, round(free / (1024 ** 3), 1)
    except Exception:
        return None, None


# Surface a warning when the CPU crosses this temperature or the disk crosses
# this fill level. The Pi soft-throttles around 80C and hard-throttles at 85C,
# so 80 is the right point to start nudging the user.
_TEMP_WARN_C = 80.0
_DISK_WARN_PCT = 90


def _system_health():
    """Pi system health for GET /system/health: power, thermal, and disk.

    Always succeeds. Each probe degrades to None/empty rather than raising, so
    a partial read (e.g. vcgencmd present but no thermal zone) still returns a
    usable shape. The "warnings" list is what the UI badge keys off; an empty
    list means all clear.
    """
    word = _read_throttled_word()
    throttle_flags = _parse_throttled(word) if word is not None else []
    temp_c = _read_cpu_temp()
    disk_pct, disk_free_gb = _disk_usage()

    warnings = list(throttle_flags)
    if temp_c is not None and temp_c >= _TEMP_WARN_C:
        warnings.append({
            "key": "temperature",
            "message": f"CPU temperature high ({temp_c:.0f}C)",
            "live": True,
        })
    if disk_pct is not None and disk_pct >= _DISK_WARN_PCT:
        warnings.append({
            "key": "disk",
            "message": f"Disk almost full ({disk_pct}% used)",
            "live": True,
        })

    return {
        "ok": True,
        "throttled": word,
        "temp_c": temp_c,
        "disk_percent": disk_pct,
        "disk_free_gb": disk_free_gb,
        "warnings": warnings,
    }


# --- Continuous system monitoring (FoodAssistant-y06w) ----------------------
# A 60-second loop keeps a cached snapshot of the same power/thermal/disk
# probes _system_health runs on demand, so GET /system/warnings answers
# instantly (no vcgencmd round-trip per request) and the app can poll it
# cheaply, raise action items while a condition holds, and retire them when it
# clears. The disk probe watches the app data mount (where Grocy/Mealie and the
# photos live), not just /, so a filling SD card is caught where it hurts.

_DATA_MOUNT = os.path.join(INSTALL_DIR, "data")


def _collapse_throttle_flags(flags):
    """One warning per throttle key, preferring the live bit over the sticky.

    _parse_throttled reports the live (low) and since-boot (high) bits as
    separate entries with the same key. For the warnings feed we want each
    condition once: "happening now" when the live bit is set, else the sticky
    "has occurred since boot" wording. Order is preserved by key first-seen.
    """
    by_key = {}
    order = []
    for f in flags or []:
        k = f.get("key")
        if k not in by_key:
            by_key[k] = f
            order.append(k)
        elif f.get("live") and not by_key[k].get("live"):
            by_key[k] = f
    return [by_key[k] for k in order]


def _warnings_snapshot(word, temp_c, disk_pct, disk_free_gb, checked_epoch=None):
    """Build the /system/warnings payload from raw probe values. Pure.

    Mirrors _system_health's thresholds (temp >= 80C, disk >= 90%) but
    collapses the live/sticky throttle pairs to one warning per condition,
    which is what the app dedupes action items on.
    """
    flags = _collapse_throttle_flags(_parse_throttled(word) if word is not None else [])
    warnings = list(flags)
    if temp_c is not None and temp_c >= _TEMP_WARN_C:
        warnings.append({
            "key": "temperature",
            "message": f"CPU temperature high ({temp_c:.0f}C)",
            "live": True,
        })
    if disk_pct is not None and disk_pct >= _DISK_WARN_PCT:
        warnings.append({
            "key": "disk",
            "message": f"Storage almost full ({disk_pct}% used)",
            "live": True,
        })
    return {
        "ok": True,
        "throttled": word,
        "temp_c": temp_c,
        "disk_percent": disk_pct,
        "disk_free_gb": disk_free_gb,
        "warnings": warnings,
        "checked_epoch": checked_epoch if checked_epoch is not None else time.time(),
    }


_warnings_lock = threading.Lock()
_warnings_cache = None  # last snapshot from the loop; None until the first run


def _refresh_system_warnings():
    """Run the probes once and store the snapshot for GET /system/warnings."""
    global _warnings_cache
    disk_path = _DATA_MOUNT if os.path.isdir(_DATA_MOUNT) else "/"
    disk_pct, disk_free_gb = _disk_usage(disk_path)
    snap = _warnings_snapshot(
        _read_throttled_word(), _read_cpu_temp(), disk_pct, disk_free_gb)
    with _warnings_lock:
        _warnings_cache = snap
    return snap


def _system_warnings():
    """Cached snapshot for GET /system/warnings (probing now if none yet)."""
    with _warnings_lock:
        snap = _warnings_cache
    return snap if snap is not None else _refresh_system_warnings()


def _system_warnings_loop(interval=60):
    """Refresh the warnings snapshot every minute, forever. Never raises."""
    while True:
        try:
            _refresh_system_warnings()
        except Exception as e:
            print(f"system warnings probe failed: {e}", flush=True)
        time.sleep(interval)


# --- Support bundle (FoodAssistant-w7mb) -----------------------------------
# GET /support-bundle returns a JSON report of host-level facts the app folds
# into its downloadable support zip: systemd unit states, drop-in contents,
# helper hashes, journal and log tails, display and input probes. Every probe
# is best-effort: a missing command or file yields a "note: ..." line in its
# section, never an error, so a partial device still produces a full bundle.

_SUPPORT_UPDATE_LOG = "/var/log/foodassistant-update.log"
_SUPPORT_TAIL_BYTES = 32768


def _run_capture(cmd, timeout=15):
    """Run a command and return its stdout as text, degrading to a note.

    A nonzero exit with output still returns the output (df and systemctl
    exit nonzero for benign reasons); anything unrunnable becomes a one-line
    note so support bundle sections never raise.
    """
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        out = (r.stdout or "").strip()
        if out:
            return out
        err = (r.stderr or "").strip()
        if r.returncode != 0:
            return "note: %s exited %d: %s" % (cmd[0], r.returncode, err or "no output")
        return err or ("note: %s produced no output" % cmd[0])
    except FileNotFoundError:
        return "note: %s is not installed on this device" % cmd[0]
    except subprocess.TimeoutExpired:
        return "note: %s timed out" % cmd[0]
    except Exception as e:
        return "note: %s failed: %s" % (cmd[0], e)


def _read_file_or_note(path, max_bytes=_SUPPORT_TAIL_BYTES):
    """Tail of a text file, or a note when it is missing or unreadable."""
    try:
        with open(path, "rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            f.seek(max(0, size - max_bytes))
            data = f.read()
        text = data.decode("utf-8", "replace")
        if size > max_bytes:
            text = "note: showing the last %d bytes of %d\n%s" % (max_bytes, size, text)
        return text if text.strip() else "note: %s is empty" % path
    except FileNotFoundError:
        return "note: %s does not exist" % path
    except OSError as e:
        return "note: could not read %s: %s" % (path, e)


def _support_unit_names(run=_run_capture):
    """Names of every foodassistant-* systemd unit file on the device."""
    out = run(["systemctl", "list-unit-files", "foodassistant-*",
               "--no-legend", "--no-pager"])
    names = []
    for line in out.splitlines():
        first = line.split()[0] if line.split() else ""
        if first.startswith("foodassistant-"):
            names.append(first)
    return names


def _support_units(run=_run_capture):
    """One line per foodassistant-* unit: name, enabled state, active state."""
    names = _support_unit_names(run)
    if not names:
        return "note: no foodassistant-* systemd units found"
    lines = []
    for name in names:
        enabled = run(["systemctl", "is-enabled", name]).splitlines()
        active = run(["systemctl", "is-active", name]).splitlines()
        lines.append("%s: enabled=%s active=%s" % (
            name,
            enabled[0] if enabled else "?",
            active[0] if active else "?",
        ))
    return "\n".join(lines)


def _support_dropins(root="/etc/systemd/system"):
    """Contents of every foodassistant-* unit file and drop-in under root."""
    import glob
    paths = sorted(
        glob.glob(os.path.join(root, "foodassistant-*"))
        + glob.glob(os.path.join(root, "foodassistant-*.d", "*"))
    )
    parts = []
    for p in paths:
        if os.path.isfile(p):
            parts.append("===== %s =====\n%s" % (p, _read_file_or_note(p)))
    return "\n\n".join(parts) or "note: no foodassistant-* unit files under %s" % root


def _support_helper_hashes(bin_dir=_HELPER_BIN_DIR):
    """sha1 of each installed foodassistant-* helper, so version skew between
    devices (or against the repo) is visible at a glance."""
    import glob
    import hashlib
    lines = []
    for p in sorted(glob.glob(os.path.join(bin_dir, "foodassistant-*"))):
        if not os.path.isfile(p):
            continue
        try:
            with open(p, "rb") as f:
                digest = hashlib.sha1(f.read()).hexdigest()
            lines.append("%s  %s" % (digest, p))
        except OSError as e:
            lines.append("note: could not hash %s: %s" % (p, e))
    return "\n".join(lines) or "note: no foodassistant-* helpers under %s" % bin_dir


def _support_boot_cmdline():
    for path in ("/boot/firmware/cmdline.txt", "/boot/cmdline.txt"):
        if os.path.exists(path):
            return "%s:\n%s" % (path, _read_file_or_note(path))
    return "note: no boot cmdline file found"


def _support_drm(root="/sys/class/drm"):
    """Every DRM connector's status, connected or not, one per line."""
    import glob
    lines = []
    for status_path in sorted(glob.glob(os.path.join(root, "*", "status"))):
        name = os.path.basename(os.path.dirname(status_path))
        lines.append("%s: %s" % (name, _read_sysfs(status_path) or "unreadable"))
    return "\n".join(lines) or "note: no DRM connectors under %s" % root


def _support_bundle(run=_run_capture):
    """Assemble the host-side support report: {section name: text}.

    Section names become file names inside the app's support zip (host/<name>
    .txt). Everything is text and everything degrades to a note.
    """
    sections = {
        "systemd-units": _support_units(run),
        "systemd-unit-files": _support_dropins(),
        "boot-cmdline": _support_boot_cmdline(),
        "helper-sha1": _support_helper_hashes(),
        "bridge-journal": run(["journalctl", "-u", "foodassistant-host-bridge",
                               "-n", "200", "--no-pager"]),
        "input-devices": _read_file_or_note("/proc/bus/input/devices"),
        "drm-connectors": _support_drm(),
        "disk-usage": run(["df", "-h", INSTALL_DIR])
                      if os.path.isdir(INSTALL_DIR) else run(["df", "-h", "/"]),
        "throttled": run(["vcgencmd", "get_throttled"]),
        "update-log": _read_file_or_note(_SUPPORT_UPDATE_LOG),
    }
    return {"ok": True, "sections": sections}


def _streamdeck_present():
    try:
        out = subprocess.run(["lsusb"], capture_output=True, text=True, timeout=5).stdout
        if "0fd9:" in out.lower():
            return True
    except Exception:
        pass
    # Fallback: scan sysfs idVendor files.
    try:
        import glob
        for f in glob.glob("/sys/bus/usb/devices/*/idVendor"):
            try:
                with open(f) as fh:
                    if fh.read().strip().lower() == "0fd9":
                        return True
            except OSError:
                continue
    except Exception:
        pass
    return False


# Elgato USB product IDs mapped to their key counts. Lets the web editor size
# its grid to the deck that is actually attached instead of guessing.
_SD_PRODUCT_KEYS = {
    "0060": 15, "006d": 15, "0080": 15,   # Original / v2 / MK.2
    "0063": 6, "0090": 6,                 # Mini / Mini MK.2
    "006c": 32, "008f": 32,               # XL / XL v2
}


# Touch-controller name hints (lowercased) for finding the panel in the kernel
# input list when applying a calibration matrix. Mirrors the app's detection.
_TOUCH_NAME_HINTS = (
    "touch", "ads7846", "goodix", "ft5x", "ft6", "edt-ft5", "ilitek", "ili2",
    "silead", "eeti", "egalax", "hynitron", "st1633", "gslx680", "stmpe",
    "raspberrypi-ts", "waveshare", "hosyond", "chipone", "cst", "zforce",
)


def _touch_device_name(path="/proc/bus/input/devices"):
    """Name of the first touchscreen in the input device list, or '' if none.

    Matches a known controller name, or a kernel-flagged direct absolute pointer
    (INPUT_PROP_DIRECT plus absolute axes), the same signals the app uses."""
    try:
        blocks = open(path).read().split("\n\n")
    except OSError:
        return ""
    for b in blocks:
        nm = re.search(r'^N: Name="(.*)"', b, re.M)
        if not nm:
            continue
        low = b.lower()
        if any(h in low for h in _TOUCH_NAME_HINTS):
            return nm.group(1)
        prop = re.search(r"^B: PROP=([0-9a-fA-F]+)", b, re.M)
        has_abs = re.search(r"^B: ABS=[0-9a-fA-F]", b, re.M) is not None
        if prop and (int(prop.group(1), 16) & 0x2) and has_abs:
            return nm.group(1)
    return ""


# Where the base calibration is remembered so it can follow a display rotation
# (FoodAssistant-9ohp): the matrix the user fit, plus the rotation it was fit
# at. The compositor does not transform touch, so a matrix taken at one rotation
# is wrong at another; we recompose it by the rotation delta instead of making
# the user recalibrate.
_CALIB_STORE = "/etc/foodassistant/touch-calibration.json"

# Rotation of normalized coordinates as a 2x3 affine [a b c d e f] mapping
# (x,y) -> (a*x+b*y+c, d*x+e*y+f). The 90/270 pair is the clockwise/counter
# convention; if a rotated display ends up mirrored the wrong way, swap them.
_ROT_AFFINE = {
    0:   [1, 0, 0, 0, 1, 0],
    90:  [0, -1, 1, 1, 0, 0],    # (x,y) -> (1-y, x)
    180: [-1, 0, 1, 0, -1, 1],   # (x,y) -> (1-x, 1-y)
    270: [0, 1, 0, -1, 0, 1],    # (x,y) -> (y, 1-x)
}


def _compose_affine(t, m):
    """Affine for t(m(x,y)); both are 2x3 [a b c d e f]."""
    a, b, c, d, e, f = m
    t0, t1, t2, t3, t4, t5 = t
    return [t0 * a + t1 * d, t0 * b + t1 * e, t0 * c + t1 * f + t2,
            t3 * a + t4 * d, t3 * b + t4 * e, t3 * c + t4 * f + t5]


def _read_kiosk_rotation():
    """Current kiosk rotation in degrees (0 when unset/normal)."""
    try:
        val = open("/etc/foodassistant/kiosk-rotation").read().strip()
    except OSError:
        return 0
    return {"90": 90, "180": 180, "270": 270}.get(val, 0)


def _store_base_calibration(matrix, rotation):
    """Remember the fit matrix and the rotation it was taken at."""
    try:
        os.makedirs("/etc/foodassistant", exist_ok=True)
        with open(_CALIB_STORE, "w") as f:
            json.dump({"matrix": matrix, "rotation": int(rotation)}, f)
    except OSError:
        pass


def _matrix_for_rotation(target_deg):
    """The touch matrix for target_deg, or None when no rule is needed.

    Composes the rotation delta onto the stored fit: M = Rot(target - base) .
    M_base. A panel that was never calibrated (e.g. the 7-inch DSI screen,
    accurate out of the box) has no store; it is treated as an identity fit at
    rotation 0, so rotating the display still writes the pure rotation matrix.
    Without that, touch stayed in panel-native orientation on rotated
    never-calibrated panels (FoodAssistant-mox4): the compositor rotates only
    the output, never touch. Returns None when the composed matrix is the
    identity, meaning any existing rule should be removed rather than written.
    """
    base = None
    try:
        with open(_CALIB_STORE) as f:
            base = json.load(f)
    except (OSError, ValueError):
        pass
    m, base_rot = [1.0, 0, 0, 0, 1.0, 0], 0
    if isinstance(base, dict):
        parts = (base.get("matrix") or "").split()
        if len(parts) == 6:
            m = [float(p) for p in parts]
            base_rot = int(base.get("rotation", 0))
    delta = (int(target_deg) - base_rot) % 360
    composed = _compose_affine(_ROT_AFFINE.get(delta, _ROT_AFFINE[0]), m)
    if all(abs(v - i) < 1e-9 for v, i in zip(composed, [1, 0, 0, 0, 1, 0])):
        return None
    return " ".join("%.6g" % v for v in composed)


def _remove_calibration_rule():
    """Delete the touch udev rule (if any) and reload udev. Used when the
    composed matrix is the identity, so the panel default applies again."""
    rule = "/etc/udev/rules.d/99-foodassistant-touch.rules"
    if not os.path.exists(rule):
        return False
    os.remove(rule)
    subprocess.run(["udevadm", "control", "--reload-rules"], timeout=10)
    subprocess.run(["udevadm", "trigger", "--subsystem-match=input"], timeout=10)
    return True


def _write_calibration_rule(matrix):
    """Write the LIBINPUT_CALIBRATION_MATRIX udev rule and reload udev.

    Matches the detected panel by name (or any udev-tagged touchscreen as a
    fallback), so cage/libinput applies the matrix when the device is next
    opened. Returns the device match used, for the log."""
    name = _touch_device_name()
    match = 'ATTRS{name}=="%s"' % name if name else 'ENV{ID_INPUT_TOUCHSCREEN}=="1"'
    rule = (
        "# FoodAssistant touchscreen calibration (applied from the web UI).\n"
        'SUBSYSTEM=="input", KERNEL=="event*", %s, '
        'ENV{LIBINPUT_CALIBRATION_MATRIX}="%s"\n' % (match, matrix)
    )
    os.makedirs("/etc/udev/rules.d", exist_ok=True)
    with open("/etc/udev/rules.d/99-foodassistant-touch.rules", "w") as f:
        f.write(rule)
    subprocess.run(["udevadm", "control", "--reload-rules"], timeout=10)
    subprocess.run(["udevadm", "trigger", "--subsystem-match=input"], timeout=10)
    return name or "ID_INPUT_TOUCHSCREEN"


# Boot config path: /boot/firmware/config.txt on Bookworm+, /boot/config.txt on
# older releases. Mirrors firstboot.sh's _pi_config_txt. Empty when neither
# exists (not a Pi, or an unusual image).
def _pi_config_txt():
    for p in ("/boot/firmware/config.txt", "/boot/config.txt"):
        if os.path.exists(p):
            return p
    return ""


# The ADS7846 SPI resistive-touch overlay for Waveshare 3.5-4in HDMI LCDs and
# similar small Pi HATs. Kept in step with firstboot.sh configure_touch's
# ads7846 branch: penirq_pull=2 pulls up the active-low PENIRQ line, swapxy=1
# matches the panel's landscape mount, and the x/y bounds are the measured
# Waveshare defaults.
_ADS7846_OVERLAY = (
    "dtoverlay=ads7846,cs=1,penirq=25,penirq_pull=2,speed=50000,keep_vcc,"
    "swapxy=1,pmax=255,xohms=150,xmin=200,xmax=3900,ymin=200,ymax=3900"
)


def _config_has_active(text, needle):
    """True when a non-comment line of the boot config contains needle."""
    return any(needle in ln and not ln.lstrip().startswith("#")
               for ln in text.splitlines())


def _provision_touch(driver, cfg_path=None):
    """Apply, on a running Pi, the boot config a touch panel needs.

    This is the missing counterpart to firstboot.sh configure_touch: the display
    type chosen in the setup wizard AFTER first boot never re-ran provisioning,
    so an ADS7846 panel stayed invisible (no SPI, no overlay). Called from the
    web UI, this writes what firstboot would have.

    driver 'ads7846' enables SPI and adds the ADS7846 overlay (a reboot loads
    it). Other drivers need no boot-config overlay here. Idempotent: re-running
    is a no-op once the lines are present. Returns (changed, needs_reboot).
    Raises OSError when the boot config cannot be found or written."""
    if driver != "ads7846":
        return (False, False)
    cfg = cfg_path or _pi_config_txt()
    if not cfg:
        raise OSError("no Pi boot config.txt found")
    text = open(cfg).read()
    lines = []
    if not _config_has_active(text, "dtparam=spi=on"):
        lines.append("dtparam=spi=on")
    if not _config_has_active(text, "dtoverlay=ads7846"):
        lines.append(_ADS7846_OVERLAY)
    if not lines:
        return (False, False)
    # Emit under an explicit [all] header so the overlay applies regardless of
    # whatever board-specific section the file happened to end in.
    block = ("\n[all]\n# FoodAssistant: ADS7846 SPI resistive touch "
             "(Waveshare 3.5-4in HDMI)\n" + "\n".join(lines) + "\n")
    with open(cfg, "a") as f:
        if not text.endswith("\n"):
            f.write("\n")
        f.write(block)
    return (True, True)


def _streamdeck_keycount(usb_root="/sys/bus/usb/devices"):
    """Best-effort key count for the attached deck, or None if unknown."""
    try:
        import re
        out = subprocess.run(["lsusb"], capture_output=True, text=True, timeout=5).stdout
        m = re.search(r"0fd9:([0-9a-fA-F]{4})", out)
        if m:
            return _SD_PRODUCT_KEYS.get(m.group(1).lower())
    except Exception:
        pass
    # Fallback when lsusb is unavailable: read the Elgato device's idProduct from
    # sysfs and map it, mirroring how _streamdeck_info finds the vendor there.
    try:
        import glob
        for vendor_path in sorted(glob.glob(os.path.join(usb_root, "*", "idVendor"))):
            if _read_sysfs(vendor_path).lower() == _STREAMDECK_VENDOR:
                pid = _read_sysfs(os.path.join(os.path.dirname(vendor_path), "idProduct")).lower()
                if pid:
                    return _SD_PRODUCT_KEYS.get(pid)
    except Exception:
        pass
    return None


def _installing(step):
    p = _INSTALL_PROCS.get(step)
    return bool(p and p.poll() is None)


def _start_provision(step):
    """Launch the provisioner for one step (firstboot with STEPS=<step>) in
    the background, streaming output to the step's install log. Returns
    (ok, started, error). Re-entry while the same step is still running is a
    no-op (ok=True, started=False), and firstboot's steps are themselves
    idempotent, so re-running an already-provisioned step changes nothing.
    """
    if _installing(step):
        return True, False, ""
    script, repo_dir = _find_firstboot()
    if not script:
        return False, False, "Provisioner not found on this device."
    try:
        env = dict(os.environ, STEPS=step)
        if repo_dir:
            env["REPO_DIR"] = repo_dir
        log = open(f"/var/log/foodassistant-{step}-install.log", "ab")
        p = subprocess.Popen(
            ["bash", script], env=env, stdout=log, stderr=subprocess.STDOUT
        )
        _INSTALL_PROCS[step] = p
        return True, True, ""
    except Exception as e:
        return False, False, str(e)


# Kiosk auto-enable (FoodAssistant-92e.3)
# ---------------------------------------
# A Pi provisioned without a display skips the kiosk (the display gate in
# firstboot). When a display is connected later the appliance should just
# light up: this watcher notices the connector coming up and provisions or
# starts the kiosk on its own, no reflash or SSH needed. An explicit
# ENABLE_KIOSK=false in the appliance config opts out.

# Same config file search order firstboot uses (it sources the first hit).
_CONFIG_ENV_CANDIDATES = [
    "/boot/firmware/foodassistant.config.env",
    "/boot/foodassistant.config.env",
    "/etc/foodassistant/config.env",
]

_KIOSK_UNIT = "foodassistant-kiosk.service"


def _config_env_value(key, paths=None):
    """Return KEY's value from the first appliance config file that exists.

    Mirrors how firstboot consumes the file (it sources the first candidate,
    so a later assignment in the same file wins, and other candidates are
    never read). Comment lines, blank lines, and an optional `export ` prefix
    are handled; surrounding quotes are stripped. Returns "" when the key is
    unset or no config file exists.
    """
    for path in (paths if paths is not None else _CONFIG_ENV_CANDIDATES):
        try:
            with open(path) as fh:
                lines = fh.read().splitlines()
        except OSError:
            continue
        value = ""
        for line in lines:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[len("export "):].lstrip()
            if "=" not in line:
                continue
            k, v = line.split("=", 1)
            if k.strip() == key:
                value = v.strip().strip('"').strip("'")
        return value
    return ""


def _kiosk_autoenable_action(display_connected, installed, installing, active,
                             enable_flag, attempted_install, attempted_start):
    """Decide what the kiosk auto-enable watcher should do this tick.

    Returns "install", "start", or None. Pure so it is unit-testable; the
    loop supplies live state. Rules:
      - No display connected, or an install already in flight: do nothing.
      - ENABLE_KIOSK explicitly false: the owner opted out, never auto-act.
      - Kiosk never provisioned: install, once per bridge run (a failing
        install must not loop).
      - Provisioned but not running: start it, once per display connection
        (covers a kiosk installed while headless whose service exited).
      - Installed and running: nothing to do.
    """
    if not display_connected or installing:
        return None
    if str(enable_flag).strip().lower() in ("false", "0", "no", "off"):
        return None
    if not installed:
        return None if attempted_install else "install"
    if not active:
        return None if attempted_start else "start"
    return None


def _kiosk_autoenable_loop(interval=30):
    """Background watcher that turns a newly attached display into a running
    kiosk. Runs for the life of the bridge; every tick reads live state and
    lets _kiosk_autoenable_action decide. Attempt latches keep a failure
    from looping: one install per bridge run, one start per connection (a
    replug resets the start latch)."""
    attempted_install = False
    attempted_start = False
    while True:
        try:
            connected = bool(_drm_connected())
            if not connected:
                attempted_start = False
            action = _kiosk_autoenable_action(
                connected,
                _unit_installed(_KIOSK_UNIT),
                _installing("kiosk"),
                _service_active(_KIOSK_UNIT),
                _config_env_value("ENABLE_KIOSK"),
                attempted_install,
                attempted_start,
            )
            if action == "install":
                attempted_install = True
                ok, started, err = _start_provision("kiosk")
                if started:
                    print("kiosk auto-enable: display detected, provisioning the kiosk", flush=True)
                elif not ok:
                    print(f"kiosk auto-enable: install failed to start: {err}", flush=True)
            elif action == "start":
                attempted_start = True
                print("kiosk auto-enable: display detected, starting the installed kiosk", flush=True)
                subprocess.run(["systemctl", "start", _KIOSK_UNIT], timeout=30)
        except Exception:
            pass
        time.sleep(interval)


# Wi-Fi helpers
# -------------
# nmcli is always invoked in terse mode (-t -f) so the output is colon-separated
# and stable across versions. nmcli escapes literal colons in field values as
# "\:", so splitting must unescape them rather than a naive str.split(":").

def _nmcli_split(line):
    """Split one terse nmcli line into fields, honoring backslash escapes.

    nmcli escapes ':' and '\\' in values as '\\:' and '\\\\'. A naive split on
    ':' would break SSIDs that contain a colon, so walk the string instead.
    """
    fields = []
    cur = []
    i = 0
    while i < len(line):
        ch = line[i]
        if ch == "\\" and i + 1 < len(line):
            cur.append(line[i + 1])
            i += 2
            continue
        if ch == ":":
            fields.append("".join(cur))
            cur = []
            i += 1
            continue
        cur.append(ch)
        i += 1
    fields.append("".join(cur))
    return fields


def _parse_wifi_device(out):
    """Pick the wifi device from `nmcli -t -f DEVICE,TYPE,STATE device` output.

    Returns (device, state) for the first wifi device, or (None, None) when no
    wifi hardware is present. state is the raw nmcli state string, for example
    "connected", "disconnected", or "unmanaged".
    """
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = _nmcli_split(line)
        if len(parts) < 3:
            continue
        device, dtype, state = parts[0], parts[1], parts[2]
        if dtype == "wifi":
            return device, state
    return None, None


def _parse_active_ssid(out):
    """Connected SSID from `nmcli -t -f ACTIVE,SSID dev wifi`, or "" if none."""
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = _nmcli_split(line)
        if len(parts) >= 2 and parts[0] == "yes":
            return parts[1]
    return ""


def _parse_wifi_scan(out):
    """Parse `nmcli -t -f SSID,SIGNAL,SECURITY dev wifi list` output.

    Returns a list of {ssid, signal, security} dicts, hidden/blank SSIDs
    dropped, deduped by SSID (keeping the strongest signal), sorted by signal
    descending.
    """
    best = {}
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = _nmcli_split(line)
        if len(parts) < 1:
            continue
        ssid = parts[0]
        if not ssid:
            continue
        try:
            signal = int(parts[1]) if len(parts) > 1 and parts[1] else 0
        except ValueError:
            signal = 0
        security = parts[2] if len(parts) > 2 else ""
        prev = best.get(ssid)
        if prev is None or signal > prev["signal"]:
            best[ssid] = {"ssid": ssid, "signal": signal, "security": security}
    return sorted(best.values(), key=lambda n: n["signal"], reverse=True)


def _ethernet_status():
    """Best-effort wired status: {connected, device, ip}. Never raises.

    A Pi on Ethernet should not look offline just because Wi-Fi is idle
    (FoodAssistant-7r5), so the Wi-Fi status carries the wired state too. A
    physical interface counts as connected when its carrier is up and it holds
    an IPv4 address; virtual interfaces (docker, veth, bridges) are skipped.
    """
    try:
        for name in sorted(os.listdir("/sys/class/net")):
            if name == "lo" or name.startswith(("wlan", "ap", "docker", "veth", "br-", "tun", "tap", "vir")):
                continue
            try:
                carrier = Path(f"/sys/class/net/{name}/carrier").read_text().strip()
            except Exception:
                carrier = "0"
            if carrier != "1":
                continue
            ip = ""
            try:
                out = subprocess.run(
                    ["ip", "-4", "-o", "addr", "show", "dev", name],
                    capture_output=True, text=True, timeout=4
                ).stdout
                for tok in out.split():
                    if "/" in tok and tok[0].isdigit():
                        ip = tok.split("/")[0]
                        break
            except Exception:
                pass
            if ip:
                return {"connected": True, "device": name, "ip": ip}
        return {"connected": False, "device": "", "ip": ""}
    except Exception:
        return {"connected": False, "device": "", "ip": ""}


def _default_route_out():
    """Raw `ip route show default` output, or "" on any failure. Never raises.

    Sent back with the Wi-Fi status so the app can classify which link carries
    the network (FoodAssistant-1idf); the branching lives in the app so it can
    be unit tested without this root-only script.
    """
    try:
        return subprocess.run(
            ["ip", "route", "show", "default"],
            capture_output=True, text=True, timeout=4
        ).stdout
    except Exception:
        return ""


def _nm_running():
    """True when NetworkManager (nmcli) is reachable."""
    try:
        r = subprocess.run(
            ["nmcli", "-t", "-f", "RUNNING", "general"],
            capture_output=True, text=True, timeout=5
        )
        return r.returncode == 0 and "running" in r.stdout.lower()
    except Exception:
        return False


class _Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code, data):
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _body(self):
        n = int(self.headers.get("Content-Length", 0))
        return json.loads(self.rfile.read(n)) if n else {}

    def _authorized(self):
        """Token gate for this request; sends the 401 itself when denied."""
        verdict = _token_gate(
            self.command, self.path,
            self.headers.get("X-Bridge-Token", ""),
            _EXPECTED_TOKEN, GRACE_MODE,
        )
        if verdict == "deny":
            self._send(401, {"ok": False, "error": "missing or invalid X-Bridge-Token"})
            return False
        if verdict == "grace":
            print(
                f"bridge auth: allowing tokenless {self.command} {self.path} "
                "(grace mode; this will be denied in a future release)",
                flush=True,
            )
        return True

    # --- Display + activity coordination (FoodAssistant-otiy) -------------

    def _activity_get(self):
        """Current activity/display state, polled by the Stream Deck controller
        so a kiosk touch wakes the deck (shared activity, separate timeouts)."""
        with _activity_lock:
            self._send(200, {
                "ok": True,
                "last_activity": _activity_state["last_activity"],
                "display_blanked": _activity_state["display_blanked"],
                "idle_minutes": _activity_state["idle_minutes"],
                "wake_on_motion": _activity_state["wake_on_motion"],
                "motion_sensor": _activity_state["motion_sensor"],
            })

    def _activity_post(self):
        """Report user activity from either surface; wakes the display."""
        woke = _record_activity()
        with _activity_lock:
            last = _activity_state["last_activity"]
        self._send(200, {"ok": True, "woke": woke, "last_activity": last})

    def _display_blank(self):
        ok = _set_display_power(False)
        with _activity_lock:
            _activity_state["display_blanked"] = ok
        # A 500 on failure matters: the Stream Deck's screen-off key reads the
        # status code, so a 200 with ok=false made it show success while the
        # display stayed on (FoodAssistant-9la0).
        if ok:
            self._send(200, {"ok": True})
        else:
            self._send(500, {"ok": False, "error": _DISPLAY_POWER_ERROR})

    def _display_wake(self):
        ok = _set_display_power(True)
        with _activity_lock:
            _activity_state["display_blanked"] = False
            _activity_state["last_activity"] = time.time()
        if ok:
            self._send(200, {"ok": True})
        else:
            self._send(500, {"ok": False, "error": _DISPLAY_POWER_ERROR})

    def _display_idle_set(self):
        """Set (and persist) the display idle timeout, and optionally the
        wake-on-motion mode pushed alongside it."""
        body = self._body()
        try:
            minutes = max(0, int(body.get("minutes", 0)))
        except (TypeError, ValueError):
            self._send(400, {"ok": False, "error": "minutes must be an integer"})
            return
        mode = body.get("wake_on_motion")
        if mode is not None:
            mode = str(mode).strip().lower()
            if mode not in _WAKE_ON_MOTION_MODES:
                self._send(400, {
                    "ok": False,
                    "error": "wake_on_motion must be auto, on, or off",
                })
                return
        with _activity_lock:
            _activity_state["idle_minutes"] = minutes
            if mode is not None:
                _activity_state["wake_on_motion"] = mode
        persisted = _write_persisted_idle_minutes(minutes)
        if mode is not None:
            persisted = _write_persisted_wake_on_motion(mode) and persisted
        resp = {"ok": True, "minutes": minutes, "persisted": persisted}
        if mode is not None:
            resp["wake_on_motion"] = mode
        self._send(200, resp)

    # --- Forager remote-access tunnel (FoodAssistant-uczr) ----------------

    def _tunnel_keygen(self):
        """Generate a WireGuard keypair; keep the private key on the device.

        Returns only the public key to the caller. The private key is written
        to a root-only file for the up step and never logged or returned.
        """
        if not _wg_tools_present():
            self._send(500, {"ok": False, "error":
                "WireGuard is not installed on this device."})
            return
        try:
            priv = subprocess.run(
                ["wg", "genkey"], capture_output=True, text=True, timeout=10,
            ).stdout.strip()
            if not priv:
                self._send(500, {"ok": False, "error": "Could not generate a key."})
                return
            pub = subprocess.run(
                ["wg", "pubkey"], input=priv,
                capture_output=True, text=True, timeout=10,
            ).stdout.strip()
            if not pub:
                self._send(500, {"ok": False, "error": "Could not derive the public key."})
                return
            os.makedirs(os.path.dirname(_WG_PRIVATE_KEY_PATH), exist_ok=True)
            with open(_WG_PRIVATE_KEY_PATH, "w") as f:
                f.write(priv + "\n")
            os.chmod(_WG_PRIVATE_KEY_PATH, 0o600)
            self._send(200, {"ok": True, "public_key": pub})
        except Exception as e:
            # Never echo the key material; report only the class of failure.
            self._send(500, {"ok": False, "error":
                "Key generation failed: %s" % e.__class__.__name__})

    def _tunnel_up(self):
        """Write the interface config and bring it up (idempotent).

        Uses the private key from the request when given, otherwise the one
        stored by the last keygen. Persists the interface with systemd so it
        survives a reboot. The config text (which holds the private key) is
        never logged.
        """
        if not _wg_tools_present():
            self._send(500, {"ok": False, "error":
                "WireGuard is not installed on this device."})
            return
        body = self._body()
        private_key = (body.get("private_key") or "").strip()
        if not private_key:
            try:
                private_key = Path(_WG_PRIVATE_KEY_PATH).read_text().strip()
            except OSError:
                private_key = ""
        address = (body.get("address") or body.get("tunnel_ip") or "").strip()
        server_public_key = (body.get("server_public_key") or "").strip()
        endpoint = (body.get("endpoint") or "").strip()
        allowed_ips = (body.get("allowed_ips") or "").strip()
        dns = (body.get("dns") or "").strip()
        keepalive = body.get("keepalive", 25)
        missing = [name for name, val in (
            ("private_key", private_key), ("address", address),
            ("server_public_key", server_public_key), ("endpoint", endpoint),
            ("allowed_ips", allowed_ips),
        ) if not val]
        if missing:
            self._send(400, {"ok": False, "error":
                "Missing tunnel parameters: %s" % ", ".join(missing)})
            return
        try:
            config = _render_wg_config(
                private_key, address, server_public_key, endpoint,
                allowed_ips, dns=dns, keepalive=keepalive,
            )
            os.makedirs(os.path.dirname(_WG_CONFIG_PATH), exist_ok=True)
            # Idempotent: tear down any existing interface before re-applying,
            # so a re-enable with new parameters converges instead of erroring.
            subprocess.run(
                ["wg-quick", "down", _WG_INTERFACE],
                capture_output=True, text=True, timeout=30,
            )
            with open(_WG_CONFIG_PATH, "w") as f:
                f.write(config)
            os.chmod(_WG_CONFIG_PATH, 0o600)
            r = subprocess.run(
                ["wg-quick", "up", _WG_INTERFACE],
                capture_output=True, text=True, timeout=30,
            )
            if r.returncode != 0:
                self._send(500, {"ok": False, "error":
                    (r.stderr or r.stdout or "wg-quick up failed").strip()})
                return
            # Survive a reboot. Best effort: the interface is already up.
            subprocess.run(
                ["systemctl", "enable", "wg-quick@%s" % _WG_INTERFACE],
                capture_output=True, text=True, timeout=15,
            )
            self._send(200, {"ok": True, "interface": _WG_INTERFACE})
        except Exception as e:
            self._send(500, {"ok": False, "error":
                "Bringing the tunnel up failed: %s" % e.__class__.__name__})

    def _tunnel_down(self):
        """Take the interface down and stop persisting it (best effort)."""
        subprocess.run(
            ["wg-quick", "down", _WG_INTERFACE],
            capture_output=True, text=True, timeout=30,
        )
        subprocess.run(
            ["systemctl", "disable", "wg-quick@%s" % _WG_INTERFACE],
            capture_output=True, text=True, timeout=15,
        )
        self._send(200, {"ok": True})

    def _tunnel_status(self):
        """Whether the interface is up and its latest handshake age."""
        if not _wg_tools_present():
            self._send(200, {"ok": True, "up": False, "last_handshake_seconds": None})
            return
        try:
            r = subprocess.run(
                ["wg", "show", _WG_INTERFACE, "latest-handshakes"],
                capture_output=True, text=True, timeout=10,
            )
        except Exception:
            self._send(200, {"ok": True, "up": False, "last_handshake_seconds": None})
            return
        if r.returncode != 0:
            self._send(200, {"ok": True, "up": False, "last_handshake_seconds": None})
            return
        epoch = _parse_wg_handshakes(r.stdout)
        seconds = int(time.time() - epoch) if epoch > 0 else None
        self._send(200, {"ok": True, "up": True, "last_handshake_seconds": seconds})

    def do_GET(self):

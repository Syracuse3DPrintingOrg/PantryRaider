    def _provision(self, step, unit):
        if _installing(step):
            self._send(200, {"ok": True, "started": False, "message": "Already installing."})
            return
        ok, _started, err = _start_provision(step)
        if ok:
            self._send(200, {"ok": True, "started": True})
        else:
            self._send(500, {"ok": False, "error": err})

    def _ap_status(self):
        """Return whether the fallback AP is active.

        The flag file alone is not trusted: a device that has real network
        connectivity (a wired link, or any default route) does not need the
        setup hotspot, even if an earlier watchdog run raised it. In that case
        the AP is stood down here and reported inactive, so the settings page
        never shows the Wi-Fi setup banner on an ethernet-connected device
        (FoodAssistant-xt9b).
        """
        try:
            active = Path(_AP_FLAG).exists()
            if active and _has_lan_connectivity():
                try:
                    _ap_stand_down()
                except Exception:
                    pass
                active = False
            self._send(200, {"ok": True, "active": active})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _ap_disable(self):
        """Stop the fallback AP and remove the flag file."""
        try:
            _ap_stand_down()
            self._send(200, {"ok": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _update_channel_set(self):
        # Persist the update channel where the foodassistant-update helper reads
        # it (FoodAssistant-wkwx). The app cannot write /etc from its container,
        # so it lands the value here on settings save and before each update.
        body = self._body()
        channel = (body.get("channel") or "").strip()
        ok, err = _write_update_channel(channel)
        if not ok:
            self._send(400 if "channel must be" in err else 500,
                       {"ok": False, "error": err})
            return
        self._send(200, {"ok": True, "channel": channel})

    def _update(self):
        # Pull the latest source and redeploy by delegating to the
        # foodassistant-update helper. The bridge runs as root, so it can write
        # under /opt and restart the units (the app service cannot: its caps are
        # bound to CAP_NET_BIND_SERVICE).
        #
        # The helper redeploys both the web app and the Stream Deck package,
        # reinstalls venv deps only when requirements changed, and restarts
        # whichever services it refreshed. It is idempotent and safe to re-run
        # after a manual pull. It prints a human log to stdout and ends with a
        # single JSON line {ok, error, before, after, restarted, service_synced,
        # streamdeck_synced, deps_installed}. We parse that last line and pass
        # the full text back as "log" so the setup UI can show it. A pull that
        # fails to fast-forward leaves the checkout untouched (the helper still
        # redeploys the current HEAD); we never restart from here directly.
        helper = _ensure_helper("foodassistant-update")
        if not helper:
            self._send(500, {"ok": False, "error":
                "The update helper is missing on this device and there is no "
                "source checkout to restore it from. Re-run the installer "
                "(install.sh) on this device."})
            return
        try:
            # An update can pull, run pip, and restart, which on a Pi may take a
            # couple of minutes when requirements change. Keep the timeout
            # generous so a slow pip install does not look like a failure.
            r = subprocess.run(
                [helper], capture_output=True, text=True, timeout=600
            )
            out = (r.stdout or "").strip()
            result = {}
            if out:
                # The JSON summary is the last non-empty stdout line.
                last = out.splitlines()[-1].strip()
                try:
                    result = json.loads(last)
                except ValueError:
                    result = {}
            if not result:
                # The helper did not emit its summary line (it should always);
                # fall back to the return code and whatever it printed.
                self._send(500, {
                    "ok": False,
                    "error": (r.stderr or out or "update helper produced no output").strip(),
                    "log": out,
                })
                return
            result["log"] = out
            # Keep the latest update transcript on disk so the support bundle
            # can show what the last OTA did (best-effort, overwrite in place).
            try:
                with open(_SUPPORT_UPDATE_LOG, "w") as lf:
                    lf.write("=== foodassistant-update at %s ===\n%s\n"
                             % (time.strftime("%Y-%m-%d %H:%M:%S"), out))
            except OSError:
                pass
            self._send(200 if result.get("ok") else 500, result)
        except subprocess.TimeoutExpired:
            self._send(500, {"ok": False, "error": "update timed out"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _reboot(self):
        # Reboot the host. The bridge runs as root, so it can call systemctl
        # directly (the app service cannot: its caps are bound to
        # CAP_NET_BIND_SERVICE). We answer before the reboot takes effect; the
        # caller treats a dropped connection as success.
        cmd = _reboot_command()
        try:
            subprocess.Popen(cmd)
            self._send(200, {"ok": True, "rebooting": True})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    # --- One-image mode switch (FoodAssistant-dzx9) ------------------------

    def _stack_status(self):
        """Whether this device carries a local backend stack, and its state.

        hosted_stack is True when the deployed compose file defines the backend
        services (the appliance layout). A device flashed as a Pi Remote has no
        such compose file (or the remote one, which defines none), so the switch
        endpoints below can never act on it.
        """
        try:
            services = _compose_backend_services(_read_stack_compose())
            self._send(200, {
                "ok": True,
                "hosted_stack": bool(services),
                "services": {
                    name: _container_running("foodassistant-%s" % name)
                    for name in services
                },
            })
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _stack_standdown(self):
        """Stop the local backend containers so the device can act as a
        satellite. Containers and data directories are kept, never removed, so
        the stack can be resumed later exactly as it was. Idempotent: stopping
        an already-stopped (or never-created) service is a no-op.
        """
        services = _compose_backend_services(_read_stack_compose())
        if not services:
            self._send(400, {"ok": False, "error":
                "This device has no local inventory stack to stand down."})
            return
        try:
            r = subprocess.run(
                _stack_stop_cmd(services), cwd=INSTALL_DIR, env=_compose_env(),
                capture_output=True, text=True, timeout=300,
            )
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            self._send(200, {"ok": True, "stopped": services})
        except subprocess.TimeoutExpired:
            self._send(500, {"ok": False, "error": "stopping the local stack timed out"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _stack_standup(self):
        """Start the parked local backend stack again (the switch back).

        A plain compose up from the install dir: the persisted COMPOSE_PROFILES
        restores exactly the optional services (Mealie/Ollama) that were enabled
        before the stand-down. Idempotent: running services are left alone.
        """
        services = _compose_backend_services(_read_stack_compose())
        if not services:
            self._send(400, {"ok": False, "error":
                "This device has no parked local stack to start."})
            return
        try:
            r = subprocess.run(
                _stack_up_cmd(), cwd=INSTALL_DIR, env=_compose_env(),
                capture_output=True, text=True, timeout=600,
            )
            if r.returncode != 0:
                self._send(500, {"ok": False, "error": (r.stderr or r.stdout).strip()})
                return
            self._send(200, {"ok": True, "started": services})
        except subprocess.TimeoutExpired:
            self._send(500, {"ok": False, "error": "starting the local stack timed out"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def _usb_photos_list(self):
        """GET /usb/photos: image names in the drive's photos folder. Always
        answers; no drive or no folder is just an empty list, never an error,
        so the screensaver can quietly fall back to the bouncing logo."""
        try:
            pdir, _reason = _usb_photos_status()
            if not pdir:
                self._send(200, {"ok": True, "photos": []})
                return
            self._send(200, {"ok": True, "photos": _usb_photo_names(pdir)})
        except Exception as e:
            self._send(200, {"ok": False, "photos": [], "error": str(e)})

    def _usb_photo_serve(self):
        """GET /usb/photo?path=name: serve one image from the photos folder.
        Read-only; the name must resolve to a regular image file directly
        inside that folder and stay under the size cap. HEIC/HEIF sources are
        transcoded to JPEG on the way out so a browser can display them; the
        size cap is checked on the source file either way."""
        try:
            query = urllib.parse.urlsplit(self.path).query
            name = (urllib.parse.parse_qs(query).get("path") or [""])[0]
            pdir, _reason = _usb_photos_status()
            full = _usb_photo_safe_path(pdir, name) if pdir else None
            if not full or os.path.getsize(full) > _USB_PHOTO_MAX_BYTES:
                self._send(404, {"error": "photo not found"})
                return
            if _usb_photo_is_heic(full):
                body = _heic_transcode(full)
                if body is None:
                    # heif-convert missing or failed: skip this frame cleanly
                    # rather than 500 so the slideshow moves on.
                    self._send(415, {"error": "cannot transcode HEIC photo"})
                    return
            else:
                with open(full, "rb") as f:
                    body = f.read()
        except Exception as e:
            self._send(500, {"error": str(e)})
            return
        ctype = _USB_PHOTO_TYPES.get(
            os.path.splitext(full)[1].lower(), "application/octet-stream")
        self.send_response(200)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _usb_status(self):
        """Attached USB flash drive status for the app's Backup pane."""
        self._send(200, _usb_drive_status())

    def _usb_backup(self):
        """Snapshot the data dirs into pantryraider-backups/ on the drive.

        Same content as scripts/backup.sh: a tar of the bind-mounted data dirs
        that exist under the install dir (app data always; Grocy and Mealie on
        a Pi Hosted box), so the file restores with foodassistant-restore. The
        archive is written to a temp name and renamed, so a yanked drive never
        leaves a half-written file looking like a good backup, and the newest
        14 backups are kept.
        """
        status = _usb_drive_status()
        if not status.get("detected"):
            self._send(400, {"ok": False, "error": status.get(
                "error",
                "No USB drive found. Plug in a drive that is already formatted "
                "and mounted, then try again.")})
            return
        dirs = _usb_data_dirs()
        if not dirs:
            self._send(400, {"ok": False, "error":
                "No data directories found under %s; nothing to back up." % INSTALL_DIR})
            return
        bdir = os.path.join(status["mountpoint"], _USB_BACKUP_DIRNAME)
        name = "foodassistant-usb-%s.tar.gz" % time.strftime("%Y%m%d-%H%M%S")
        final = os.path.join(bdir, name)
        tmp = os.path.join(bdir, "." + name + ".part")
        try:
            os.makedirs(bdir, exist_ok=True)
            r = subprocess.run(
                ["tar", "-czf", tmp, "-C", INSTALL_DIR] + dirs,
                capture_output=True, text=True, timeout=600,
            )
            if r.returncode != 0:
                try:
                    os.unlink(tmp)
                except OSError:
                    pass
                self._send(500, {"ok": False, "error":
                    (r.stderr or "tar failed").strip()[:400]})
                return
            os.replace(tmp, final)
        except subprocess.TimeoutExpired:
            try:
                os.unlink(tmp)
            except OSError:
                pass
            self._send(500, {"ok": False, "error": "The backup timed out; the drive may be too slow or full."})
            return
        except OSError as e:
            self._send(500, {"ok": False, "error": "Could not write to the drive: %s" % e})
            return
        deleted = []
        for victim in _usb_rotation_victims(os.listdir(bdir)):
            try:
                os.unlink(os.path.join(bdir, victim))
                deleted.append(victim)
            except OSError:
                pass
        try:
            size = os.stat(final).st_size
        except OSError:
            size = 0
        self._send(200, {"ok": True, "file": final, "bytes": size,
                         "dirs": dirs, "deleted": deleted})

    def _restore(self):
        # Restore the FULL stack snapshot (Grocy + Mealie + app data) by
        # delegating to the foodassistant-restore helper. The bridge runs as
        # root, so it can stop/start the docker stack and swap the data dirs;
        # the app container cannot. This mirrors _update: we validate the body,
        # run the helper synchronously, parse its LAST stdout line as JSON, and
        # relay it with the full text as "log".
        #
        # Design (the bead's open question): we do NOT accept a browser upload
        # of the large snapshot. The body's {source} is either an absolute path
        # to a .tar.gz already on the device, or "rclone:<remote-path>" to pull
        # from the configured rclone remote first. The helper itself also
        # resolves rclone sources, but we validate the shape here so a bad
        # source fails fast with a clear error and never reaches the stack.
        helper = _ensure_helper("foodassistant-restore")
        if not helper:
            self._send(500, {"ok": False, "error":
                "The restore helper is missing on this device. Press Update "
                "under Backup & Updates to install it, then try again."})
            return
        body = self._body()
        kind, value = _classify_restore_source(body.get("source", ""))
        if kind == "invalid":
            self._send(400, {"ok": False, "error": value})
            return
        try:
            env = dict(os.environ)
            env.setdefault("INSTALL_DIR", INSTALL_DIR)
            env.setdefault("RCLONE_CONFIG", _RCLONE_CONFIG)
            # Stopping the stack, pulling a possibly-large snapshot, unpacking,
            # and restarting can take a while on a Pi, so keep the timeout
            # generous (the proxy's timeout is matched to this).
            r = subprocess.run(
                [helper, body.get("source", "").strip()],
                capture_output=True, text=True, timeout=900, env=env,
            )
            out = (r.stdout or "").strip()
            result = {}
            if out:
                last = out.splitlines()[-1].strip()
                try:
                    result = json.loads(last)
                except ValueError:
                    result = {}
            if not result:
                self._send(500, {
                    "ok": False,
                    "error": (r.stderr or out or "restore helper produced no output").strip(),
                    "log": out,
                })
                return
            result["log"] = out
            self._send(200 if result.get("ok") else 500, result)
        except subprocess.TimeoutExpired:
            self._send(500, {"ok": False, "error": "restore timed out"})
        except Exception as e:
            self._send(500, {"ok": False, "error": str(e)})

    def log_message(self, *_):
        pass



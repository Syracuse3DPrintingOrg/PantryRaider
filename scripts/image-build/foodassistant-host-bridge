# --- Display + activity coordination (FoodAssistant-otiy) -----------------
# The bridge is the one process both the kiosk browser and the Stream Deck
# controller can reach, so it brokers "user activity" between them and owns the
# physical display power. The kiosk display and the Stream Deck keep SEPARATE
# idle timeouts (the deck times itself out locally), but activity on either
# surface is reported here and wakes both: this loop wakes the display, and the
# deck polls GET /activity to wake itself.
#
# The display idle timeout (minutes, 0 = off) is pushed by the app on settings
# save and persisted here so it survives a bridge restart.
_DISPLAY_IDLE_FILE = "/etc/foodassistant/display-idle"

# Wake on motion (FoodAssistant-fr5). When an LSM6DSOX accelerometer is fitted
# (the same part the boot rotation helper reads), physically moving or bumping
# the device counts as user activity and wakes a blanked display. The mode is
# pushed by the app on settings save and persisted here: "auto" turns it on
# exactly when the sensor is present, "on" and "off" force it. On hardware
# without the sensor every mode is a safe no-op.
_WAKE_ON_MOTION_FILE = "/etc/foodassistant/wake-on-motion"
_WAKE_ON_MOTION_MODES = ("auto", "on", "off")

# Update channel (FoodAssistant-wkwx). The app pushes it on settings save (and
# again just before each update), and the foodassistant-update helper reads the
# file to decide what to install: "main" follows the branch tip, "stable" checks
# out the newest release tag. Absent file means "main" (the historical behavior).
_UPDATE_CHANNEL_FILE = "/etc/foodassistant/update-channel"
_UPDATE_CHANNELS = ("stable", "main")


def _write_update_channel(channel, path=None):
    """Persist the update channel for the OTA helper. Returns (ok, error)."""
    if channel not in _UPDATE_CHANNELS:
        return False, "channel must be 'stable' or 'main'"
    p = Path(path or _UPDATE_CHANNEL_FILE)
    try:
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(channel + "\n")
        return True, ""
    except OSError as e:
        return False, str(e)

# Minimum change of the acceleration vector between samples, in g, that counts
# as motion. At rest the sensor reports a steady ~1 g gravity vector with noise
# well under 0.02 g, so 0.08 g means a real nudge, tilt, or lift.
_MOTION_THRESHOLD_G = 0.08


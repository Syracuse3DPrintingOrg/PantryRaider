# input list when applying a calibration matrix. Mirrors the app's detection.
_TOUCH_NAME_HINTS = (
    "touch", "ads7846", "goodix", "ft5x", "ft6", "edt-ft5", "ilitek", "ili2",
    "silead", "eeti", "egalax", "hynitron", "st1633", "gslx680", "stmpe",
    "raspberrypi-ts", "waveshare", "hosyond", "chipone", "cst", "zforce",

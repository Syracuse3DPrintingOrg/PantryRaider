main() {
  log "=== FoodAssistant print stack setup ==="
  install_packages || warn "Package install did not fully succeed; continuing with configuration."
  enable_services
  add_to_lpadmin
  configure_cupsd
  configure_cups_sharing
  install_cups_browsed
  install_label_ppds
  if bluetooth_printing_enabled; then
    log "Bluetooth printing opted in; installing the Supvan bridge."
    install_supvan_bridge
  else
    log "Bluetooth printing not enabled; skipping the Supvan bridge (set ENABLE_BLUETOOTH_PRINTING=1 to install it). The base network print stack is ready."
  fi
  # Validate and repair cupsd.conf LAST, so a broken config from any step (or a
  # prior version) is healed before we restart, and the scheduler always comes
  # back up. Then restart cups so the final config (repaired or not) is live.
  heal_cupsd_conf
  if command -v systemctl >/dev/null 2>&1; then
    systemctl restart cups >/dev/null 2>&1 || true
  fi
  write_env_fragment
  log "=== Print stack setup complete ==="
  log "Bring the app up to apply: cd $INSTALL_DIR && docker compose up -d"
}

# Allow sourcing for tests without running main().
if [ "${FA_PRINT_SETUP_SOURCE:-0}" != "1" ]; then
  main "$@"
fi

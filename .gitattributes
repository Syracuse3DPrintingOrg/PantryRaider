# Auto detect text files and perform LF normalization
* text=auto

# Force LF for files that must be executed on Linux regardless of checkout OS.
# Windows git clients convert to CRLF by default; CRLF in bash/service files
# causes "invalid option" and "bad interpreter" errors on the Pi.
*.sh text eol=lf
*.service text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
